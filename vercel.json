{
  "trailingSlash": false,
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/admin/cleanup-pending",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/.git/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ],
  "redirects": [
    {
      "source": "/apple-app-site-association",
      "destination": "/",
      "permanent": false
    }
  ]
}
