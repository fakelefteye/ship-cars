---
const { title = "Ship Cars — Location de véhicules à Grenoble" } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Ship Cars — Location de véhicules à Grenoble, proche de la gare. Réservation en ligne, paiement sécurisé." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        /* Ship Cars — charte couleurs logo */
        --navy-deep:   #0a1421;   /* fond principal — bleu nuit profond */
        --navy:        #0f1e33;   /* fond carte */
        --navy-light:  #1a2d47;   /* fond carte hover */
        --navy-accent: #20385a;   /* bordure accent */

        --teal:        #4dd4c8;   /* teal du "Ship" */
        --teal-bright: #5eead4;   /* variante claire */
        --teal-soft:   rgba(77,212,200,0.12);

        --silver:      #d4d8de;   /* argenté du "CARS" */
        --silver-dim:  #a8afbd;

        /* alias fonctionnels */
        --bg:          var(--navy-deep);
        --bg-2:        var(--navy);
        --bg-3:        var(--navy-light);
        --border:      rgba(212,216,222,0.08);
        --border-md:   rgba(77,212,200,0.22);
        --gold:        var(--teal);         /* ancien accent gold -> teal */
        --gold-light:  var(--teal-bright);
        --text:        #f0f3f7;
        --text-muted:  #8a95a8;
        --text-dim:    #55627a;
        --green:       #3ecf8e;
        --radius:      12px;
        --radius-lg:   20px;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(10,20,33,0.88);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--border);
        padding: 0 2rem;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nav-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1.2rem;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .nav-logo-mark {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        flex-shrink: 0;
        overflow: hidden;
      }

      .nav-logo-mark img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }

      .nav-logo em { color: var(--teal); font-style: normal; }

      .nav-right { display: flex; align-items: center; gap: 1.5rem; }

      .nav-pill {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.78rem;
        color: var(--text-muted);
        background: var(--bg-2);
        border: 1px solid var(--border);
        padding: 5px 12px;
        border-radius: 99px;
      }

      .nav-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        animation: blink 2.4s ease-in-out infinite;
        flex-shrink: 0;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.3; }
      }

      .nav-admin {
        font-size: 0.75rem;
        color: var(--text-dim);
        text-decoration: none;
        padding: 5px 12px;
        border: 1px solid var(--border);
        border-radius: 6px;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
        font-family: 'DM Sans', sans-serif;
        letter-spacing: 0.02em;
      }
      .nav-admin:hover { color: var(--text-muted); border-color: var(--border-md); background: var(--bg-2); }

      main { flex: 1; }

      .footer {
        margin-top: 5rem;
        border-top: 1px solid var(--border);
        padding: 2.5rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .footer-brand {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-muted);
      }
      .footer-brand em { color: var(--teal); font-style: normal; }

      .footer-info {
        font-size: 0.78rem;
        color: var(--text-dim);
        text-align: right;
        line-height: 1.7;
      }

      .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

      a { color: inherit; }

      ::selection { background: var(--teal); color: var(--navy-deep); }

      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--bg-3); border-radius: 3px; }

      @media (max-width: 600px) {
        .nav { padding: 0 1rem; }
        .nav-pill { display: none; }
        .footer { flex-direction: column; text-align: center; }
        .footer-info { text-align: center; }
      }
    </style>
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="nav-logo">
        <div class="nav-logo-mark">
          <img src="/logo.png" alt="Ship Cars" />
        </div>
        Ship<em>Cars</em>
      </a>
      <div class="nav-right">
        <div class="nav-pill">
          <div class="nav-pill-dot"></div>
          Grenoble · Proche gare
        </div>
      </div>
    </nav>

    <main><slot /></main>

    <footer class="footer">
      <div class="footer-brand">Ship<em>Cars</em></div>
      <div class="footer-info">
        © 2026 Ship Cars · Grenoble, proche de la gare<br>
        Paiement sécurisé via Stripe · Caution par empreinte bancaire
      </div>
    </footer>
  </body>
</html>
