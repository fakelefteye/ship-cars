---
import Analytics from '@vercel/analytics/astro';
const { title = "Ship Cars — Location de véhicules à Grenoble" } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo_ship_cars.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Ship Cars — Location de véhicules à Grenoble, proche de la gare. Réservation en ligne, paiement sécurisé." />
    <title>{title}</title>
    <slot name="head" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NLLG4BH3');</script>
    <!-- End Google Tag Manager -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        /* Ship Cars — charte couleurs logo */
        --navy-deep:   #0a1421;   /* fond principal — bleu nuit profond */
        --navy:        #0f1e33;   /* fond carte */
        --navy-light:  #1a2d47;   /* fond carte hover */
        --navy-accent: #20385a;   /* bordure accent */

        --teal:        #4dd4c8;   /* teal du "Ship" */
        --teal-bright: #5eead4;   /* variante claire */
        --teal-soft:   rgba(77,212,200,0.12);

        --silver:      #d4d8de;   /* argenté du "CARS" */
        --silver-dim:  #a8afbd;

        /* alias fonctionnels */
        --bg:          var(--navy-deep);
        --bg-2:        var(--navy);
        --bg-3:        var(--navy-light);
        --border:      rgba(212,216,222,0.08);
        --border-md:   rgba(77,212,200,0.22);
        --gold:        var(--teal);         /* ancien accent gold -> teal */
        --gold-light:  var(--teal-bright);
        --text:        #f0f3f7;
        --text-muted:  #8a95a8;
        --text-dim:    #55627a;
        --green:       #3ecf8e;
        --radius:      12px;
        --radius-lg:   20px;
      }

      /* ── Maintenance banner ── */
      .maintenance-banner {
        background: linear-gradient(135deg,#ea580c,#f97316);
        color:#fff; position:sticky; top:64px; z-index:99;
        box-shadow:0 2px 20px rgba(249,115,22,.4);
      }
      .maintenance-inner {
        max-width:1200px; margin:0 auto; padding:.9rem 2rem;
        display:flex; align-items:center; gap:1rem; flex-wrap:wrap;
      }
      .maintenance-icon { font-size:1.4rem; flex-shrink:0; }
      .maintenance-inner > div { flex:1; min-width:0; }
      .maintenance-inner strong { display:block; font-size:1.1rem; font-weight:800; margin-bottom:.1rem; }
      .maintenance-inner span { font-size:.88rem; opacity:.95; }
      .maintenance-inner span a { color:#fff; font-weight:700; text-decoration:underline; }
      .maintenance-wa {
        display:inline-flex; align-items:center; gap:6px;
        background:#25d366; color:#fff !important; font-weight:700;
        font-size:.85rem; padding:.55rem 1.1rem; border-radius:8px;
        text-decoration:none !important; white-space:nowrap; flex-shrink:0;
        box-shadow:0 2px 8px rgba(0,0,0,.2); transition:opacity .15s;
      }
      .maintenance-wa:hover { opacity:.9; }

      /* ── Zone restriction notice ── */
      .zone-notice {
        display:flex; align-items:center; gap:.7rem;
        background:rgba(77,212,200,.08); border:1px solid rgba(77,212,200,.25);
        border-radius:10px; padding:.7rem 1rem; font-size:.83rem;
        color:var(--text-muted,#8a95a8); line-height:1.5;
      }
      .zone-notice strong { color:var(--teal,#4dd4c8); }
      .zone-notice a { color:var(--teal,#4dd4c8); font-weight:600; text-decoration:underline; white-space:nowrap; }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Exo 2', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(10,20,33,0.88);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--border);
        padding: 0 2rem;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nav-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        font-family: 'Exo 2', sans-serif;
        font-weight: 800;
        font-size: 1.2rem;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .nav-logo-mark {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        flex-shrink: 0;
        overflow: hidden;
      }

      .nav-logo-mark img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }

      .nav-logo em { color: var(--teal); font-style: normal; }

      .nav-right { display: flex; align-items: center; gap: 1.5rem; }

      .nav-pill {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.78rem;
        color: var(--text-muted);
        background: var(--bg-2);
        border: 1px solid var(--border);
        padding: 5px 12px;
        border-radius: 99px;
      }

      .nav-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        animation: blink 2.4s ease-in-out infinite;
        flex-shrink: 0;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.3; }
      }

      .nav-admin {
        font-size: 0.75rem;
        color: var(--text-dim);
        text-decoration: none;
        padding: 5px 12px;
        border: 1px solid var(--border);
        border-radius: 6px;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
        font-family: 'Exo 2', sans-serif;
        letter-spacing: 0.02em;
      }
      .nav-admin:hover { color: var(--text-muted); border-color: var(--border-md); background: var(--bg-2); }

      .nav-blog {
        font-size: 0.78rem;
        color: var(--text-muted);
        text-decoration: none;
        font-family: 'Exo 2', sans-serif;
        font-weight: 500;
        letter-spacing: 0.02em;
        transition: color 0.15s;
      }
      .nav-blog:hover { color: var(--teal); }

      main { flex: 1; }

      .footer {
        margin-top: 5rem;
        border-top: 1px solid var(--border);
        padding: 2rem 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }

      .footer-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.25rem;
      }

      .footer-brand {
        font-family: 'Exo 2', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-muted);
      }
      .footer-brand em { color: var(--teal); font-style: normal; }

      .footer-links {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
      }

      .footer-links a {
        font-size: 0.76rem;
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.15s;
        letter-spacing: 0.01em;
      }
      .footer-links a:hover { color: var(--teal); }

      .footer-info {
        font-size: 0.78rem;
        color: var(--text-dim);
        text-align: right;
        line-height: 1.7;
      }

      .footer-contact {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        padding-top: 0.75rem;
        border-top: 1px solid var(--border);
        font-size: 0.8rem;
        color: var(--text-dim);
      }
      .footer-contact-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .footer-contact-item svg { opacity: 0.6; flex-shrink: 0; }
      .footer-contact a {
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.15s;
      }
      .footer-contact a:hover { color: var(--teal); }
      .footer-contact-sep { opacity: 0.4; }

      .footer-promo {
        font-size: 0.78rem;
        color: var(--text-dim);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .footer-promo a {
        color: var(--teal);
        text-decoration: none;
        font-weight: 600;
        transition: opacity 0.15s;
      }
      .footer-promo a:hover { opacity: 0.75; }

      .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

      a { color: inherit; }

      ::selection { background: var(--teal); color: var(--navy-deep); }

      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--bg-3); border-radius: 3px; }

      @media (max-width: 600px) {
        .nav { padding: 0 1rem; }
        .nav-pill { display: none; }
        .footer { flex-direction: column; align-items: center; text-align: center; }
        .footer-links { justify-content: center; }
        .footer-info { text-align: center; }
      }
    </style>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NLLG4BH3"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <nav class="nav">
      <a href="/" class="nav-logo">
        <div class="nav-logo-mark">
          <img src="/logo_ship_cars.png" alt="Ship Cars" />
        </div>
        Ship<em>Cars</em>
      </a>
      <div class="nav-right">
        <a href="/blog" class="nav-blog">Blog</a>
        <a href="/faq" class="nav-blog">FAQ</a>
        <div class="nav-pill">
          <div class="nav-pill-dot"></div>
          Grenoble · Proche gare
        </div>
      </div>
    </nav>

    <main><slot /></main>
    <Analytics />

    <footer class="footer">
      <div class="footer-top">
        <div class="footer-brand">Ship<em>Cars</em></div>
        <div class="footer-links">
          <a href="/location-voiture-grenoble">Location Grenoble</a>
          <a href="/location-voiture-gare-grenoble">Gare de Grenoble</a>
          <a href="/location-voiture-pas-cher-grenoble">Tarifs</a>
          <a href="/blog">Blog</a>
          <a href="/faq">FAQ</a>
          <a href="/zones">Zones</a>
          <a href="/cgu">CGU</a>
          <a href="/confidentialite">Confidentialité</a>
        </div>
        <div class="footer-info">
          © 2026 Ship Cars · Grenoble, proche de la gare<br>
          Paiement sécurisé via Stripe · Caution par empreinte bancaire
        </div>
      </div>

      <div class="footer-contact">
        <span class="footer-contact-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
          <span class="obf-contact" data-u="contact" data-d="shipcars" data-tld="fr"></span>
        </span>
        <span class="footer-contact-sep">·</span>
        <span class="footer-contact-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="obf-contact" data-type="wa" data-n="33661691178" data-display="06 61 69 11 78"></span>
        </span>
      </div>

      <div class="footer-promo">
        Vous voulez un site comme celui-ci ?
        <span class="obf-contact" data-type="promo" data-u="contact" data-d="shipcars" data-tld="fr"></span>
      </div>
    </footer>

    <script>
      document.querySelectorAll('.obf-contact').forEach(el => {
        const type = el.dataset.type || 'email';
        if (type === 'email') {
          const addr = el.dataset.u + '@' + el.dataset.d + '.' + el.dataset.tld;
          const a = document.createElement('a');
          a.href = 'mailto:' + addr;
          a.textContent = addr;
          el.appendChild(a);
        } else if (type === 'wa') {
          const a = document.createElement('a');
          a.href = 'https://wa.me/' + el.dataset.n;
          a.target = '_blank';
          a.rel = 'noopener';
          a.textContent = el.dataset.display + ' (WhatsApp)';
          el.appendChild(a);
        } else if (type === 'promo') {
          const addr = el.dataset.u + '@' + el.dataset.d + '.' + el.dataset.tld;
          const a = document.createElement('a');
          a.href = 'mailto:' + addr;
          a.textContent = 'Contactez-nous →';
          el.appendChild(a);
        }
      });
    </script>
  </body>
</html>
