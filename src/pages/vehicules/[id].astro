---
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const { id } = Astro.params;

const { data: vehicule, error } = await supabaseAdmin
  .from('vehicules')
  .select('*')
  .eq('id', id)
  .single();

if (error || !vehicule) {
  return Astro.redirect('/404');
}

const photos = [
  vehicule.image_url,
  vehicule.image_url_2,
  vehicule.image_url_3,
  vehicule.image_url_4,
  vehicule.image_url_5
].filter(url => url !== null && url !== "");
---

<MainLayout title={`${vehicule.nom} — Ship Cars`}>
  <div class="container detail-container">

    <a href="/" class="back-link">← Retour au catalogue</a>

    <div class="detail-grid">

      <!-- GALERIE -->
      <section class="gallery">
        <div class="main-img-wrap">
          <img src={photos[0]} alt={vehicule.nom} id="current-img" />
          <div class="img-overlay"></div>
        </div>
        {photos.length > 1 && (
          <div class="thumbs">
            {photos.map((url, i) => (
              <button
                class={`thumb ${i === 0 ? 'active' : ''}`}
                onclick={`switchPhoto('${url}', this)`}
                type="button"
              >
                <img src={url} alt={`Photo ${i + 1}`} />
              </button>
            ))}
          </div>
        )}
      </section>

      <!-- INFOS + RÉSA -->
      <aside class="info-panel">

        <header class="panel-header">
          <p class="panel-label">{vehicule.modele} · {vehicule.annee}</p>
          <h1 class="panel-title">{vehicule.nom}</h1>
          <div class="panel-price">
            <span class="price-amount">{vehicule.prix_journalier_base}€</span>
            <span class="price-unit">/ jour</span>
          </div>
          <div class="panel-included">
            <span class="included-icon">🛣️</span>
            <span><strong>100 km/jour inclus</strong> dans la location</span>
          </div>
        </header>

        <div class="panel-divider"></div>

        <div class="resa-section">
          <h2 class="resa-title">📅 Réserver ce véhicule</h2>

          <div class="form-group">
            <label class="form-label">Départ et retour</label>
            <div class="date-trigger" id="date-trigger" role="button" tabindex="0">
              <div class="date-pill">
                <span class="date-pill-icon">🚗</span>
                <div class="date-pill-content">
                  <span class="date-pill-label">Départ</span>
                  <span class="date-pill-value" id="start-display">Choisir une date</span>
                </div>
              </div>
              <div class="date-pill-sep">→</div>
              <div class="date-pill">
                <span class="date-pill-icon">🔙</span>
                <div class="date-pill-content">
                  <span class="date-pill-label">Retour</span>
                  <span class="date-pill-value" id="end-display">Choisir une date</span>
                </div>
              </div>
            </div>
            <input type="text" id="date-range" class="hidden-picker-input" readonly aria-hidden="true" />
            <div class="calendar-legend">
              <span class="legend-item"><span class="legend-dot available"></span>Disponible</span>
              <span class="legend-item"><span class="legend-dot partial"></span>Partiellement</span>
              <span class="legend-item"><span class="legend-dot occupied"></span>Occupé</span>
            </div>
          </div>

          <div id="conflict-error" class="conflict-error" style="display:none;">
            ⚠️ Créneau en conflit avec une réservation existante. Veuillez ajuster vos horaires.
          </div>

          <!-- Option siège auto -->
          <label class="option-card" id="siege-card">
            <input type="checkbox" id="siege-checkbox" disabled />
            <div class="option-content">
              <div class="option-header">
                <span class="option-icon">👶</span>
                <div class="option-text">
                  <span class="option-title">Siège auto enfant</span>
                  <span class="option-desc" id="siege-status">Sélectionnez vos dates pour vérifier la disponibilité</span>
                </div>
                <span class="option-price" id="siege-price"></span>
              </div>
            </div>
          </label>

          <!-- Code promo -->
          <div class="promo-input-group" id="promo-group" style="display:none;">
            <label class="form-label" for="promo-code-input">Code promo (optionnel)</label>
            <div class="promo-input-row">
              <input type="text" id="promo-code-input" placeholder="Ex: GNB10" autocomplete="off" />
              <button type="button" id="promo-apply-btn" class="btn-promo-apply">Appliquer</button>
            </div>
            <p class="promo-feedback" id="promo-feedback"></p>
          </div>

          <div id="resa-summary" style="display:none;">
            <div class="summary-box">
              <div class="summary-row">
                <span>Durée</span>
                <strong id="duration-text">—</strong>
              </div>
              <div class="summary-row">
                <span>Location</span>
                <strong id="location-amount">—</strong>
              </div>
              <div class="summary-row" id="siege-row" style="display:none;">
                <span>Siège auto</span>
                <strong id="siege-amount">—</strong>
              </div>
              <div class="summary-row promo-row" id="promo-row" style="display:none;">
                <span>Code promo <em id="promo-row-code"></em></span>
                <strong id="promo-amount">—</strong>
              </div>
              <div class="summary-row included-row">
                <span>🛣️ Kilométrage</span>
                <strong><span id="km-included">—</span> inclus</strong>
              </div>
              <div class="summary-row">
                <span>Total</span>
                <strong class="summary-total" id="total-amount">—</strong>
              </div>
            </div>
            <div class="caution-notice">
              <div class="caution-icon">⚠️</div>
              <div>
                <strong>Caution : 800 €</strong>
                <p>Pré-autorisation bancaire après le paiement — aucune somme débitée.</p>
              </div>
            </div>
          </div>

          <button id="btn-book" class="btn-book" disabled>
            Payer la location
          </button>
          <p class="secure-note">🔒 Paiement sécurisé via Stripe</p>
        </div>

      </aside>
    </div>
  </div>
  <!-- MODAL COORDONNÉES LOCATAIRE -->
  <div id="modal-locataire" class="modal-overlay" style="display:none;" role="dialog" aria-modal="true">
    <div class="modal-box">
      <button class="modal-close" id="modal-close" aria-label="Fermer">×</button>
      <h2 class="modal-title">Vos coordonnées</h2>
      <p class="modal-sub">Requis pour générer votre contrat de location. Données sécurisées.</p>

      <form id="form-locataire" class="locataire-form" novalidate>
        <div class="form-row-2">
          <div class="form-field">
            <label class="field-label" for="loc-nom">Nom et prénom *</label>
            <input type="text" id="loc-nom" placeholder="Jean Dupont" autocomplete="name" required />
          </div>
          <div class="form-field">
            <label class="field-label" for="loc-email">Email *</label>
            <input type="email" id="loc-email" placeholder="jean@email.com" autocomplete="email" required />
          </div>
        </div>
        <div class="form-row-2">
          <div class="form-field">
            <label class="field-label" for="loc-naissance">Date de naissance *</label>
            <input type="date" id="loc-naissance" required />
          </div>
          <div class="form-field">
            <label class="field-label" for="loc-permis">N° de permis *</label>
            <input type="text" id="loc-permis" placeholder="14AB12345" autocomplete="off" required />
          </div>
        </div>
        <div class="form-row-2">
          <div class="form-field">
            <label class="field-label" for="loc-permis-date">Date d'obtention du permis *</label>
            <input type="date" id="loc-permis-date" required />
          </div>
          <div class="form-field">
            <label class="field-label" for="loc-adresse">Adresse complète *</label>
            <input type="text" id="loc-adresse" placeholder="4 rue des Fleurs, 38000, Grenoble" autocomplete="street-address" required />
          </div>
        </div>

        <div id="modal-error" class="modal-error" style="display:none;"></div>

        <button type="submit" id="btn-modal-submit" class="btn-modal-submit">
          Continuer vers le paiement →
        </button>
        <p class="modal-secure">🔒 Paiement sécurisé via Stripe · Données chiffrées</p>
      </form>
    </div>
  </div>
</MainLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

<script is:inline>
  function switchPhoto(url, btn) {
    document.getElementById('current-img').src = url;
    document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
  }
</script>

<script define:vars={{ prixJournalier: vehicule.prix_journalier_base, vehiculeId: vehicule.id }}>
  async function initCalendar() {
    let reservations = [];
    try {
      const res = await fetch(`/api/reservations/occupied-dates?id=${vehiculeId}`);
      if (res.ok) {
        const raw = await res.json();
        reservations = raw.map(r => ({ from: new Date(r.from), to: new Date(r.to) }));
      }
    } catch (e) { console.error(e); }

    // 🔍 Diagnostic : affiche les réservations chargées dans la console
    console.log('[Calendrier] Réservations chargées :', reservations.map(r => ({
      from: r.from.toLocaleString('fr-FR'),
      to: r.to.toLocaleString('fr-FR')
    })));

    // Un jour est totalement bloqué uniquement s'il est entièrement couvert par une résa
    function isFullyBlocked(date) {
      const dayStart = new Date(date); dayStart.setHours(0, 0, 0, 0);
      const dayEnd = new Date(date); dayEnd.setHours(23, 59, 59, 999);
      return reservations.some(r => r.from <= dayStart && r.to >= dayEnd);
    }

    // Un jour est partiel si un bord de réservation tombe dedans sans couvrir totalement
    function isPartiallyBlocked(date) {
      const dayStart = new Date(date); dayStart.setHours(0, 0, 0, 0);
      const dayEnd = new Date(date); dayEnd.setHours(23, 59, 59, 999);
      return reservations.some(r => {
        const fromInDay = r.from >= dayStart && r.from <= dayEnd;
        const toInDay = r.to >= dayStart && r.to <= dayEnd;
        const fullyCovers = r.from <= dayStart && r.to >= dayEnd;
        return (fromInDay || toInDay) && !fullyCovers;
      });
    }

    // Vérifie si [start, end] chevauche une réservation (à la minute près)
    function hasTimeConflict(start, end) {
      return reservations.some(r => start < r.to && end > r.from);
    }

    // Calcule l'heure recommandée pour un jour partiel
    // role 'start' : prend la FIN de la résa qui se termine ce jour-là + 30 min (battement)
    // role 'end'   : prend le DÉBUT de la résa qui commence ce jour-là - 30 min (battement)
    function getRecommendedTime(date, role) {
      const dayStart = new Date(date); dayStart.setHours(0, 0, 0, 0);
      const dayEnd = new Date(date); dayEnd.setHours(23, 59, 59, 999);
      const MARGIN = 30 * 60 * 1000; // 30 minutes

      if (role === 'start') {
        // La voiture revient ce jour-là → on peut repartir après r.to + 30 min
        const endingToday = reservations
          .filter(r => r.to >= dayStart && r.to <= dayEnd)
          .sort((a, b) => b.to - a.to)[0]; // prend la plus tardive
        if (endingToday) return new Date(endingToday.to.getTime() + MARGIN);
      } else {
        // Une résa démarre ce jour-là → il faut rendre avant r.from - 30 min
        const startingToday = reservations
          .filter(r => r.from >= dayStart && r.from <= dayEnd)
          .sort((a, b) => a.from - b.from)[0]; // prend la plus matinale
        if (startingToday) return new Date(startingToday.from.getTime() - MARGIN);
      }
      return null;
    }

    let previousCount = 0;

    function formatDateTime(d) {
      const date = d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
      const time = d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
      return `${date} · ${time}`;
    }

    function updateDisplay(dates) {
      const startEl = document.getElementById('start-display');
      const endEl = document.getElementById('end-display');
      const trigger = document.getElementById('date-trigger');
      if (dates[0]) {
        startEl.textContent = formatDateTime(dates[0]);
        startEl.classList.add('filled');
      } else {
        startEl.textContent = 'Choisir une date';
        startEl.classList.remove('filled');
      }
      if (dates[1]) {
        endEl.textContent = formatDateTime(dates[1]);
        endEl.classList.add('filled');
      } else {
        endEl.textContent = 'Choisir une date';
        endEl.classList.remove('filled');
      }
      trigger.classList.toggle('has-selection', dates.length > 0);
    }

    const fpInstance = flatpickr("#date-range", {
      mode: "range",
      enableTime: true,
      time_24hr: true,
      minuteIncrement: 30,
      minDate: "today",
      dateFormat: "Y-m-d H:i",
      locale: "fr",
      clickOpens: false,
      disable: [ isFullyBlocked ],
      onDayCreate(_d, _s, _fp, dayElem) {
        if (dayElem.classList.contains('flatpickr-disabled')) return;
        if (isPartiallyBlocked(dayElem.dateObj)) {
          dayElem.classList.add('partially-occupied');
          dayElem.setAttribute('title', 'Journée partiellement réservée — l\'heure sera pré-remplie');
          // Injection d'un marqueur visible (fiable, indépendant de ::after)
          const marker = document.createElement('span');
          marker.className = 'partial-marker';
          dayElem.appendChild(marker);
        }
      },
      onChange(selectedDates, _dateStr, instance) {
        // Auto-remplissage de l'heure quand une nouvelle date est ajoutée
        if (selectedDates.length > previousCount && selectedDates.length <= 2) {
          const idx = selectedDates.length - 1;
          const addedDate = selectedDates[idx];
          const role = idx === 0 ? 'start' : 'end';
          const recommended = getRecommendedTime(addedDate, role);

          if (recommended) {
            const adjusted = new Date(addedDate);
            adjusted.setHours(recommended.getHours(), recommended.getMinutes(), 0, 0);

            // Évite la boucle si l'heure est déjà celle recommandée
            if (adjusted.getTime() !== addedDate.getTime()) {
              const newDates = selectedDates.slice();
              newDates[idx] = adjusted;
              previousCount = newDates.length;
              instance.setDate(newDates, false);
              updateDisplay(newDates);
              return;
            }
          }
        }
        previousCount = selectedDates.length;
        updateDisplay(selectedDates);
      },
      async onClose(selectedDates) {
        const errorEl = document.getElementById('conflict-error');
        const summaryEl = document.getElementById('resa-summary');
        const btn = document.getElementById('btn-book');

        if (selectedDates.length !== 2) return;
        const [start, end] = selectedDates;

        if (hasTimeConflict(start, end)) {
          errorEl.style.display = 'block';
          summaryEl.style.display = 'none';
          btn.disabled = true;
          return;
        }

        errorEl.style.display = 'none';

        const diffH = (end - start) / 3600000;
        const diffDays = Math.max(1, Math.ceil(diffH / 24));
        const locationAmount = diffDays * prixJournalier;

        document.getElementById('duration-text').textContent = `${diffDays} jour(s) (${Math.floor(diffH)}h)`;
        document.getElementById('location-amount').textContent = `${locationAmount.toFixed(2)} €`;
        document.getElementById('km-included').textContent = `${diffDays * 100} km`;
        summaryEl.style.display = 'block';
        document.getElementById('promo-group').style.display = 'block';

        btn.dataset.start = start.toISOString();
        btn.dataset.end = end.toISOString();
        btn.dataset.location = locationAmount.toFixed(2);
        btn.dataset.days = String(diffDays);

        // Vérifie la dispo du siège auto pour ces dates
        await refreshSiegeAvailability(start, end);

        // Si un code est déjà appliqué, on le revalide sur les nouvelles dates
        if (appliedPromo) await revalidatePromo();

        recalcTotal();

        btn.disabled = false;
      }
    });

    // ── Gestion du siège auto ─────────────────────────
    const siegeCheckbox = document.getElementById('siege-checkbox');
    const siegeCard = document.getElementById('siege-card');
    const siegeStatus = document.getElementById('siege-status');
    const siegePriceEl = document.getElementById('siege-price');
    const siegeRow = document.getElementById('siege-row');
    const siegeAmountEl = document.getElementById('siege-amount');

    let siegeInfo = { configured: false, available: false, prix: 0, remaining: 0 };

    async function refreshSiegeAvailability(start, end) {
      siegeCheckbox.checked = false;
      siegeCheckbox.disabled = true;
      siegeRow.style.display = 'none';

      try {
        const params = new URLSearchParams({
          start: start.toISOString(),
          end: end.toISOString(),
        });
        const res = await fetch(`/api/reservations/siege-availability?${params}`);
        siegeInfo = await res.json();
      } catch (e) {
        console.error('Erreur dispo siège auto:', e);
        siegeInfo = { configured: false, available: false, prix: 0, remaining: 0 };
      }

      if (!siegeInfo.configured) {
        siegeCard.classList.add('disabled');
        siegeStatus.textContent = 'Option non disponible';
        siegePriceEl.textContent = '';
        return;
      }

      siegePriceEl.textContent = `+${Number(siegeInfo.prix).toFixed(2)} €`;

      if (siegeInfo.available) {
        siegeCard.classList.remove('disabled');
        siegeCheckbox.disabled = false;
        siegeStatus.textContent = siegeInfo.remaining === 1
          ? 'Dernier siège disponible sur ce créneau'
          : `${siegeInfo.remaining} sièges disponibles sur ce créneau`;
      } else {
        siegeCard.classList.add('disabled');
        siegeStatus.textContent = 'Indisponible sur ce créneau';
      }
    }

    // Code promo appliqué
    let appliedPromo = null; // { code, pourcentage }

    function recalcTotal() {
      const btn = document.getElementById('btn-book');
      const location = parseFloat(btn.dataset.location || '0');
      const siegePrix = siegeCheckbox.checked ? Number(siegeInfo.prix) : 0;
      const sousTotal = location + siegePrix;

      const promoRow = document.getElementById('promo-row');
      const promoAmountEl = document.getElementById('promo-amount');
      const promoRowCode = document.getElementById('promo-row-code');

      let reduction = 0;
      if (appliedPromo) {
        reduction = +(sousTotal * (appliedPromo.pourcentage / 100)).toFixed(2);
        promoRow.style.display = 'flex';
        promoRowCode.textContent = appliedPromo.code;
        promoAmountEl.textContent = `-${reduction.toFixed(2)} €`;
      } else {
        promoRow.style.display = 'none';
      }

      const total = Math.max(0, sousTotal - reduction).toFixed(2);

      if (siegeCheckbox.checked) {
        siegeRow.style.display = 'flex';
        siegeAmountEl.textContent = `${siegePrix.toFixed(2)} €`;
      } else {
        siegeRow.style.display = 'none';
      }

      document.getElementById('total-amount').textContent = `${total} €`;
      btn.dataset.total = total;
      btn.dataset.siege = siegeCheckbox.checked ? '1' : '0';
      btn.dataset.promo = appliedPromo ? appliedPromo.code : '';
      btn.dataset.reduction = reduction.toFixed(2);
    }

    siegeCheckbox.addEventListener('change', recalcTotal);

    // ── Code promo ────────────────────────
    const promoInput = document.getElementById('promo-code-input');
    const promoBtn = document.getElementById('promo-apply-btn');
    const promoFeedback = document.getElementById('promo-feedback');

    async function applyPromo() {
      const code = (promoInput.value || '').trim().toUpperCase();
      promoFeedback.className = 'promo-feedback';

      if (!code) {
        appliedPromo = null;
        promoFeedback.textContent = '';
        promoBtn.textContent = 'Appliquer';
        recalcTotal();
        return;
      }

      promoBtn.disabled = true;
      promoBtn.textContent = '...';

      const btn = document.getElementById('btn-book');
      try {
        const res = await fetch('/api/promo/validate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            code,
            date_debut: btn.dataset.start || null,
            date_fin: btn.dataset.end || null,
          }),
        });
        const data = await res.json();

        if (data.valid) {
          appliedPromo = { code: data.code, pourcentage: data.pourcentage };
          promoFeedback.textContent = `✅ Code ${data.code} appliqué (-${data.pourcentage}%)`;
          promoFeedback.classList.add('ok');
          promoBtn.textContent = 'Retirer';
        } else {
          appliedPromo = null;
          promoFeedback.textContent = `❌ ${data.reason || 'Code invalide'}`;
          promoFeedback.classList.add('ko');
          promoBtn.textContent = 'Appliquer';
        }
      } catch (e) {
        appliedPromo = null;
        promoFeedback.textContent = '❌ Erreur réseau';
        promoFeedback.classList.add('ko');
        promoBtn.textContent = 'Appliquer';
      } finally {
        promoBtn.disabled = false;
        recalcTotal();
      }
    }

    // Re-valide silencieusement le code déjà appliqué quand les dates changent
    async function revalidatePromo() {
      if (!appliedPromo) return;
      const btn = document.getElementById('btn-book');
      try {
        const res = await fetch('/api/promo/validate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            code: appliedPromo.code,
            date_debut: btn.dataset.start || null,
            date_fin: btn.dataset.end || null,
          }),
        });
        const data = await res.json();
        promoFeedback.className = 'promo-feedback';
        if (data.valid) {
          appliedPromo = { code: data.code, pourcentage: data.pourcentage };
          promoFeedback.textContent = `✅ Code ${data.code} appliqué (-${data.pourcentage}%)`;
          promoFeedback.classList.add('ok');
        } else {
          appliedPromo = null;
          promoFeedback.textContent = `⚠️ ${data.reason || 'Code non applicable sur ces dates'}`;
          promoFeedback.classList.add('ko');
          promoBtn.textContent = 'Appliquer';
        }
      } catch (e) {
        // silencieux en cas d'erreur réseau
      }
    }

    promoBtn.addEventListener('click', () => {
      if (appliedPromo) {
        // Retirer
        appliedPromo = null;
        promoInput.value = '';
        promoFeedback.textContent = '';
        promoBtn.textContent = 'Appliquer';
        recalcTotal();
      } else {
        applyPromo();
      }
    });

    promoInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        applyPromo();
      }
    });

    // Ouvre le calendrier au clic sur la pilule Départ/Retour
    const trigger = document.getElementById('date-trigger');
    trigger.addEventListener('click', () => fpInstance.open());
    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fpInstance.open(); }
    });
  }

  initCalendar();

  const modal = document.getElementById('modal-locataire');

  document.getElementById('btn-book').addEventListener('click', () => {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  });

  document.getElementById('modal-close').addEventListener('click', () => {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }
  });

  document.getElementById('form-locataire').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn    = document.getElementById('btn-book');
    const submit = document.getElementById('btn-modal-submit');
    const errEl  = document.getElementById('modal-error');

    const nom       = document.getElementById('loc-nom').value.trim();
    const email     = document.getElementById('loc-email').value.trim();
    const naiss     = document.getElementById('loc-naissance').value;
    const adresse   = document.getElementById('loc-adresse').value.trim();
    const permis    = document.getElementById('loc-permis').value.trim().toUpperCase();
    const permisDate = document.getElementById('loc-permis-date').value;

    if (!nom || !email || !naiss || !adresse || !permis || !permisDate) {
      errEl.textContent = 'Veuillez remplir tous les champs obligatoires.';
      errEl.style.display = 'block';
      return;
    }

    submit.disabled = true;
    submit.textContent = 'Redirection vers Stripe…';
    errEl.style.display = 'none';

    try {
      const res = await fetch('/api/stripe/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          vehicule_id:              vehiculeId,
          vehicule_nom:             document.querySelector('.panel-title').textContent,
          date_debut:               btn.dataset.start,
          date_fin:                 btn.dataset.end,
          montant:                  btn.dataset.total,
          siege_auto:               btn.dataset.siege === '1',
          promo_code:               btn.dataset.promo || null,
          reduction:                parseFloat(btn.dataset.reduction || '0'),
          email_client:             email,
          locataire_nom:            nom,
          locataire_date_naissance: naiss,
          locataire_permis_numero:  permis,
          locataire_permis_date:    permisDate,
          locataire_adresse:        adresse,
        })
      });
      const { url, error } = await res.json();
      if (url) { window.location.href = url; }
      else throw new Error(error || 'Erreur Stripe');
    } catch (err) {
      errEl.textContent = 'Erreur : ' + err.message;
      errEl.style.display = 'block';
      submit.disabled = false;
      submit.textContent = 'Continuer vers le paiement →';
    }
  });
</script>

