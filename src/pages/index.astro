---
import MainLayout from '../layouts/MainLayout.astro';
import CardVehicule from '../components/CardVehicule.astro';
import { supabaseAdmin } from '../lib/supabase';
import { isMaintenanceMode } from '../lib/maintenance';

const [{ data: vehicules }, maintenance, mardiConfig, derniereMinuteConfig] = await Promise.all([
  supabaseAdmin.from('vehicules').select('*').eq('disponible_resa', true),
  isMaintenanceMode(),
  supabaseAdmin.from('app_config').select('value').eq('key', 'mardi_flash_actif').single(),
  supabaseAdmin.from('app_config').select('value').eq('key', 'derniere_minute_actif').single(),
]);

const mardiFlashActif = mardiConfig?.data?.value === 'true';
const derniereMinuteActif = derniereMinuteConfig?.data?.value === 'true';
---

<MainLayout title="Ship Cars — Location de véhicules à Grenoble">

  {maintenance && (
    <div class="maintenance-banner">
      <div class="maintenance-inner">
        <span class="maintenance-icon">🔧</span>
        <div>
          <strong>Site en maintenance</strong>
          <span>Pour les disponibilités, appelez ou envoyez un message WhatsApp au <a href="https://wa.me/33661691178" target="_blank" rel="noopener">06 61 69 11 78</a></span>
        </div>
        <a href="https://wa.me/33661691178" target="_blank" rel="noopener" class="maintenance-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  )}

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Agence en ligne · Grenoble, proche de la gare
      </div>
      <h1 class="hero-title">
        Location de voiture<br>
        <em>sans guichet, sans attente</em>
      </h1>
      <p class="hero-sub">
        <strong>62 rue Félix Esclangon, 38000 Grenoble</strong> — à 2 min à pied de la gare.<br>
        Réservez en ligne, payez par Stripe, <strong>ouvrez votre voiture depuis votre téléphone</strong>. Zéro guichet, zéro file d'attente.
      </p>
      <div class="hero-unlock-strip">
        <div class="unlock-step">
          <span class="unlock-num">1</span>
          <span>Réservez en ligne</span>
        </div>
        <svg class="unlock-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div class="unlock-step">
          <span class="unlock-num">2</span>
          <span>Payez par carte</span>
        </div>
        <svg class="unlock-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div class="unlock-step unlock-step--highlight">
          <span class="unlock-num">3</span>
          <span>🔓 Ouvrez à distance</span>
        </div>
      </div>
      <div class="hero-cta">
        <a href="#catalogue" class="btn-primary">Voir les véhicules disponibles</a>
        <div class="hero-stats">
          <div class="stat">
            <strong>2 min</strong>
            <span>de la gare</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <strong>0</strong>
            <span>guichet · 0 attente</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <strong>📱</strong>
            <span>ouverture à distance</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARDI FLASH (si actif) -->
  {mardiFlashActif && !maintenance && (
    <section class="flash-section">
      <div class="container flash-inner">
        <div class="flash-badge">⚡ Offre limitée</div>
        <div class="flash-content">
          <div class="flash-text">
            <h2 class="flash-title">Mardi Flash</h2>
            <p class="flash-desc">25 € la journée · 50 km inclus · Valable uniquement pour un départ dans les 3 prochains jours</p>
          </div>
          <div class="flash-code-block">
            <span class="flash-code-label">Code promo</span>
            <span class="flash-code">MARDI</span>
          </div>
          <a href="#catalogue" class="flash-btn">En profiter →</a>
        </div>
      </div>
    </section>
  )}

  <!-- DERNIÈRE MINUTE (si actif) -->
  {derniereMinuteActif && !maintenance && (
    <section class="flash-section dm-section">
      <div class="container flash-inner">
        <div class="flash-badge">🕐 Dernière minute</div>
        <div class="flash-content">
          <div class="flash-text">
            <h2 class="flash-title">Prix Dernière Minute</h2>
            <p class="flash-desc">25 € la journée · 50 km inclus · Départ sous 48 h · En semaine uniquement (lun–ven)</p>
          </div>
          <div class="flash-code-block">
            <span class="flash-code-label">Code promo</span>
            <span class="flash-code">MINUTE</span>
          </div>
          <a href="#catalogue" class="flash-btn">En profiter →</a>
        </div>
      </div>
    </section>
  )}

  <!-- CATALOGUE -->
