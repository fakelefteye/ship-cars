---
import MainLayout from '../layouts/MainLayout.astro';
import CardVehicule from '../components/CardVehicule.astro';
import { supabaseAdmin } from '../lib/supabase';

const { data: vehicules, error } = await supabaseAdmin
  .from('vehicules')
  .select('*')
  .eq('disponible_resa', true);
---

<MainLayout title="Ship Cars — Location de véhicules à Grenoble">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Disponible maintenant · Grenoble
      </div>
      <h1 class="hero-title">
        La location auto<br>
        <em>sans prise de tête</em>
      </h1>
      <p class="hero-sub">
        Clio, 208, C3 Picasso et plus — à deux minutes à pied de la gare de Grenoble.<br>
        Réservez en ligne, payez en toute sécurité, récupérez votre véhicule.
      </p>
      <div class="hero-cta">
        <a href="#catalogue" class="btn-primary">Voir les véhicules disponibles</a>
        <div class="hero-stats">
          <div class="stat">
            <strong>5 min</strong>
            <span>de la gare</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <strong>100%</strong>
            <span>en ligne</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <strong>Stripe</strong>
            <span>paiement sécurisé</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATALOGUE -->
  <section id="catalogue" class="catalogue">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Flotte disponible</div>
        <h2 class="section-title">Choisissez votre véhicule</h2>
        <p class="section-sub">Tous nos véhicules sont vérifiés et assurés. Caution par empreinte bancaire uniquement.</p>
      </div>

      <div class="grid-cars">
        {vehicules?.map((car) => (
          <CardVehicule
            id={car.id}
            nom={car.nom}
            modele={car.modele}
            prix={car.prix_journalier_base}
            image={car.image_url || '/img/default-car.jpg'}
          />
        ))}
        {(!vehicules || vehicules.length === 0) && (
          <div class="empty-state">
            <div class="empty-icon">🚗</div>
            <p>Aucun véhicule disponible pour le moment.</p>
            <small>Revenez bientôt ou contactez-nous directement.</small>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- POURQUOI NOUS -->
  <section class="why">
    <div class="container">
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">📍</div>
          <h3>À 5 min de la gare</h3>
          <p>Idéal pour les voyageurs. Récupérez votre voiture dès votre descente du train, sans navette.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🔒</div>
          <h3>Paiement 100% sécurisé</h3>
          <p>Stripe gère votre paiement et la caution par empreinte bancaire. Aucune somme bloquée sur votre compte.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">📅</div>
          <h3>Réservation instantanée</h3>
          <p>Choisissez vos dates en temps réel, payez en ligne. Votre créneau est bloqué immédiatement.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <h3>Véhicules vérifiés</h3>
          <p>Tous nos véhicules sont contrôlés, assurés et entretenus régulièrement pour votre sécurité.</p>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 7rem 0 6rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .hero-glow-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(77,212,200,0.14) 0%, transparent 70%);
    top: -100px;
    left: -100px;
  }

  .hero-glow-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(32,56,90,0.5) 0%, transparent 70%);
    bottom: 0;
    right: 5%;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: var(--teal);
    background: rgba(77,212,200,0.1);
    border: 1px solid rgba(77,212,200,0.28);
    padding: 6px 14px;
    border-radius: 99px;
    margin-bottom: 2rem;
    letter-spacing: 0.03em;
    font-family: 'DM Sans', sans-serif;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
    box-shadow: 0 0 8px rgba(77,212,200,0.8);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  .hero-title {
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .hero-title em {
    font-style: normal;
    color: var(--teal);
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 560px;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--teal);
    color: var(--navy-deep);
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 14px 28px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    white-space: nowrap;
    box-shadow: 0 4px 20px rgba(77,212,200,0.25);
  }

  .btn-primary:hover {
    background: var(--teal-bright);
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(77,212,200,0.4);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat strong {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .stat span {
    font-size: 0.72rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 28px;
    background: var(--border-md);
  }

  /* ── CATALOGUE ── */
  .catalogue { padding: 5rem 0; }

  .section-header {
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--teal);
    margin-bottom: 0.75rem;
    font-family: 'DM Sans', sans-serif;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-size: 0.92rem;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 520px;
  }

  .grid-cars {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 5rem 2rem;
    color: var(--text-muted);
  }

  .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
  .empty-state small { display: block; margin-top: 0.5rem; color: var(--text-dim); font-size: 0.85rem; }

  /* ── WHY ── */
  .why { padding: 3rem 0 5rem; }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .why-card {
    background: var(--bg-2);
    padding: 2rem 1.75rem;
    transition: background 0.2s;
  }

  .why-card:hover { background: var(--bg-3); }

  .why-icon {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    display: block;
  }

  .why-card h3 {
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.6rem;
  }

  .why-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.65;
    font-weight: 300;
  }

  @media (max-width: 700px) {
    .hero { padding: 4rem 0 3rem; }
    .hero-cta { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .grid-cars { grid-template-columns: 1fr; }
  }
</style>
