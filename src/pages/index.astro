  .info-row { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: 1rem; }
  .info-chip {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: .78rem; color: #374151;
    background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
    padding: 5px 12px;
