  }

  /* ── CATALOGUE ── */
  .catalogue { padding: 5rem 0; background: #f8fafc; }

  .section-header { margin-bottom: 2.5rem; }
  .section-label {
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--teal); margin-bottom: 0.6rem; font-family: 'Exo 2', sans-serif;
