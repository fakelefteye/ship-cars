      <div class="section-header">
        <div class="section-label">Flotte disponible</div>
        <h2 class="section-title">Nos véhicules</h2>
        <p class="section-sub">Tous nos véhicules sont vérifiés, assurés et entretenus. Caution par empreinte bancaire uniquement.</p>
        <div class="info-row">
          <div class="info-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            62 rue Félix Esclangon, 38000 Grenoble
          </div>
          <div class="info-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Agence 100% en ligne · Pas de boutique physique
          </div>
          <div class="info-chip info-chip--zone">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span>Zone limitée Sud-Est &amp; pays frontaliers. <a href="/zones">Voir les zones →</a></span>
          </div>
        </div>
      </div>

      <!-- FILTRE DATES -->
      <div class="date-filter">
        <div class="df-picker" id="df-trigger" role="button" tabindex="0">
          <div class="df-pill">
            <span class="df-pill-icon">🚗</span>
            <div class="df-pill-content">
              <span class="df-label">Départ</span>
              <span class="df-value" id="df-start">Choisir une date</span>
            </div>
          </div>
          <div class="df-sep">→</div>
          <div class="df-pill">
            <span class="df-pill-icon">🔙</span>
            <div class="df-pill-content">
              <span class="df-label">Retour</span>
              <span class="df-value" id="df-end">Choisir une date</span>
            </div>
          </div>
        </div>
        <button id="df-reset" class="df-reset" style="display:none" type="button">✕ Effacer</button>
        <input type="text" id="df-range" class="df-hidden" readonly aria-hidden="true" />
        <div id="df-result" class="df-result" style="display:none">
          <span id="df-count"></span>
        </div>
      </div>

      <div class="grid-cars" id="grid-cars">
        {vehicules?.map((car) => {
          const prixMin = Math.min(
            ...[car.prix_basse, car.prix_moyenne, car.prix_journalier_base]
              .filter((p) => p != null && p > 0)
              .map(Number)
          );
          return (
          <CardVehicule
            id={car.id}
            nom={car.nom}
            modele={car.modele}
            prix={prixMin || car.prix_journalier_base}
            image={car.image_url || '/img/default-car.jpg'}
          />
          );
        })}
        {(!vehicules || vehicules.length === 0) && (
          <div class="empty-state">
            <div class="empty-icon">🚗</div>
            <p>Aucun véhicule disponible pour le moment.</p>
            <small>Revenez bientôt ou contactez-nous directement.</small>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- AVANTAGES -->
  <section class="why">
    <div class="container">
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon-wrap">🚉</div>
          <h3>À 2 min de la gare</h3>
          <p>62 rue Félix Esclangon, Grenoble. Récupérez votre voiture dès votre descente du train.</p>
        </div>
        <div class="why-card">
          <div class="why-icon-wrap">💳</div>
          <h3>Paiement sécurisé</h3>
          <p>Stripe gère votre paiement et la caution par empreinte bancaire. Aucune somme bloquée.</p>
        </div>
        <div class="why-card why-card--accent">
          <div class="why-icon-wrap">🔓</div>
          <h3>Ouverture à distance</h3>
          <p>Pas de clé à récupérer en main propre. Votre véhicule s'ouvre depuis votre téléphone — à l'heure exacte de votre réservation.</p>
        </div>
        <div class="why-card">
          <div class="why-icon-wrap">🛡️</div>
          <h3>Véhicules vérifiés</h3>
          <p>Tous nos véhicules sont contrôlés, assurés et entretenus régulièrement pour votre sécurité.</p>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

<script is:inline>
(function () {
  function fmt(d) {
    const date = d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
    const time = d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    return date + ' · ' + time;
  }

  const trigger  = document.getElementById('df-trigger');
  const startEl  = document.getElementById('df-start');
  const endEl    = document.getElementById('df-end');
  const resetBtn = document.getElementById('df-reset');
  const resultEl = document.getElementById('df-result');
  const countEl  = document.getElementById('df-count');

  function clearFilter() {
    startEl.textContent = 'Choisir une date';
    endEl.textContent   = 'Choisir une date';
    startEl.classList.remove('filled');
    endEl.classList.remove('filled');
    trigger.classList.remove('has-selection');
    resetBtn.style.display = 'none';
    resultEl.style.display = 'none';
    document.querySelectorAll('.card[data-vehicule-id]').forEach(c => {
      c.classList.remove('card--unavailable');
      c.style.display = '';
    });
    fp.clear();
  }

  async function applyFilter(start, end) {
    const debut = start.toISOString();
    const fin   = end.toISOString();
    try {
      const res  = await fetch('/api/reservations/available-vehicles?debut=' + encodeURIComponent(debut) + '&fin=' + encodeURIComponent(fin));
      const data = await res.json();
      const unavailable = new Set(data.unavailable ?? []);
      const available   = data.available ?? [];

      document.querySelectorAll('.card[data-vehicule-id]').forEach(card => {
        const id = card.getAttribute('data-vehicule-id');
        if (unavailable.has(id)) {
          card.classList.add('card--unavailable');
        } else {
          card.classList.remove('card--unavailable');
        }
        card.style.display = '';
      });

      const n = available.length;
      countEl.textContent = n === 0
        ? 'Aucun véhicule disponible sur ces dates'
        : n + ' véhicule' + (n > 1 ? 's' : '') + ' disponible' + (n > 1 ? 's' : '') + ' sur ces dates';
      resultEl.style.display = 'flex';
      resultEl.className = 'df-result ' + (n === 0 ? 'df-result--none' : 'df-result--ok');
    } catch (e) {
      console.error('[filtre dispo]', e);
    }
  }

  const fp = flatpickr('#df-range', {
    mode: 'range',
    enableTime: true,
    time_24hr: true,
    minuteIncrement: 30,
    minDate: 'today',
    dateFormat: 'Y-m-d H:i',
    locale: 'fr',
    clickOpens: false,
    onChange(dates) {
      if (dates[0]) {
        startEl.textContent = fmt(dates[0]);
        startEl.classList.add('filled');
      }
      if (dates[1]) {
        endEl.textContent = fmt(dates[1]);
        endEl.classList.add('filled');
        trigger.classList.add('has-selection');
        resetBtn.style.display = 'inline-flex';
        applyFilter(dates[0], dates[1]);
      }
    },
  });

  trigger.addEventListener('click', () => fp.open());
  trigger.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fp.open(); } });
  resetBtn.addEventListener('click', clearFilter);
})();
</script>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 5rem;
    background: linear-gradient(160deg, #0d1f35 0%, #0a1421 50%, #071219 100%);
  }

  .hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
  }
  .hero-glow-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(77,212,200,0.18) 0%, transparent 65%);
    top: -150px; left: -100px;
  }
  .hero-glow-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(29,78,216,0.15) 0%, transparent 65%);
    bottom: -100px; right: 0;
  }

  .hero-inner { position: relative; z-index: 1; max-width: 1000px; }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.78rem; color: var(--teal);
    background: rgba(77,212,200,0.12); border: 1px solid rgba(77,212,200,0.3);
    padding: 6px 14px; border-radius: 99px;
    margin-bottom: 2rem; letter-spacing: 0.03em;
    font-family: 'Exo 2', sans-serif;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--teal); box-shadow: 0 0 8px rgba(77,212,200,0.8);
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.35} }

  .hero-title {
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 800; line-height: 1.06;
    letter-spacing: -0.02em; color: #fff;
    margin-bottom: 1.5rem;
  }
  .hero-title em { font-style: normal; color: var(--teal); }

  .hero-sub {
    font-size: 1rem; color: #a0b4c8;
    line-height: 1.8; max-width: 780px;
    margin-bottom: 1.5rem; font-weight: 300;
  }
  .hero-sub strong { color: #cbd5e1; font-weight: 600; }

  .hero-unlock-strip {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: nowrap;
    margin-bottom: 2rem;
    padding: 0.85rem 1.25rem;
    background: rgba(77,212,200,0.07);
    border: 1px solid rgba(77,212,200,0.2);
    border-radius: var(--radius);
    width: fit-content;
  }
  .unlock-step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #a0b4c8;
    font-family: 'Exo 2', sans-serif;
    font-weight: 500;
  }
  .unlock-step--highlight {
    color: var(--teal);
    font-weight: 700;
  }
  .unlock-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px; height: 22px;
    background: rgba(77,212,200,0.15);
    border: 1px solid rgba(77,212,200,0.3);
    border-radius: 50%;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--teal);
    flex-shrink: 0;
  }
  .unlock-arrow { color: rgba(77,212,200,0.4); flex-shrink: 0; }

  .hero-cta { display: flex; align-items: center; flex-wrap: wrap; gap: 2rem; }

  .btn-primary {
    display: inline-block; background: var(--teal); color: #0a1421;
    font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 0.95rem;
    padding: 14px 28px; border-radius: var(--radius); text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(77,212,200,0.3);
  }
  .btn-primary:hover {
    background: var(--teal-bright); transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(77,212,200,0.45);
  }

  .hero-stats { display: flex; align-items: center; gap: 1.5rem; }
  .stat { display: flex; flex-direction: column; gap: 2px; }
  .stat strong { font-family: 'Exo 2', sans-serif; font-size: 1rem; font-weight: 700; color: #fff; }
  .stat span { font-size: 0.72rem; color: #6b8499; text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-divider { width: 1px; height: 28px; background: rgba(77,212,200,0.2); }

  /* ── MARDI FLASH ── */
  .flash-section {
    background: linear-gradient(135deg, #f97316, #f59e0b);
    padding: 1.25rem 0;
  }
  .flash-inner {
    display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;
  }
  .flash-badge {
    background: rgba(0,0,0,.2); color: #fff;
    font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em;
    padding: 4px 12px; border-radius: 99px; white-space: nowrap; flex-shrink: 0;
  }
  .flash-content {
    display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; flex: 1;
  }
  .flash-text { flex: 1; }
  .flash-title {
    font-family: 'Exo 2', sans-serif; font-size: 1.15rem; font-weight: 800;
    color: #fff; margin: 0 0 .2rem;
  }
  .flash-desc { font-size: .82rem; color: rgba(255,255,255,.9); margin: 0; }
  .flash-code-block {
    display: flex; flex-direction: column; align-items: center;
    background: rgba(255,255,255,.15); border: 2px solid rgba(255,255,255,.35);
