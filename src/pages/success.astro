---
export const prerender = false;
import MainLayout from '../layouts/MainLayout.astro';
import Stripe from 'stripe';
import { supabaseAdmin } from '../lib/supabase';

const sessionId = Astro.url.searchParams.get('session_id');
let reservation: Record<string, any> | null = null;
let vehicule: Record<string, any> | null = null;

if (sessionId) {
  try {
    const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    const reservationId = session.metadata?.reservation_id;
    if (reservationId) {
      const { data } = await supabaseAdmin
        .from('reservations')
        .select('*, vehicules(*)')
        .eq('id', reservationId)
        .single();
      if (data) {
        reservation = data;
        vehicule = data.vehicules;
      }
    }
  } catch (e) {
    console.error('Erreur récupération contrat:', e);
  }
}

const fmt = (d: string | null | undefined): string => {
  if (!d) return '—';
  return new Date(d).toLocaleString('fr-FR', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
};

const fmtDate = (d: string | null | undefined): string => {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('fr-FR');
};

const diffDays = reservation
  ? Math.max(1, Math.ceil(
      (new Date(reservation.date_fin as string).getTime() - new Date(reservation.date_debut as string).getTime()) / 86400000
    ))
  : 0;

const contractNum = reservation?.id
  ? (reservation.id as string).replace(/-/g, '').slice(0, 8).toUpperCase()
  : '—';
---

<MainLayout title="Contrat de location — Ship Cars">
  <div class="page-wrapper">

    <!-- CONFIRMATION -->
    <div class="confirm-banner no-print">
      <span class="confirm-icon">✅</span>
      <div>
        <h1 class="confirm-title">Paiement validé !</h1>
        <p class="confirm-sub">Merci d'avoir choisi <strong>Ship Cars</strong>. Votre contrat de location est disponible ci-dessous.</p>
      </div>
    </div>

    <!-- CONTRAT -->
    {reservation ? (
      <div class="contract" id="contract">
        <div class="contract-header">
          <div class="contract-brand">
            <img src="/logo.png" alt="Ship Cars" class="contract-logo" />
            <span class="contract-brand-name">Ship<em>Cars</em></span>
          </div>
          <div class="contract-id-block">
            <div class="contract-title-label">Contrat de location</div>
            <div class="contract-num">N° SC-{contractNum}</div>
          </div>
        </div>

        <section class="contract-section">
          <h2 class="contract-section-title">Réservation</h2>
          <table class="contract-table">
            <tbody>
              <tr><td>Date de réservation</td><td>{fmt(reservation.created_at)}</td></tr>
              <tr><td>Horaire de début</td><td>{fmt(reservation.date_debut)}</td></tr>
              <tr><td>Horaire de fin</td><td>{fmt(reservation.date_fin)}</td></tr>
              <tr><td>Prix de la réservation</td><td>{Number(reservation.montant_total).toFixed(2)} €</td></tr>
              <tr><td>Distance incluse</td><td>{diffDays * 100} km</td></tr>
              <tr><td>Prix additionnel par km</td><td>0,36 €</td></tr>
              <tr><td>Nom du propriétaire</td><td>Ship Cars</td></tr>
              <tr><td>Protection</td><td>Standard</td></tr>
            </tbody>
          </table>
        </section>

        <section class="contract-section">
          <h2 class="contract-section-title">Informations du locataire</h2>
          <table class="contract-table">
            <tbody>
              {vehicule && (
                <tr><td>Véhicule</td><td>{vehicule.nom}{vehicule.modele ? ` — ${vehicule.modele}` : ''}{vehicule.annee ? ` (${vehicule.annee})` : ''}</td></tr>
              )}
              {vehicule?.immatriculation && <tr><td>Plaque d'immatriculation</td><td>{vehicule.immatriculation}</td></tr>}
              {vehicule?.carburant && <tr><td>Type de carburant</td><td>{vehicule.carburant}</td></tr>}
              {reservation.locataire_nom && <tr><td>Nom du locataire</td><td>{reservation.locataire_nom}</td></tr>}
              {reservation.locataire_date_naissance && <tr><td>Date de naissance</td><td>{fmtDate(reservation.locataire_date_naissance)}</td></tr>}
              {reservation.locataire_permis_numero && <tr><td>Numéro de permis de conduire</td><td>{reservation.locataire_permis_numero}</td></tr>}
              {reservation.locataire_permis_date && <tr><td>Date d'obtention du permis</td><td>{fmtDate(reservation.locataire_permis_date)}</td></tr>}
              {reservation.locataire_adresse && <tr><td>Adresse du locataire</td><td>{reservation.locataire_adresse}</td></tr>}
              {reservation.email_client && <tr><td>Email</td><td>{reservation.email_client}</td></tr>}
            </tbody>
          </table>
        </section>

        <p class="contract-disclaimer">
          Les informations fournies par le locataire peuvent, le cas échéant, être corrigées en fonction d'éléments découverts ultérieurement.
          Ce document fait office de contrat de location entre Ship Cars (propriétaire) et le locataire identifié ci-dessus.
        </p>
      </div>
    ) : (
      <div class="contract-placeholder no-print">
        <p>Récupération du contrat en cours…</p>
      </div>
    )}

    <button onclick="window.print()" class="btn-print no-print">
      Imprimer / Télécharger le contrat (PDF)
    </button>

    <!-- CAUTION -->
    <div class="caution-box no-print">
      <h2 class="caution-title">Dernière étape : La Caution</h2>
      <p>Pour finaliser votre dossier, veuillez effectuer la <strong>pré-autorisation (caution) de 800,00€</strong>.</p>
      <div class="stripe-button-wrapper">
        <script async src="https://js.stripe.com/v3/buy-button.js"></script>
        <stripe-buy-button
          buy-button-id="buy_btn_1TLl29Lm0bysFbj9rUtBeBSQ"
          publishable-key="pk_test_51AhCIJLm0bysFbj9Zn7hSJw9G8qq6pA5z0DpHQjKb3KsKEEle6yl4yhjv8AOlMsUc7VpmKgwWVwBZrWEy8fFCG0000vh1zLidr"
        ></stripe-buy-button>
      </div>
      <div class="info-alert">
        <small>💡 <strong>Rappel :</strong> Cette somme n'est pas débitée, il s'agit d'une empreinte bancaire pour sécuriser la location.</small>
      </div>
    </div>

    <p class="mail-info no-print">Un e-mail de confirmation a été envoyé par <strong>Ship Cars</strong>.</p>
    <a href="/" class="back-home no-print">← Retour au catalogue</a>
  </div>
</MainLayout>

<style>
  .page-wrapper {
    max-width: 820px;
    margin: 3rem auto;
    padding: 0 1.5rem 5rem;
  }

  /* ── CONFIRMATION ── */
  .confirm-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(62,207,142,0.08);
    border: 1px solid rgba(62,207,142,0.25);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .confirm-icon { font-size: 2rem; flex-shrink: 0; }

  .confirm-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .confirm-sub { font-size: 0.9rem; color: var(--text-muted); }

  /* ── CONTRAT ── */
  .contract {
    background: #ffffff;
    color: #1a1a2e;
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 40px rgba(0,0,0,0.35);
  }

  .contract-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #e8eaf0;
    margin-bottom: 2rem;
  }

  .contract-brand { display: flex; align-items: center; gap: 10px; }

  .contract-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 50%;
  }

  .contract-brand-name {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: #0f1e33;
  }
  .contract-brand-name em { color: #4dd4c8; font-style: normal; }

  .contract-id-block { text-align: right; }

  .contract-title-label {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a2e;
  }

  .contract-num {
    font-size: 0.82rem;
    color: #6b7280;
    font-weight: 600;
    margin-top: 3px;
  }

  .contract-section { margin-bottom: 2rem; }

  .contract-section-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: #1a1a2e;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #e8eaf0;
    margin-bottom: 0.25rem;
  }

  .contract-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .contract-table tr { border-bottom: 1px solid #f3f4f6; }

  .contract-table td {
    padding: 10px 6px;
    color: #374151;
    vertical-align: top;
    line-height: 1.4;
  }

  .contract-table td:first-child {
    font-weight: 600;
    color: #1f2937;
    width: 42%;
  }

  .contract-disclaimer {
    font-size: 0.75rem;
    color: #9ca3af;
    line-height: 1.6;
    border-top: 1px solid #e8eaf0;
    padding-top: 1rem;
    margin-top: 0.5rem;
  }

  .contract-placeholder {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* ── BOUTON IMPRIMER ── */
  .btn-print {
    display: block;
    width: 100%;
    background: var(--teal);
    color: var(--navy-deep);
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 14px 28px;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    margin-bottom: 2rem;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 16px rgba(77,212,200,0.3);
  }
  .btn-print:hover { background: var(--teal-bright); transform: translateY(-1px); }

  /* ── CAUTION ── */
  .caution-box {
    background: var(--bg-2);
    border: 1px solid rgba(77,212,200,0.2);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .caution-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .caution-box p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .stripe-button-wrapper {
    display: flex;
    justify-content: center;
    margin: 1.5rem 0;
    min-height: 50px;
  }

  .info-alert {
    background: rgba(77,212,200,0.06);
    border: 1px solid rgba(77,212,200,0.18);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
    text-align: left;
  }

  .mail-info {
    font-size: 0.85rem;
    color: var(--text-dim);
    text-align: center;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .back-home {
    display: block;
    text-align: center;
    color: var(--teal);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s;
  }
  .back-home:hover { color: var(--teal-bright); }

  /* ── IMPRESSION ── */
  @media print {
    .no-print { display: none !important; }

    .page-wrapper { margin: 0; padding: 0; max-width: 100%; }

    .contract {
      box-shadow: none;
      border-radius: 0;
      padding: 1rem;
    }
  }
</style>
