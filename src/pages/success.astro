---
export const prerender = false;
import MainLayout from '../layouts/MainLayout.astro';
import Stripe from 'stripe';
import { supabaseAdmin } from '../lib/supabase';

const sessionId = Astro.url.searchParams.get('session_id');
let reservation: Record<string, any> | null = null;
let vehicule: Record<string, any> | null = null;

if (sessionId) {
  try {
    const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    const reservationId = session.metadata?.reservation_id;
    if (reservationId) {
      const { data } = await supabaseAdmin
        .from('reservations')
        .select('*, vehicules(*)')
        .eq('id', reservationId)
        .single();
      if (data) {
        reservation = data;
        vehicule = data.vehicules;
      }
    }
  } catch (e) {
    console.error('Erreur récupération contrat:', e);
  }
}

const fmt = (d: string | null | undefined): string => {
  if (!d) return '—';
  return new Date(d).toLocaleString('fr-FR', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
    hour: '2-digit', minute: '2-digit',
    timeZone: 'Europe/Paris',
  });
};

const fmtDate = (d: string | null | undefined): string => {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('fr-FR');
};

const diffDays = reservation
  ? Math.max(1, Math.ceil(
      (new Date(reservation.date_fin as string).getTime() - new Date(reservation.date_debut as string).getTime()) / 86400000
    ))
  : 0;

const contractNum = reservation?.id
  ? (reservation.id as string).replace(/-/g, '').slice(0, 8).toUpperCase()
  : '—';

const cautionDejaAutorisee = reservation?.caution_statut === 'autorisee';
---

<MainLayout title="Récépissé de réservation — Ship Cars">
  <div class="page-wrapper">

    <!-- CONFIRMATION -->
    <div class="confirm-banner no-print">
      <span class="confirm-icon">✅</span>
      <div>
        <h1 class="confirm-title">Paiement validé !</h1>
        <p class="confirm-sub">Merci d'avoir choisi <strong>Ship Cars</strong>. Votre récépissé de réservation est disponible ci-dessous. Le contrat définitif sera signé lors de la remise des clés.</p>
      </div>
    </div>

    <!-- RECU -->
    {reservation ? (
      <div class="contract" id="contract">
        <div class="contract-header">
          <div class="contract-brand">
            <img src="/logo_ship_cars.png" alt="Ship Cars" class="contract-logo" />
            <span class="contract-brand-name">Ship<em>Cars</em></span>
          </div>
          <div class="contract-id-block">
            <div class="contract-title-label">Récépissé de réservation</div>
            <div class="contract-num">N° SC-{contractNum}</div>
            <div class="contract-title-note">⚠️ Ce document n'est pas un contrat — le contrat est signé lors de la remise des clés</div>
          </div>
        </div>

        <section class="contract-section">
          <h2 class="contract-section-title">Réservation</h2>
          <table class="contract-table">
            <tbody>
              <tr><td>Date de réservation</td><td>{fmt(reservation.created_at)}</td></tr>
              <tr><td>Horaire de début</td><td>{fmt(reservation.date_debut)}</td></tr>
              <tr><td>Horaire de fin</td><td>{fmt(reservation.date_fin)}</td></tr>
              <tr><td>Prix de la réservation</td><td>{Number(reservation.montant_total).toFixed(2)} €</td></tr>
              <tr><td>Distance incluse</td><td>{diffDays * 100} km</td></tr>
              <tr><td>Prix additionnel par km</td><td>0,36 €</td></tr>
              <tr><td>Nom du propriétaire</td><td>Ship Cars</td></tr>
              <tr><td>Protection</td><td>Standard</td></tr>
            </tbody>
          </table>
        </section>

        <section class="contract-section">
          <h2 class="contract-section-title">Informations du locataire</h2>
          <table class="contract-table">
            <tbody>
              {vehicule && (
                <tr><td>Véhicule</td><td>{vehicule.nom}{vehicule.modele ? ` — ${vehicule.modele}` : ''}{vehicule.annee ? ` (${vehicule.annee})` : ''}</td></tr>
              )}
              {vehicule?.immatriculation && <tr><td>Plaque d'immatriculation</td><td>{vehicule.immatriculation}</td></tr>}
              {vehicule?.carburant && <tr><td>Type de carburant</td><td>{vehicule.carburant}</td></tr>}
              {reservation.locataire_nom && <tr><td>Nom du locataire</td><td>{reservation.locataire_nom}</td></tr>}
              {reservation.locataire_date_naissance && <tr><td>Date de naissance</td><td>{fmtDate(reservation.locataire_date_naissance)}</td></tr>}
              {reservation.locataire_lieu_naissance && <tr><td>Lieu de naissance</td><td>{reservation.locataire_lieu_naissance}</td></tr>}
              {reservation.locataire_permis_numero && <tr><td>Numéro de permis de conduire</td><td>{reservation.locataire_permis_numero}</td></tr>}
              {reservation.locataire_permis_date && <tr><td>Date d'obtention du permis</td><td>{fmtDate(reservation.locataire_permis_date)}</td></tr>}
              {reservation.locataire_adresse && <tr><td>Adresse du locataire</td><td>{reservation.locataire_adresse}</td></tr>}
              {reservation.email_client && <tr><td>Email</td><td>{reservation.email_client}</td></tr>}
            </tbody>
          </table>
        </section>

        <p class="contract-disclaimer">
          Ce document est un récépissé de réservation confirmant votre paiement. Il ne constitue pas un contrat de location.
          Le contrat définitif sera établi et signé contradictoirement lors de la remise des clés, après vérification de votre identité et de votre permis de conduire.
        </p>
      </div>
    ) : (
      <div class="contract-placeholder no-print">
        <p>Récupération du reçu en cours…</p>
      </div>
    )}

    <button onclick="window.print()" class="btn-print no-print">
      🖨️ Imprimer le reçu (PDF)
    </button>

    <!-- CAUTION — statut mis à jour en live via polling -->
    <div class={`caution-status no-print${cautionDejaAutorisee ? ' done' : ''}`} id="caution-block">
      <span class="caution-icon" id="caution-icon">{cautionDejaAutorisee ? '🔒' : '⏳'}</span>
      <div>
        <p class="caution-title-line" id="caution-title">
          {cautionDejaAutorisee ? 'Caution enregistrée' : "Caution en cours d'enregistrement…"}
        </p>
        <p class="caution-sub" id="caution-sub">
          {cautionDejaAutorisee
            ? <>L'empreinte bancaire de <strong>900 €</strong> a bien été enregistrée. <strong>Aucune somme n'a été débitée.</strong></>
            : <>Nous enregistrons automatiquement votre empreinte bancaire de <strong>900 €</strong>. <strong>Aucune somme ne sera débitée.</strong></>
          }
        </p>
        {reservation?.id && !cautionDejaAutorisee && (
          <a
            href={`/api/stripe/caution?reservation_id=${reservation.id}`}
            class="caution-link-fallback"
            id="caution-fallback"
            style="display:none"
          >
            Compléter la caution manuellement →
          </a>
        )}
      </div>
    </div>

    <p class="mail-info no-print">Un e-mail de confirmation a été envoyé par <strong>Ship Cars</strong>.</p>
    <a href="/" class="back-home no-print">← Retour au catalogue</a>
  </div>
</MainLayout>

<style>
  .page-wrapper {
    max-width: 820px;
    margin: 3rem auto;
    padding: 0 1.5rem 5rem;
  }

  /* ── CONFIRMATION ── */
  .confirm-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(62,207,142,0.08);
    border: 1px solid rgba(62,207,142,0.25);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .confirm-icon { font-size: 2rem; flex-shrink: 0; }

  .confirm-title {
    font-family: 'Exo 2', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .confirm-sub { font-size: 0.9rem; color: var(--text-muted); }

  /* ── CONTRAT ── */
  .contract {
    background: #ffffff;
    color: #1a1a2e;
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 40px rgba(0,0,0,0.35);
  }

  .contract-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #e8eaf0;
    margin-bottom: 2rem;
  }

  .contract-brand { display: flex; align-items: center; gap: 10px; }

  .contract-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 50%;
  }

  .contract-brand-name {
    font-family: 'Exo 2', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: #0f1e33;
  }
  .contract-brand-name em { color: #4dd4c8; font-style: normal; }

  .contract-id-block { text-align: right; }

  .contract-title-label {
    font-family: 'Exo 2', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a2e;
  }

  .contract-title-note {
    font-size: 0.72rem;
    color: #b45309;
    font-weight: 600;
    margin-top: 4px;
    font-style: italic;
  }

  .contract-num {
    font-size: 0.82rem;
    color: #6b7280;
    font-weight: 600;
    margin-top: 3px;
  }

  .contract-section { margin-bottom: 2rem; }

  .contract-section-title {
    font-family: 'Exo 2', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: #1a1a2e;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #e8eaf0;
    margin-bottom: 0.25rem;
  }

  .contract-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .contract-table tr { border-bottom: 1px solid #f3f4f6; }

  .contract-table td {
    padding: 10px 6px;
    color: #374151;
    vertical-align: top;
    line-height: 1.4;
  }

  .contract-table td:first-child {
    font-weight: 600;
    color: #1f2937;
    width: 42%;
  }

  .contract-disclaimer {
    font-size: 0.75rem;
    color: #9ca3af;
    line-height: 1.6;
    border-top: 1px solid #e8eaf0;
    padding-top: 1rem;
    margin-top: 0.5rem;
  }

  .contract-placeholder {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* ── BOUTON IMPRIMER ── */
  .btn-print {
    display: block;
    width: 100%;
    background: var(--teal);
    color: var(--navy-deep);
    font-family: 'Exo 2', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 14px 28px;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    margin-bottom: 2rem;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 16px rgba(77,212,200,0.3);
  }
  .btn-print:hover { background: var(--teal-bright); transform: translateY(-1px); }

  /* ── CAUTION STATUS ── */
  .caution-status {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(77, 212, 200, 0.2);
    background: var(--bg-2);
    transition: background 0.4s, border-color 0.4s;
  }

  .caution-status.done {
    background: rgba(62, 207, 142, 0.06);
    border-color: rgba(62, 207, 142, 0.3);
  }

  .caution-status.failed {
    background: rgba(234, 179, 8, 0.06);
    border-color: rgba(234, 179, 8, 0.3);
  }

  .caution-icon { font-size: 1.5rem; flex-shrink: 0; line-height: 1.2; }

  .caution-title-line {
    font-family: 'Exo 2', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
    margin-bottom: 0.3rem;
  }

  .caution-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0 0 0.5rem;
  }

  .caution-link-fallback {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #3498db;
    text-decoration: none;
    margin-top: 0.5rem;
  }

  .caution-link-fallback:hover { text-decoration: underline; }

  .mail-info {
    font-size: 0.85rem;
    color: var(--text-dim);
    text-align: center;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .back-home {
    display: block;
    text-align: center;
    color: var(--teal);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s;
  }
  .back-home:hover { color: var(--teal-bright); }

  /* ── IMPRESSION ── */
  @media print {
    .no-print { display: none !important; }

    .page-wrapper { margin: 0; padding: 0; max-width: 100%; }

    .contract {
      box-shadow: none;
      border-radius: 0;
      padding: 1rem;
    }
  }
</style>

{!cautionDejaAutorisee && reservation?.id && (
  <script is:inline define:vars={{ reservationId: reservation.id }}>
    const MAX_ATTEMPTS = 20;
    const INTERVAL_MS  = 3000;
    let attempts = 0;

    const block    = document.getElementById('caution-block');
    const icon     = document.getElementById('caution-icon');
    const title    = document.getElementById('caution-title');
    const sub      = document.getElementById('caution-sub');
    const fallback = document.getElementById('caution-fallback');

    function setDone() {
      block?.classList.add('done');
      if (icon)  icon.textContent  = '🔒';
      if (title) title.textContent = 'Caution enregistrée';
      if (sub)   sub.innerHTML     = "L'empreinte bancaire de <strong>900 €</strong> a bien été enregistrée. <strong>Aucune somme n'a été débitée.</strong>";
      if (fallback) fallback.style.display = 'none';
    }

    function setFailed() {
      block?.classList.add('failed');
      if (icon)  icon.textContent  = '⚠️';
      if (title) title.textContent = 'Action requise : complétez votre caution';
      if (sub)   sub.innerHTML     = "L'enregistrement automatique n'a pas pu aboutir. Cliquez sur le lien ci-dessous pour déposer votre caution de <strong>900 €</strong> (aucun débit immédiat).";
      if (fallback) fallback.style.display = 'inline-block';
    }

    async function poll() {
      attempts++;
      try {
        const res  = await fetch(`/api/reservations/caution-status?reservation_id=${reservationId}`);
        const data = await res.json();

        if (data.caution_statut === 'autorisee') {
          setDone();
          return;
        }
      } catch (_) {}

      if (attempts >= MAX_ATTEMPTS) {
        setFailed();
        return;
      }
      setTimeout(poll, INTERVAL_MS);
    }

    setTimeout(poll, INTERVAL_MS);
  </script>
)}
