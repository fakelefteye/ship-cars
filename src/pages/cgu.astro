    color: var(--teal);
    background: var(--teal-soft);
    border: 1px solid rgba(77,212,200,0.25);
    padding: 4px 12px;
    border-radius: 99px;
    margin-bottom: 1rem;
  }

  .legal-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .legal-meta {
    font-size: 0.82rem;
    color: var(--text-dim);
  }

  .legal-body section {
    margin-bottom: 2.5rem;
  }

  .legal-body h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--teal);
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }

  .legal-body h3 {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--silver);
    margin: 1.2rem 0 0.5rem;
  }

  .legal-body p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .legal-body ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0.75rem;
