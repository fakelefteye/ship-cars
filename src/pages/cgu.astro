  }

  .legal-body a {
    color: var(--teal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal-info-box {
    background: var(--bg-2);
    border: 1px solid var(--border-md);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    font-size: 0.87rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-top: 0.75rem;
  }

