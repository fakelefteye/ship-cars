---
// src/pages/admin/calendrier.astro
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const cookies = Astro.request.headers.get('cookie') || '';
if (!cookies.includes('admin_auth=true')) return Astro.redirect('/admin');

const { data: vehicules } = await supabaseAdmin
  .from('vehicules').select('id, nom, getaround_id').order('nom');

const { data: reservations } = await supabaseAdmin
  .from('reservations')
  .select('id, vehicule_id, date_debut, date_fin, statut, email_client, locataire_nom, vehicules(nom)')
  .in('statut', ['paye', 'confirmee', 'en_attente_paiement'])
  .order('date_debut');

const { data: indisponibilites } = await supabaseAdmin
  .from('indisponibilites')
  .select('id, vehicule_id, date_debut, date_fin, source, note, getaround_rental_id, vehicules(nom)')
  .order('date_debut');
---

<MainLayout title="Calendrier — Admin Ship Cars">
  <!-- FullCalendar CSS + JS via CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.15/locales/fr.global.min.js"></script>

  <script is:inline define:vars={{
    RESA_DATA: reservations ?? [],
    INDIS_DATA: indisponibilites ?? [],
    VEHS_DATA: vehicules ?? []
  }}>
  document.addEventListener('DOMContentLoaded', () => {

    const COLORS = {
      paye:                { bg:'#15803d', border:'#166534', text:'#bbf7d0' },
      confirmee:           { bg:'#1d4ed8', border:'#1e3a8a', text:'#bfdbfe' },
      en_attente_paiement: { bg:'#b45309', border:'#92400e', text:'#fed7aa' },
      getaround:           { bg:'#7e22ce', border:'#581c87', text:'#e9d5ff' },
      manual:              { bg:'#a16207', border:'#713f12', text:'#fef08a' },
    };

    const STATUS_LABELS = {
      paye: 'Payée ✓',
      confirmee: 'Confirmée',
      en_attente_paiement: 'En attente de paiement',
    };

    let filterVId = '';

    function buildEvents() {
      const evs = [];
      (RESA_DATA || []).forEach(r => {
        if (filterVId && r.vehicule_id !== filterVId) return;
        const c = COLORS[r.statut] || COLORS.confirmee;
        const nom = r.vehicules?.nom ?? '?';
        evs.push({
          id: 'resa-' + r.id,
          title: nom + ' — ' + (r.locataire_nom || r.email_client || '?'),
          start: r.date_debut,
          end: r.date_fin,
          backgroundColor: c.bg,
          borderColor: c.border,
          textColor: c.text,
          extendedProps: { type: 'resa', raw: r, vehicule: nom },
        });
      });
      (INDIS_DATA || []).forEach(i => {
        if (filterVId && i.vehicule_id !== filterVId) return;
        const c = COLORS[i.source] || COLORS.manual;
        const nom = i.vehicules?.nom ?? '?';
        const label = i.source === 'getaround' ? '(Getaround)' : i.note || '(Bloqué)';
        evs.push({
          id: 'indis-' + i.id,
          title: nom + ' ' + label,
          start: i.date_debut,
          end: i.date_fin,
          backgroundColor: c.bg,
          borderColor: c.border,
          textColor: c.text,
          extendedProps: { type: 'indispo', raw: i, vehicule: nom },
        });
      });
      return evs;
    }

    function fmtDate(str) {
      return new Date(str).toLocaleString('fr-FR', {
        day: '2-digit', month: '2-digit', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });
    }

    function openModal(info) {
      const ev = info.event;
      const props = ev.extendedProps;
      const raw = props.raw;
      const type = props.type;

      document.getElementById('modal-overlay').style.display = 'flex';
      const body = document.getElementById('modal-body');

      let statusBadge = '';
      let actionBtn = '';
      let rows = '';

      if (type === 'resa') {
        const statut = raw.statut;
        const badgeColor = { paye:'#15803d', confirmee:'#1d4ed8', en_attente_paiement:'#b45309' }[statut] || '#555';
        statusBadge = `<span class="modal-badge" style="background:${badgeColor}20;color:${badgeColor};border:1px solid ${badgeColor}40">${STATUS_LABELS[statut] || statut}</span>`;
        rows = `
          <div class="modal-row"><span class="modal-label">Véhicule</span><span class="modal-value">${props.vehicule}</span></div>
          <div class="modal-row"><span class="modal-label">Client</span><span class="modal-value">${raw.locataire_nom || '—'}</span></div>
          <div class="modal-row"><span class="modal-label">Email</span><span class="modal-value">${raw.email_client || '—'}</span></div>
          <div class="modal-row"><span class="modal-label">Début</span><span class="modal-value">${fmtDate(raw.date_debut)}</span></div>
          <div class="modal-row"><span class="modal-label">Fin</span><span class="modal-value">${fmtDate(raw.date_fin)}</span></div>
        `;
        actionBtn = `<button class="btn-cancel" data-action="cancel-resa" data-id="${raw.id}">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/></svg>
          Annuler la réservation + libérer sur Getaround
        </button>`;
      } else {
        const isGA = raw.source === 'getaround';
        statusBadge = `<span class="modal-badge" style="background:${isGA ? '#7e22ce' : '#a16207'}20;color:${isGA ? '#a855f7' : '#d97706'};border:1px solid ${isGA ? '#7e22ce' : '#a16207'}40">${isGA ? 'Blocage Getaround' : 'Blocage manuel'}</span>`;
        rows = `
          <div class="modal-row"><span class="modal-label">Véhicule</span><span class="modal-value">${props.vehicule}</span></div>
          <div class="modal-row"><span class="modal-label">Début</span><span class="modal-value">${fmtDate(raw.date_debut)}</span></div>
          <div class="modal-row"><span class="modal-label">Fin</span><span class="modal-value">${fmtDate(raw.date_fin)}</span></div>
          ${raw.note ? `<div class="modal-row"><span class="modal-label">Motif</span><span class="modal-value">${raw.note}</span></div>` : ''}
        `;
        actionBtn = `<button class="btn-cancel" data-action="unblock" data-id="${raw.id}">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
          Supprimer ce blocage + libérer sur Getaround
        </button>`;
      }

      body.innerHTML = `
        <div class="modal-head">
          ${statusBadge}
          <h2 class="modal-title">${type === 'resa' ? 'Réservation' : 'Indisponibilité'}</h2>
        </div>
        <div class="modal-rows">${rows}</div>
        <div class="modal-footer">${actionBtn}</div>
        <div class="action-msg" style="display:none"></div>
      `;

      body.querySelector('[data-action]')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        const action = btn.dataset.action;
        const rid = btn.dataset.id;
        if (!confirm(action === 'cancel-resa'
          ? 'Annuler cette réservation ? Le créneau sera libéré sur Getaround.'
          : 'Supprimer ce blocage ? Le créneau sera libéré sur Getaround.')) return;

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> En cours...';
        const msgEl = body.querySelector('.action-msg');

        try {
          let res;
          if (action === 'cancel-resa') {
            res = await fetch('/api/reservations/cancel', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ reservation_id: rid }),
            });
          } else {
            res = await fetch('/api/admin/block-dates', {
              method: 'DELETE', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ indisponibilite_id: rid }),
            });
          }
          const data = await res.json();
          if (data.success) {
            msgEl.style.display = 'block';
            msgEl.className = 'action-msg ok';
            msgEl.textContent = action === 'cancel-resa'
              ? '✅ Réservation annulée, créneau libéré sur Getaround.'
              : '✅ Blocage supprimé, créneau libéré sur Getaround.';
            setTimeout(() => location.reload(), 1500);
          } else {
            msgEl.style.display = 'block';
            msgEl.className = 'action-msg err';
            msgEl.textContent = '❌ ' + (data.error || 'Erreur inconnue');
            btn.disabled = false;
            btn.textContent = action === 'cancel-resa' ? 'Annuler la réservation' : 'Supprimer le blocage';
          }
        } catch {
          msgEl.style.display = 'block';
          msgEl.className = 'action-msg err';
          msgEl.textContent = '❌ Erreur réseau';
          btn.disabled = false;
        }
      });
    }

    // Populate vehicle selects
    const filterSel = document.getElementById('filter-v');
    const blockSel = document.getElementById('sel-v');
    (VEHS_DATA || []).forEach(v => {
      const label = v.nom + (v.getaround_id ? ' ✓' : '');
      [filterSel, blockSel].forEach(sel => {
        const o = document.createElement('option');
        o.value = v.id; o.textContent = label;
        sel.appendChild(o);
      });
    });

    // Init FullCalendar (loaded globally via CDN)
    const FC = /** @type {any} */ (window).FullCalendar;
    const calEl = document.getElementById('fullcal');
    const calendar = new FC.Calendar(calEl, {
      locale: 'fr',
      initialView: 'dayGridMonth',
      headerToolbar: false,
      events: buildEvents(),
      eventClick: openModal,
      dayMaxEvents: 4,
      moreLinkText: n => `+${n} autres`,
      moreLinkClick: 'popover',
      nowIndicator: true,
      height: 'auto',
      eventDisplay: 'block',
      eventTimeFormat: { hour: '2-digit', minute: '2-digit', hour12: false },
      dayHeaderFormat: { weekday: 'short' },
      firstDay: 1,
      buttonText: { today: "Aujourd'hui", month: 'Mois', week: 'Semaine', day: 'Jour', list: 'Liste' },
    });
    calendar.render();

    // Custom toolbar wiring
    document.getElementById('btn-prev').addEventListener('click', () => calendar.prev());
    document.getElementById('btn-next').addEventListener('click', () => calendar.next());
    document.getElementById('btn-today').addEventListener('click', () => calendar.today());
    document.getElementById('view-month').addEventListener('click', () => {
      calendar.changeView('dayGridMonth');
      document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('view-month').classList.add('active');
    });
    document.getElementById('view-week').addEventListener('click', () => {
      calendar.changeView('timeGridWeek');
      document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('view-week').classList.add('active');
    });
    document.getElementById('view-list').addEventListener('click', () => {
      calendar.changeView('listMonth');
      document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('view-list').classList.add('active');
    });

    // Update title on nav
    function updateTitle() {
      const d = calendar.getDate();
      const title = d.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
      document.getElementById('cal-title').textContent = title.charAt(0).toUpperCase() + title.slice(1);
    }
    calendar.on('datesSet', updateTitle);
    updateTitle();

    // Filter by vehicle
    filterSel.addEventListener('change', () => {
      filterVId = filterSel.value;
      calendar.removeAllEvents();
      calendar.addEventSource(buildEvents());
    });

    // Modal close
    document.getElementById('modal-overlay').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeModal();
    });
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
    function closeModal() {
      document.getElementById('modal-overlay').style.display = 'none';
    }

    // Sync button
    document.getElementById('btn-sync').addEventListener('click', async () => {
      const btn = document.getElementById('btn-sync');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span> Sync...';
      try {
        const res = await fetch('/api/sync-calendar');
        const data = await res.json();
        showToast(data.success
          ? `✅ ${data.synced} créneau(x) importé(s) depuis Getaround.`
          : `❌ ${data.error}`, data.success ? 'ok' : 'err');
        if (data.success) setTimeout(() => location.reload(), 2500);
      } catch {
        showToast('❌ Erreur réseau', 'err');
      }
      btn.disabled = false;
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg> Sync Getaround';
    });

    // Block form
    document.getElementById('form-block').addEventListener('submit', async e => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type=submit]');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span> En cours...';
      const vehicule_id = document.getElementById('sel-v').value;
      const date_debut  = new Date(document.getElementById('inp-debut').value).toISOString();
      const date_fin    = new Date(document.getElementById('inp-fin').value).toISOString();
      const note        = document.getElementById('inp-note').value;
      try {
        const res = await fetch('/api/admin/block-dates', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ vehicule_id, date_debut, date_fin, note }),
        });
        const data = await res.json();
        if (data.success) {
          showToast('✅ Créneau bloqué' + (data.getaround_blocked ? ' — synchronisé sur Getaround' : '') + '.', 'ok');
          setTimeout(() => location.reload(), 2000);
        } else {
          showToast('❌ ' + (data.error || 'Erreur inconnue'), 'err');
          btn.disabled = false;
          btn.textContent = 'Bloquer ce créneau';
        }
      } catch {
        showToast('❌ Erreur réseau', 'err');
        btn.disabled = false;
        btn.textContent = 'Bloquer ce créneau';
      }
    });

    function showToast(msg, type) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast ' + type + ' show';
      setTimeout(() => t.classList.remove('show'), 4000);
    }
  });
  </script>

  <div class="page">

    <!-- Topbar -->
    <div class="topbar">
      <a href="/admin" class="back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        Tableau de bord
      </a>
      <div class="topbar-right">
        <select id="filter-v" class="sel-filter">
          <option value="">Tous les véhicules</option>
        </select>
        <button id="btn-sync" class="btn-sync">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
          Sync Getaround
        </button>
        <a href="/api/admin/webhook-events" target="_blank" class="btn-logs">Logs webhook</a>
      </div>
    </div>

    <!-- Calendar toolbar -->
    <div class="cal-toolbar">
      <div class="cal-nav">
        <button id="btn-prev" class="nav-btn" title="Mois précédent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <h1 id="cal-title" class="cal-month-title">—</h1>
        <button id="btn-next" class="nav-btn" title="Mois suivant">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <button id="btn-today" class="btn-today">Aujourd'hui</button>
      </div>

      <div class="cal-views">
        <button id="view-month" class="view-btn active">Mois</button>
        <button id="view-week" class="view-btn">Semaine</button>
        <button id="view-list" class="view-btn">Liste</button>
      </div>
    </div>

    <!-- Legend -->
    <div class="legend">
      <div class="leg"><span class="leg-dot" style="background:#15803d"></span>Payée</div>
      <div class="leg"><span class="leg-dot" style="background:#1d4ed8"></span>Confirmée</div>
      <div class="leg"><span class="leg-dot" style="background:#b45309"></span>En attente</div>
      <div class="leg"><span class="leg-dot" style="background:#7e22ce"></span>Getaround</div>
      <div class="leg"><span class="leg-dot" style="background:#a16207"></span>Blocage manuel</div>
    </div>

    <!-- FullCalendar -->
    <div class="cal-card">
      <div id="fullcal"></div>
    </div>

    <!-- Block form -->
    <details class="block-panel">
      <summary>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Bloquer un créneau manuellement
      </summary>
      <div class="block-inner">
        <p class="block-note">Ce créneau sera bloqué sur ce site ET synchronisé sur Getaround.</p>
        <form id="form-block" class="block-form">
          <div class="form-g">
            <label>Véhicule</label>
            <select id="sel-v" required><option value="">Choisir...</option></select>
          </div>
          <div class="form-g">
            <label>Début</label>
            <input type="datetime-local" id="inp-debut" required />
          </div>
          <div class="form-g">
            <label>Fin</label>
            <input type="datetime-local" id="inp-fin" required />
          </div>
          <div class="form-g">
            <label>Motif <small>(optionnel)</small></label>
            <input type="text" id="inp-note" placeholder="Révision, Privatisation..." />
          </div>
          <div class="form-g form-g-btn">
            <button type="submit" class="btn-block">Bloquer ce créneau</button>
          </div>
        </form>
      </div>
    </details>
  </div>

  <!-- Modal -->
  <div id="modal-overlay" class="modal-overlay" style="display:none">
    <div class="modal-box">
      <button id="modal-close" class="modal-close" title="Fermer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div id="modal-body"></div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="toast"></div>
</MainLayout>

<style is:global>
  /* FullCalendar dark theme overrides */
  :root {
    --fc-border-color: #1e2d3d;
    --fc-button-bg-color: #1a2b3c;
    --fc-button-border-color: #2a3d50;
    --fc-button-hover-bg-color: #243448;
    --fc-button-hover-border-color: #344d63;
    --fc-button-active-bg-color: #4dd4c8;
    --fc-button-active-border-color: #4dd4c8;
    --fc-event-border-color: transparent;
    --fc-today-bg-color: rgba(77,212,200,0.06);
    --fc-page-bg-color: transparent;
    --fc-neutral-bg-color: #0f1e33;
    --fc-list-event-hover-bg-color: rgba(77,212,200,0.06);
    --fc-highlight-color: rgba(77,212,200,0.12);
  }

  .fc {
    font-family: system-ui, -apple-system, sans-serif;
    color: #cbd5e1;
    font-size: 0.84rem;
  }
  .fc-theme-standard td, .fc-theme-standard th { border-color: #1e2d3d; }
  .fc-col-header-cell { background: #07111f; }
  .fc-col-header-cell-cushion {
    color: #4b6073 !important;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none !important;
    padding: 10px 0;
  }
  .fc-daygrid-day-number {
    color: #4b6073;
    font-size: 12.5px;
    font-weight: 600;
    text-decoration: none !important;
    padding: 6px 8px;
  }
  .fc-day-today .fc-daygrid-day-number {
    background: #4dd4c8;
    color: #0b1929;
    font-weight: 800;
    border-radius: 50%;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin: 5px;
  }
  .fc-day-other .fc-daygrid-day-number { color: #2a3d50; }
  .fc-daygrid-day.fc-day-other { background: #06101c; }
  .fc-daygrid-day-frame { min-height: 80px; }
  .fc-event {
    border-radius: 4px !important;
    padding: 1px 5px !important;
    font-size: 0.75rem !important;
    font-weight: 600 !important;
    cursor: pointer;
    border: none !important;
    border-left: 3px solid var(--fc-event-border-color, transparent) !important;
  }
  .fc-event:hover { filter: brightness(1.2); }
  .fc-daygrid-more-link {
    color: #4dd4c8 !important;
    font-weight: 600;
    font-size: 0.72rem;
  }
  .fc-timegrid-slot { height: 3rem; }
  .fc-timegrid-slot-label { color: #3d5166; font-size: 0.72rem; }
  .fc-timegrid-now-indicator-line { border-color: #f87171; }
  .fc-timegrid-now-indicator-arrow { border-color: #f87171; }
  .fc-list-table tr { border-color: #1e2d3d; }
  .fc-list-day-cushion { background: #0f1e33 !important; }
  .fc-list-day-text, .fc-list-day-side-text {
    color: #4dd4c8 !important;
    text-decoration: none !important;
    font-size: 0.8rem;
  }
  .fc-list-event-title a { color: #cbd5e1 !important; text-decoration: none !important; }
  .fc-list-event:hover td { background: rgba(77,212,200,0.06) !important; }
  .fc-popover {
    background: #162130 !important;
    border: 1px solid #253647 !important;
    border-radius: 10px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,.5) !important;
  }
  .fc-popover-header { background: #0f1e33 !important; color: #cbd5e1 !important; border-radius: 10px 10px 0 0 !important; }
  .fc-popover-close { color: #6b7280 !important; }
  .fc-scrollgrid-section-header th { border-color: #1e2d3d; }
</style>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  .page {
    max-width: 1300px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 5rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* Topbar */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
