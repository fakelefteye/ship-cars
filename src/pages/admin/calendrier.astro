---
// src/pages/admin/calendrier.astro
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const cookies = Astro.request.headers.get('cookie') || '';
if (!cookies.includes('admin_auth=true')) return Astro.redirect('/admin');

const { data: vehicules } = await supabaseAdmin
  .from('vehicules').select('id, nom, getaround_id').order('nom');

const { data: reservations } = await supabaseAdmin
  .from('reservations')
  .select('id, vehicule_id, date_debut, date_fin, statut, email_client, locataire_nom, vehicules(nom)')
  .in('statut', ['paye', 'confirmee', 'en_attente_paiement'])
  .order('date_debut');

const { data: indisponibilites } = await supabaseAdmin
  .from('indisponibilites')
  .select('id, vehicule_id, date_debut, date_fin, source, note, getaround_rental_id, vehicules(nom)')
  .order('date_debut');
---

<MainLayout title="Calendrier — Admin Ship Cars">
  <script is:inline define:vars={{
    RESA_DATA: reservations ?? [],
    INDIS_DATA: indisponibilites ?? [],
    VEHS_DATA: vehicules ?? []
  }}>
  (() => {
    const MONTHS = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
    const COLORS = {
      paye:                { bg:'rgba(21,128,61,0.85)',   text:'#bbf7d0', border:'#16a34a' },
      confirmee:           { bg:'rgba(29,78,216,0.85)',   text:'#bfdbfe', border:'#3b82f6' },
      en_attente_paiement: { bg:'rgba(180,83,9,0.85)',    text:'#fed7aa', border:'#f97316' },
      getaround:           { bg:'rgba(126,34,206,0.85)',  text:'#e9d5ff', border:'#a855f7' },
      manual:              { bg:'rgba(161,98,7,0.85)',    text:'#fef08a', border:'#eab308' },
    };

    let year  = new Date().getFullYear();
    let month = new Date().getMonth();
    let filterVId = '';

    function getEvents() {
      const evs = [];
      (RESA_DATA || []).forEach(r => {
        if (filterVId && r.vehicule_id !== filterVId) return;
        evs.push({
          id: r.id, type: 'resa', colorKey: r.statut,
          vehicule: r.vehicules?.nom ?? '?',
          client: r.locataire_nom || r.email_client || '?',
          email: r.email_client, statut: r.statut,
          start: new Date(r.date_debut), end: new Date(r.date_fin), raw: r,
        });
      });
      (INDIS_DATA || []).forEach(i => {
        if (filterVId && i.vehicule_id !== filterVId) return;
        evs.push({
          id: i.id, type: 'indispo', colorKey: i.source,
          vehicule: i.vehicules?.nom ?? '?',
          note: i.note, source: i.source,
          start: new Date(i.date_debut), end: new Date(i.date_fin), raw: i,
        });
      });
      return evs;
    }

    function dayStart(d) { return new Date(d.getFullYear(), d.getMonth(), d.getDate()); }
    function addDays(d, n) { const r = new Date(d); r.setDate(r.getDate() + n); return r; }
    function sameDay(a, b) {
      return a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate();
    }
    function dayDiff(a, b) { return Math.round((b - a) / 86400000); }

    function assignLanes(evs) {
      const sorted = [...evs].sort((a,b) => a.start - b.start);
      const result = [];
      const laneEnds = [];
      for (const ev of sorted) {
        let lane = laneEnds.findIndex(e => e <= ev.start);
        if (lane === -1) lane = laneEnds.length;
        laneEnds[lane] = ev.end;
        result.push({ ev, lane });
      }
      return result;
    }

    function render() {
      document.getElementById('cal-title').textContent = MONTHS[month] + ' ' + year;
      const body = document.getElementById('cal-body');
      const today = new Date();

      let startDow = new Date(year, month, 1).getDay();
      startDow = startDow === 0 ? 6 : startDow - 1;
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const numWeeks = Math.ceil((startDow + daysInMonth) / 7);
      const allEvents = getEvents();
      let html = '';

      for (let w = 0; w < numWeeks; w++) {
        const weekActualStart = new Date(year, month, w * 7 - startDow + 1);
        const weekEnd = addDays(weekActualStart, 7);

        const weekEvs = allEvents.filter(ev => {
          const es = dayStart(ev.start);
          const ee = dayStart(ev.end);
          return es < weekEnd && ee >= weekActualStart;
        });

        const positioned = assignLanes(weekEvs);
        const maxLane = positioned.length > 0 ? Math.max(...positioned.map(p => p.lane)) : -1;
        const evAreaH = maxLane >= 0 ? (maxLane + 1) * 26 + 6 : 0;

        let cellsHtml = '';
        for (let d = 0; d < 7; d++) {
          const dayNum = w * 7 + d - startDow + 1;
          const isInMonth = dayNum >= 1 && dayNum <= daysInMonth;
          const cellDate = isInMonth ? new Date(year, month, dayNum) : null;
          const isToday = cellDate && sameDay(cellDate, today);
          const isWeekend = d >= 5;
          cellsHtml += `<div class="cal-cell${!isInMonth ? ' other-month' : ''}${isToday ? ' is-today' : ''}${isWeekend ? ' weekend' : ''}">`;
          if (isInMonth) cellsHtml += `<span class="day-n${isToday ? ' today-n' : ''}">${dayNum}</span>`;
          cellsHtml += '</div>';
        }

        let barsHtml = '';
        for (const { ev, lane } of positioned) {
          const evStartDay = dayStart(ev.start);
          const evEndDay   = dayStart(ev.end);
          const visStart = evStartDay < weekActualStart ? weekActualStart : evStartDay;
          const visEnd   = evEndDay >= weekEnd ? addDays(weekEnd, -1) : evEndDay;
          const startCol = dayDiff(weekActualStart, visStart);
          const endCol   = dayDiff(weekActualStart, visEnd) + 1;
          const left  = (startCol / 7 * 100).toFixed(2) + '%';
          const width = ((endCol - startCol) / 7 * 100).toFixed(2) + '%';
          const top   = (lane * 26 + 3) + 'px';
          const c = COLORS[ev.colorKey] || { bg:'#1e293b', text:'#94a3b8', border:'#334155' };
          const isStart = evStartDay >= weekActualStart;
          const isEnd   = evEndDay < weekEnd;
          const rl = isStart ? '4px' : '0';
          const rr = isEnd   ? '4px' : '0';
          const label = ev.type === 'resa'
            ? ev.vehicule + ' — ' + ev.client
            : ev.vehicule + (ev.note ? ' — ' + ev.note : ev.source === 'getaround' ? ' (Getaround)' : ' (Bloqué)');
          const prefix = (!isStart) ? '◀ ' : '';
          const suffix = (!isEnd)   ? ' ▶' : '';
          barsHtml += `<div class="ev-bar" style="left:${left};width:${width};top:${top};background:${c.bg};color:${c.text};border-left:3px solid ${c.border};border-radius:${rl} ${rr} ${rr} ${rl}" data-id="${ev.id}" data-type="${ev.type}" title="${label}"><span class="ev-lbl">${prefix}${label}${suffix}</span></div>`;
        }

        html += `<div class="week-row"><div class="week-cells">${cellsHtml}</div><div class="week-evs" style="height:${evAreaH}px">${barsHtml}</div></div>`;
      }

      body.innerHTML = html;
      body.querySelectorAll('.ev-bar').forEach(bar => {
        bar.addEventListener('click', e => {
          e.stopPropagation();
          openModal(bar.dataset.id, bar.dataset.type, allEvents);
        });
      });
    }

    function fmtDate(d) {
      return d.toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' });
    }

    function openModal(id, type, events) {
      const ev = events.find(e => String(e.id) === String(id) && e.type === type);
      if (!ev) return;
      const c = COLORS[ev.colorKey] || { border:'#4dd4c8', text:'#4dd4c8' };
      let html = '';

      if (type === 'resa') {
        const labels = { paye:'Payée ✓', confirmee:'Confirmée', en_attente_paiement:'En attente de paiement' };
        html = `
          <div class="modal-tag" style="border-color:${c.border};color:${c.text}">Réservation — ${labels[ev.statut] || ev.statut}</div>
          <h2 class="modal-title">${ev.vehicule}</h2>
          <div class="modal-rows">
            <div class="mr"><span>Client</span><strong>${ev.client}</strong></div>
            ${ev.email ? `<div class="mr"><span>Email</span><strong>${ev.email}</strong></div>` : ''}
            <div class="mr"><span>Début</span><strong>${fmtDate(ev.start)}</strong></div>
            <div class="mr"><span>Fin</span><strong>${fmtDate(ev.end)}</strong></div>
          </div>
          <div class="modal-actions">
            <button class="btn-danger" data-action="cancel-resa" data-id="${ev.id}">Annuler la réservation + libérer sur Getaround</button>
          </div>`;
      } else {
        html = `
          <div class="modal-tag" style="border-color:${c.border};color:${c.text}">${ev.source === 'getaround' ? 'Indisponibilité Getaround' : 'Blocage manuel'}</div>
          <h2 class="modal-title">${ev.vehicule}</h2>
          <div class="modal-rows">
            <div class="mr"><span>Début</span><strong>${fmtDate(ev.start)}</strong></div>
            <div class="mr"><span>Fin</span><strong>${fmtDate(ev.end)}</strong></div>
            ${ev.note ? `<div class="mr"><span>Motif</span><strong>${ev.note}</strong></div>` : ''}
          </div>
          <div class="modal-actions">
            <button class="btn-danger" data-action="unblock" data-id="${ev.id}">Supprimer ce blocage + libérer sur Getaround</button>
          </div>`;
      }

      document.getElementById('modal-body').innerHTML = html;
      document.getElementById('modal').style.display = 'flex';

      document.querySelector('[data-action]')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        const action = btn.dataset.action;
        const rid = btn.dataset.id;
        const msg = action === 'cancel-resa'
          ? 'Annuler cette réservation ? Le créneau sera libéré sur Getaround.'
          : 'Supprimer ce blocage ? Le créneau sera libéré sur Getaround.';
        if (!confirm(msg)) return;
        btn.disabled = true;
        btn.textContent = '⏳ En cours...';
        try {
          let res, data;
          if (action === 'cancel-resa') {
            res = await fetch('/api/reservations/cancel', {
              method:'POST', headers:{'Content-Type':'application/json'},
              body: JSON.stringify({ reservation_id: rid }),
            });
          } else {
            res = await fetch('/api/admin/block-dates', {
              method:'DELETE', headers:{'Content-Type':'application/json'},
              body: JSON.stringify({ indisponibilite_id: rid }),
            });
          }
          data = await res.json();
          if (data.success) {
            closeModal();
            setTimeout(() => location.reload(), 400);
          } else {
            alert('Erreur : ' + (data.error || 'Inconnue'));
            btn.disabled = false;
            btn.textContent = action === 'cancel-resa' ? 'Annuler la réservation' : 'Supprimer le blocage';
          }
        } catch {
          alert('Erreur réseau');
          btn.disabled = false;
        }
      });
    }

    function closeModal() {
      document.getElementById('modal').style.display = 'none';
    }

    // Navigation
    document.getElementById('btn-prev').addEventListener('click', () => {
      month--; if (month < 0) { month = 11; year--; } render();
    });
    document.getElementById('btn-next').addEventListener('click', () => {
      month++; if (month > 11) { month = 0; year++; } render();
    });
    document.getElementById('btn-today').addEventListener('click', () => {
      year = new Date().getFullYear(); month = new Date().getMonth(); render();
    });

    // Vehicle filter + block form selects
    const fSel = document.getElementById('filter-v');
    const bSel = document.getElementById('sel-v');
    (VEHS_DATA || []).forEach(v => {
      const label = v.nom + (v.getaround_id ? ' ✓' : '');
      [fSel, bSel].forEach((s, i) => {
        const o = document.createElement('option');
        o.value = v.id; o.textContent = label;
        s.appendChild(o);
      });
    });
    fSel.addEventListener('change', () => { filterVId = fSel.value; render(); });

    // Modal close
    document.getElementById('modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
    document.getElementById('modal-close').addEventListener('click', closeModal);

    // Sync button
    document.getElementById('btn-sync').addEventListener('click', async () => {
      const btn = document.getElementById('btn-sync');
      const msg = document.getElementById('sync-msg');
      btn.disabled = true; btn.textContent = '⏳ Sync...';
      msg.className = 'sync-msg'; msg.style.display = 'none';
      try {
        const res = await fetch('/api/sync-calendar');
        const data = await res.json();
        msg.style.display = 'block';
        if (data.success) {
          msg.classList.add('ok');
          msg.textContent = '✅ ' + data.synced + ' créneau(x) importé(s) depuis Getaround.';
          setTimeout(() => location.reload(), 2000);
        } else {
          msg.classList.add('err');
          msg.textContent = '❌ ' + data.error;
        }
      } catch {
        msg.style.display = 'block'; msg.classList.add('err');
        msg.textContent = '❌ Erreur réseau';
      }
      btn.disabled = false; btn.textContent = '↻ Sync Getaround';
    });

    // Block form
    document.getElementById('form-block').addEventListener('submit', async e => {
      e.preventDefault();
      const msg = document.getElementById('block-msg');
      msg.style.display = 'none';
      const vehicule_id = document.getElementById('sel-v').value;
      const date_debut  = new Date(document.getElementById('inp-debut').value).toISOString();
      const date_fin    = new Date(document.getElementById('inp-fin').value).toISOString();
      const note        = document.getElementById('inp-note').value;
      const btn = e.target.querySelector('button[type=submit]');
      btn.disabled = true; btn.textContent = '⏳...';
      try {
        const res = await fetch('/api/admin/block-dates', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ vehicule_id, date_debut, date_fin, note }),
        });
        const data = await res.json();
        msg.style.display = 'block';
        msg.className = 'block-msg ' + (data.success ? 'ok' : 'err');
        if (data.success) {
          msg.textContent = '✅ Créneau bloqué' + (data.getaround_blocked ? ' — synchronisé sur Getaround' : ' — non synchronisé Getaround (vérifiez l\'ID)') + '.';
          setTimeout(() => location.reload(), 2500);
        } else {
          msg.textContent = data.error || 'Erreur inconnue';
        }
      } catch {
        msg.style.display = 'block'; msg.className = 'block-msg err';
        msg.textContent = 'Erreur réseau';
      }
      btn.disabled = false; btn.textContent = 'Bloquer';
    });

    render();
  })();
  </script>

  <div class="page">
    <div class="topbar">
      <a href="/admin" class="back">← Tableau de bord</a>
      <div class="topbar-right">
        <select id="filter-v" class="sel-filter">
          <option value="">Tous les véhicules</option>
        </select>
        <button id="btn-sync" class="btn-sync">↻ Sync Getaround</button>
        <a href="/api/admin/webhook-events" target="_blank" class="btn-logs">Logs webhook</a>
      </div>
    </div>

    <div id="sync-msg" class="sync-msg" style="display:none"></div>

    <div class="cal-nav">
      <button id="btn-prev" class="nav-btn">‹</button>
      <h1 id="cal-title">—</h1>
      <button id="btn-next" class="nav-btn">›</button>
      <button id="btn-today" class="btn-today">Aujourd'hui</button>
    </div>

    <div class="legend">
      <span class="leg"><span class="dot" style="background:#16a34a"></span>Payée</span>
      <span class="leg"><span class="dot" style="background:#3b82f6"></span>Confirmée</span>
      <span class="leg"><span class="dot" style="background:#f97316"></span>En attente paiement</span>
      <span class="leg"><span class="dot" style="background:#a855f7"></span>Getaround (bloqué)</span>
      <span class="leg"><span class="dot" style="background:#eab308"></span>Blocage manuel</span>
    </div>

    <div class="cal-wrap">
      <div class="dow-header">
        <div>Lun</div><div>Mar</div><div>Mer</div>
        <div>Jeu</div><div>Ven</div>
        <div class="weekend-hdr">Sam</div>
        <div class="weekend-hdr">Dim</div>
      </div>
      <div id="cal-body"></div>
    </div>

    <details class="block-panel">
      <summary>+ Bloquer un créneau manuellement</summary>
      <div class="block-inner">
        <p class="block-sub">Ce créneau sera bloqué sur ce site ET sur Getaround simultanément.</p>
        <form id="form-block" class="block-form">
          <div class="form-g">
            <label>Véhicule</label>
            <select id="sel-v" required>
              <option value="">Choisir...</option>
            </select>
          </div>
          <div class="form-g">
            <label>Début</label>
            <input type="datetime-local" id="inp-debut" required />
          </div>
          <div class="form-g">
            <label>Fin</label>
            <input type="datetime-local" id="inp-fin" required />
          </div>
          <div class="form-g">
            <label>Motif (optionnel)</label>
            <input type="text" id="inp-note" placeholder="Révision, Privatisation..." />
          </div>
          <div class="form-g form-g-btn">
            <button type="submit" class="btn-block">Bloquer ce créneau</button>
          </div>
        </form>
        <div id="block-msg" class="block-msg" style="display:none"></div>
      </div>
    </details>
  </div>

  <!-- Modal -->
  <div id="modal" class="modal-overlay" style="display:none">
    <div class="modal-box">
      <button id="modal-close" class="modal-close">✕</button>
      <div id="modal-body"></div>
    </div>
  </div>
</MainLayout>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  .page {
    max-width: 1260px;
    margin: 0 auto;
    padding: 1.5rem 1rem 5rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* ── Topbar ──────────────────────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .back { font-size: 0.82rem; color: #6b7280; text-decoration: none; }
  .back:hover { color: #4dd4c8; }
  .topbar-right { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }

  .sel-filter {
    background: #1a2b3c;
    border: 1px solid #2a3d50;
    color: #cbd5e1;
    padding: 7px 11px;
    border-radius: 8px;
    font-size: 0.83rem;
    cursor: pointer;
    color-scheme: dark;
    height: 36px;
  }
  .btn-sync {
    background: #4dd4c8;
    color: #0f1e33;
    border: none;
    padding: 0 14px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.83rem;
    cursor: pointer;
    height: 36px;
    transition: opacity .15s;
  }
  .btn-sync:hover { opacity: .85; }
  .btn-sync:disabled { opacity: .5; cursor: not-allowed; }
  .btn-logs {
    background: transparent;
    color: #94a3b8;
    border: 1px solid #2a3d50;
    padding: 0 12px;
    border-radius: 8px;
    font-size: 0.8rem;
    text-decoration: none;
    height: 36px;
    display: flex;
    align-items: center;
  }
  .btn-logs:hover { border-color: #94a3b8; }

  .sync-msg {
    margin-bottom: 1rem;
    padding: 0.65rem 1rem;
    border-radius: 8px;
    font-size: 0.84rem;
  }
  .sync-msg.ok  { background: rgba(34,197,94,.1);  color:#4ade80; border:1px solid rgba(34,197,94,.25); }
  .sync-msg.err { background: rgba(239,68,68,.1); color:#f87171; border:1px solid rgba(239,68,68,.25); }

  /* ── Calendar nav ────────────────────────────────────────────────── */
  .cal-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }
  h1#cal-title {
    flex: 1;
    font-size: 1.45rem;
    font-weight: 800;
    color: #f0f4f8;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .nav-btn {
    background: #1a2b3c;
    border: 1px solid #2a3d50;
    color: #cbd5e1;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    font-size: 1.15rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .12s;
  }
  .nav-btn:hover { background: #243448; }
  .btn-today {
    background: transparent;
    border: 1px solid #2a3d50;
    color: #94a3b8;
    padding: 0 13px;
    height: 34px;
    border-radius: 8px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color .12s, color .12s;
  }
  .btn-today:hover { border-color: #4dd4c8; color: #4dd4c8; }

  /* ── Legend ──────────────────────────────────────────────────────── */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin-bottom: 0.9rem;
    font-size: 0.77rem;
    color: #6b7280;
  }
  .leg { display: flex; align-items: center; gap: 5px; }
  .dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }

  /* ── Calendar grid ───────────────────────────────────────────────── */
  .cal-wrap {
    background: #0b1929;
    border: 1px solid #1e2d3d;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .dow-header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    background: #07111f;
    border-bottom: 1px solid #1e2d3d;
  }
  .dow-header div {
    padding: 11px 0;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
    color: #3d5166;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }
  .weekend-hdr { color: #4d5e6e !important; }

  .week-row { border-bottom: 1px solid #131f2e; }
  .week-row:last-child { border-bottom: none; }

  .week-cells {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    height: 50px;
    border-bottom: 1px solid #0f1e2f;
  }
  .cal-cell {
    border-right: 1px solid #131f2e;
    padding: 7px 8px 4px;
  }
  .cal-cell:last-child { border-right: none; }
  .cal-cell.other-month { background: #06101c; }
  .cal-cell.is-today { background: rgba(77,212,200,.07); }
  .cal-cell.weekend { background: rgba(255,255,255,.012); }

  .day-n {
    font-size: 12.5px;
    font-weight: 600;
    color: #4b5a68;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    line-height: 1;
  }
