---
// src/pages/admin/calendrier.astro
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const cookies = Astro.request.headers.get('cookie') || '';
if (!cookies.includes('admin_auth=true')) return Astro.redirect('/admin');

const [
  { data: vehicules },
  { data: reservations },
  { data: indisponibilites },
  { data: tarifs },
] = await Promise.all([
  supabaseAdmin.from('vehicules')
    .select('id, nom, immatriculation, getaround_id, prix_journalier_base')
    .order('nom'),
  supabaseAdmin.from('reservations')
    .select('id, vehicule_id, date_debut, date_fin, statut, email_client, locataire_nom, vehicules(nom)')
    .in('statut', ['paye', 'confirmee', 'en_attente_paiement'])
    .order('date_debut'),
  supabaseAdmin.from('indisponibilites')
    .select('id, vehicule_id, date_debut, date_fin, source, note, getaround_rental_id, vehicules(nom)')
    .order('date_debut'),
  supabaseAdmin.from('tarifs_dynamiques')
    .select('vehicule_id, date_debut, date_fin, prix_journalier, label, couleur')
    .order('date_debut'),
]);
---

<MainLayout title="Calendrier — Admin Ship Cars">
<script is:inline define:vars={{
  VEHS:   vehicules        ?? [],
  RESAS:  reservations     ?? [],
  INDIS:  indisponibilites ?? [],
  TARIFS: tarifs           ?? [],
}}>
document.addEventListener('DOMContentLoaded', () => {
(() => {
  const MONTHS = ['Janvier','Février','Mars','Avril','Mai','Juin',
                  'Juillet','Août','Septembre','Octobre','Novembre','Décembre'];

  let year      = new Date().getFullYear();
  let month     = new Date().getMonth();
  let filterVId = '';

  /* ── utilitaires ──────────────────────────────────────────────────── */
  function toKey(d) {
    return d.getFullYear() + '-'
      + String(d.getMonth() + 1).padStart(2, '0') + '-'
      + String(d.getDate()).padStart(2, '0');
  }
  function ds(s) { const d = new Date(s); d.setHours(0,0,0,0); return d; }
  function fmt(s) {
    // timeZone explicite : compense les dates UTC stockées avant le fix timezone
    return new Date(s).toLocaleString('fr-FR', {
      day:'2-digit', month:'2-digit', year:'numeric',
      hour:'2-digit', minute:'2-digit',
      timeZone: 'Europe/Paris'
    });
  }

  /* ── construction de la map de jours ─────────────────────────────── */
  function buildMap() {
    const map    = {};   // 'YYYY-MM-DD' -> { type, raw }
    const prices = {};   // 'YYYY-MM-DD' -> prix_journalier

    // 1 — tarifs dynamiques
    TARIFS.forEach(t => {
      if (filterVId && t.vehicule_id !== filterVId) return;
      const d = ds(t.date_debut), e = ds(t.date_fin);
      while (d <= e) {
        const k = toKey(d);
        if (!prices[k]) prices[k] = t.prix_journalier;
        d.setDate(d.getDate() + 1);
      }
    });

    // 2 — réservations
    RESAS.forEach(r => {
      if (filterVId && r.vehicule_id !== filterVId) return;
      const d = ds(r.date_debut), e = ds(r.date_fin);
      while (d <= e) {
        map[toKey(d)] = { type:'resa', raw:r };
        d.setDate(d.getDate() + 1);
      }
    });

    // 3 — indisponibilités (sans écraser une résa)
    INDIS.forEach(i => {
      if (filterVId && i.vehicule_id !== filterVId) return;
      const d = ds(i.date_debut), e = ds(i.date_fin);
      while (d <= e) {
        const k = toKey(d);
        if (!map[k]) map[k] = { type:'indispo', raw:i };
        d.setDate(d.getDate() + 1);
      }
    });

    return { map, prices };
  }

  /* ── prix de base du véhicule sélectionné ────────────────────────── */
  function getBasePrice() {
    if (!filterVId) return null;
    const v = VEHS.find(v => v.id === filterVId);
    return v ? v.prix_journalier_base : null;
  }

  /* ── rendu du calendrier ─────────────────────────────────────────── */
  function render() {
    const todayKey       = toKey(new Date());
    const { map, prices} = buildMap();
    const basePrice      = getBasePrice();

    document.getElementById('cal-title').textContent = MONTHS[month] + ' ' + year;

    let startDow = new Date(year, month, 1).getDay();
    startDow = startDow === 0 ? 6 : startDow - 1;          // Lun = 0
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    const grid = document.getElementById('cal-grid');
    grid.innerHTML = '';

    // cases vides avant le 1er
    for (let i = 0; i < startDow; i++) {
      const el = document.createElement('div');
      el.className = 'dc dc-empty';
      grid.appendChild(el);
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const date    = new Date(year, month, d);
      const key     = toKey(date);
      const dow     = date.getDay();           // 0=Dim, 6=Sam
      const isWknd  = dow === 0 || dow === 6;
      const isToday = key === todayKey;
      const ev      = map[key];
      const price   = prices[key] ?? basePrice;

      const el = document.createElement('div');

      if (!ev) {
        // ── jour disponible ──────────────────────────────────────────
        el.className = 'dc dc-free' + (isWknd ? ' dc-weekend' : '') + (isToday ? ' dc-today' : '');
        el.innerHTML =
          `<span class="dc-num${isToday ? ' dc-num-today' : ''}">${d}</span>` +
          (price != null ? `<span class="dc-price">${Math.round(price)} €</span>` : '');

      } else if (ev.type === 'resa') {
        // ── réservé ──────────────────────────────────────────────────
        const r   = ev.raw;
        const bgC = { paye:'#16a34a', confirmee:'#1d4ed8', en_attente_paiement:'#b45309' };
        const bg  = bgC[r.statut] || '#374151';
        el.className = 'dc dc-resa' + (isToday ? ' dc-today' : '');
        el.style.background = bg;
        el.style.cursor = 'pointer';
        const client = r.locataire_nom || r.email_client || '?';
        el.innerHTML =
          `<span class="dc-num dc-num-inv">${d}</span>` +
          `<span class="dc-tag">Réservé</span>` +
          `<span class="dc-client">${client.length > 11 ? client.slice(0,11) + '…' : client}</span>`;
        el.addEventListener('click', () => openModal('resa', r));

      } else {
        // ── bloqué ───────────────────────────────────────────────────
        const i  = ev.raw;
        const bg = i.source === 'getaround' ? '#4c1d95' : '#374151';
        el.className = 'dc dc-blocked' + (isToday ? ' dc-today' : '');
        el.style.background = bg;
        el.style.cursor = 'pointer';
        el.innerHTML =
          `<span class="dc-num dc-num-inv">${d}</span>` +
          `<span class="dc-tag">${i.source === 'getaround' ? 'Getaround' : 'Bloqué'}</span>`;
        el.addEventListener('click', () => openModal('indispo', i));
      }

      grid.appendChild(el);
    }
  }

  /* ── modal ───────────────────────────────────────────────────────── */
  function openModal(type, raw) {
    const overlay = document.getElementById('modal-overlay');
    const body    = document.getElementById('modal-body');
    let html = '';

    if (type === 'resa') {
      const bgC   = { paye:'#16a34a', confirmee:'#1d4ed8', en_attente_paiement:'#b45309' };
      const lblC  = { paye:'Payée ✓', confirmee:'Confirmée', en_attente_paiement:'En attente de paiement' };
      const color = bgC[raw.statut] || '#374151';
      html = `
        <span class="mbadge" style="background:${color}22;color:${color};border:1px solid ${color}44">${lblC[raw.statut] || raw.statut}</span>
        <h2 class="mtitle">Réservation</h2>
        <div class="mrows">
          <div class="mrow"><span>Véhicule</span><strong>${raw.vehicules?.nom || '—'}</strong></div>
          <div class="mrow"><span>Client</span><strong>${raw.locataire_nom || '—'}</strong></div>
          <div class="mrow"><span>Email</span><strong>${raw.email_client || '—'}</strong></div>
          <div class="mrow"><span>Début</span><strong>${fmt(raw.date_debut)}</strong></div>
          <div class="mrow"><span>Fin</span><strong>${fmt(raw.date_fin)}</strong></div>
        </div>
        <button class="mbtn" data-action="cancel-resa" data-id="${raw.id}">
          Annuler la réservation + libérer sur Getaround
        </button>
        <div class="mmsg" style="display:none"></div>`;
    } else {
      const isGA  = raw.source === 'getaround';
      const color = isGA ? '#7c3aed' : '#6b7280';
      html = `
        <span class="mbadge" style="background:${color}22;color:${color};border:1px solid ${color}44">${isGA ? 'Blocage Getaround' : 'Blocage manuel'}</span>
        <h2 class="mtitle">Indisponibilité</h2>
        <div class="mrows">
          <div class="mrow"><span>Véhicule</span><strong>${raw.vehicules?.nom || '—'}</strong></div>
          <div class="mrow"><span>Début</span><strong>${fmt(raw.date_debut)}</strong></div>
          <div class="mrow"><span>Fin</span><strong>${fmt(raw.date_fin)}</strong></div>
          ${raw.note ? `<div class="mrow"><span>Motif</span><strong>${raw.note}</strong></div>` : ''}
        </div>
        <button class="mbtn" data-action="unblock" data-id="${raw.id}">
          Supprimer le blocage + libérer sur Getaround
        </button>
        <div class="mmsg" style="display:none"></div>`;
    }

    body.innerHTML = html;
    overlay.style.display = 'flex';

    body.querySelector('[data-action]').addEventListener('click', async e => {
      const btn    = e.currentTarget;
      const action = btn.dataset.action;
      const id     = btn.dataset.id;
      if (!confirm(action === 'cancel-resa'
        ? 'Annuler cette réservation ? Le créneau sera libéré sur Getaround.'
        : 'Supprimer ce blocage ? Le créneau sera libéré sur Getaround.')) return;
      btn.disabled = true;
      btn.innerHTML = '<span class="spin"></span> En cours…';
      const msg = body.querySelector('.mmsg');
      try {
        const res = await fetch(
          action === 'cancel-resa' ? '/api/reservations/cancel' : '/api/admin/block-dates',
          { method: action === 'cancel-resa' ? 'POST' : 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(action === 'cancel-resa'
              ? { reservation_id: id } : { indisponibilite_id: id }) }
        );
        const data = await res.json();
        if (data.success) {
          msg.style.display = 'block'; msg.className = 'mmsg ok';
          msg.textContent = action === 'cancel-resa'
            ? '✅ Réservation annulée, créneau libéré sur Getaround.'
            : '✅ Blocage supprimé, créneau libéré sur Getaround.';
          setTimeout(() => location.reload(), 1400);
        } else {
          msg.style.display = 'block'; msg.className = 'mmsg err';
          msg.textContent = '❌ ' + (data.error || 'Erreur inconnue');
          btn.disabled = false; btn.textContent = 'Réessayer';
        }
      } catch {
        msg.style.display = 'block'; msg.className = 'mmsg err';
        msg.textContent = '❌ Erreur réseau'; btn.disabled = false;
      }
    });
  }

  function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }

  /* ── init selects ────────────────────────────────────────────────── */
  const fSel = document.getElementById('filter-v');
  const bSel = document.getElementById('sel-v');
  VEHS.forEach(v => {
    const lbl = v.immatriculation
      ? v.immatriculation + ' — ' + v.nom
      : v.nom + (v.getaround_id ? ' ✓' : '');
    [fSel, bSel].forEach(s => {
      const o = document.createElement('option');
      o.value = v.id; o.textContent = lbl; s.appendChild(o);
    });
  });
  fSel.addEventListener('change', () => { filterVId = fSel.value; render(); });

  /* ── navigation ──────────────────────────────────────────────────── */
  document.getElementById('btn-prev').addEventListener('click', () => {
    if (--month < 0) { month = 11; year--; } render();
  });
  document.getElementById('btn-next').addEventListener('click', () => {
    if (++month > 11) { month = 0; year++; } render();
  });
  document.getElementById('btn-today').addEventListener('click', () => {
    year = new Date().getFullYear(); month = new Date().getMonth(); render();
  });

  /* ── fermeture modal ─────────────────────────────────────────────── */
  const ov = document.getElementById('modal-overlay');
  ov.addEventListener('click', e => { if (e.target === ov) closeModal(); });
  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  /* ── sync ────────────────────────────────────────────────────────── */
  document.getElementById('btn-sync').addEventListener('click', async () => {
    const btn = document.getElementById('btn-sync');
    btn.disabled = true; btn.innerHTML = '<span class="spin"></span> Sync…';
    try {
      const res  = await fetch('/api/sync-calendar');
      const data = await res.json();
      toast(data.success ? `✅ ${data.synced} créneau(x) importé(s).` : `❌ ${data.error}`,
            data.success ? 'ok' : 'err');
      if (data.success) setTimeout(() => location.reload(), 2500);
    } catch { toast('❌ Erreur réseau', 'err'); }
    btn.disabled = false; btn.textContent = '↻ Sync Getaround';
  });

  /* ── formulaire de blocage ───────────────────────────────────────── */

  // Préserve le fuseau horaire local (évite décalage UTC +2h en France)
  function localToISO(val) {
    if (!val) return '';
    const off = -(new Date().getTimezoneOffset()); // minutes (ex: +120 pour UTC+2)
    const sgn = off >= 0 ? '+' : '-';
    const hh  = String(Math.floor(Math.abs(off) / 60)).padStart(2, '0');
    const mm  = String(Math.abs(off) % 60).padStart(2, '0');
    return val + ':00' + sgn + hh + ':' + mm; // "2026-05-20T10:00:00+02:00"
  }

  document.getElementById('form-block').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type=submit]');
    btn.disabled = true; btn.innerHTML = '<span class="spin"></span> En cours…';
    try {
      const res = await fetch('/api/admin/block-dates', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({
          vehicule_id: document.getElementById('sel-v').value,
          date_debut:  localToISO(document.getElementById('inp-debut').value),
          date_fin:    localToISO(document.getElementById('inp-fin').value),
          note:        document.getElementById('inp-note').value,
        }),
      });
      const data = await res.json();
      if (data.success) {
        toast('✅ Créneau bloqué' + (data.getaround_blocked ? ' — sync Getaround OK' : '') + '.', 'ok');
        setTimeout(() => location.reload(), 2000);
      } else {
        toast('❌ ' + (data.error || 'Erreur'), 'err');
        btn.disabled = false; btn.textContent = 'Bloquer ce créneau';
      }
    } catch {
      toast('❌ Erreur réseau', 'err');
      btn.disabled = false; btn.textContent = 'Bloquer ce créneau';
    }
  });

  function toast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg; t.className = 'toast show ' + type;
    setTimeout(() => t.classList.remove('show'), 4000);
  }

  render();
})();
});
</script>

<div class="page">

  <!-- Topbar -->
  <div class="topbar">
    <a href="/admin" class="back">← Tableau de bord</a>
    <div class="topbar-r">
      <select id="filter-v" class="sel"><option value="">Tous les véhicules</option></select>
      <button id="btn-sync" class="btn-teal">↻ Sync Getaround</button>
      <a href="/api/admin/webhook-events" target="_blank" class="btn-ghost">Logs</a>
    </div>
  </div>

  <!-- Calendrier -->
  <div class="cal-card">

    <!-- Nav -->
    <div class="cal-nav">
      <button id="btn-prev" class="nav-btn">&#8249;</button>
      <h2 id="cal-title" class="cal-month">—</h2>
      <button id="btn-next" class="nav-btn">&#8250;</button>
      <button id="btn-today" class="btn-today-sm">Aujourd'hui</button>
      <div class="cal-legend">
        <span class="leg"><i style="background:#16a34a"></i>Payée</span>
        <span class="leg"><i style="background:#1d4ed8"></i>Confirmée</span>
        <span class="leg"><i style="background:#b45309"></i>En attente</span>
        <span class="leg"><i style="background:#4c1d95"></i>Getaround</span>
        <span class="leg"><i style="background:#374151"></i>Bloqué</span>
      </div>
    </div>

    <!-- En-têtes jours -->
    <div class="cal-dow">
      <div>Lun</div><div>Mar</div><div>Mer</div>
      <div>Jeu</div><div>Ven</div>
      <div class="wk">Sam</div><div class="wk">Dim</div>
    </div>

    <!-- Grille -->
    <div class="cal-grid" id="cal-grid"></div>

  </div>

  <!-- Formulaire blocage -->
  <details class="block-panel">
    <summary>+ Bloquer un créneau manuellement</summary>
    <div class="block-inner">
      <p class="block-note">Ce créneau sera bloqué ici ET synchronisé sur Getaround.</p>
      <form id="form-block" class="block-form">
        <div class="fg"><label>Véhicule</label>
          <select id="sel-v" required><option value="">Choisir…</option></select></div>
        <div class="fg"><label>Début</label>
          <input type="datetime-local" id="inp-debut" required /></div>
        <div class="fg"><label>Fin</label>
          <input type="datetime-local" id="inp-fin" required /></div>
        <div class="fg"><label>Motif <small>(opt.)</small></label>
          <input type="text" id="inp-note" placeholder="Révision…" /></div>
        <div class="fg fg-btn">
          <button type="submit" class="btn-gold">Bloquer ce créneau</button>
        </div>
      </form>
    </div>
  </details>

</div>

<!-- Modal -->
<div id="modal-overlay" class="modal-overlay" style="display:none">
  <div class="modal-box">
    <button id="modal-close" class="modal-close">✕</button>
    <div id="modal-body"></div>
  </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>
</MainLayout>

<style is:global>
*, *::before, *::after { box-sizing: border-box; }

.page {
  max-width: 1100px; margin: 0 auto;
  padding: 1.5rem 1.25rem 5rem;
  font-family: system-ui, -apple-system, sans-serif;
}

/* Topbar */
.topbar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.75rem; margin-bottom:1.5rem; }
.back   { font-size:.82rem; color:#6b7280; text-decoration:none; transition:color .12s; }
.back:hover { color:#4dd4c8; }
.topbar-r { display:flex; align-items:center; gap:.5rem; flex-wrap:wrap; }
.sel { background:#1a2b3c; border:1px solid #2a3d50; color:#cbd5e1; padding:0 12px; border-radius:8px; font-size:.83rem; cursor:pointer; color-scheme:dark; height:36px; }
.btn-teal { background:#4dd4c8; color:#0f1e33; border:none; padding:0 14px; border-radius:8px; font-weight:700; font-size:.83rem; cursor:pointer; height:36px; transition:opacity .15s; }
.btn-teal:hover { opacity:.85; } .btn-teal:disabled { opacity:.5; cursor:not-allowed; }
.btn-ghost { background:transparent; color:#94a3b8; border:1px solid #2a3d50; padding:0 12px; border-radius:8px; font-size:.8rem; cursor:pointer; height:36px; text-decoration:none; display:inline-flex; align-items:center; transition:border-color .12s, color .12s; }
.btn-ghost:hover { border-color:#4dd4c8; color:#4dd4c8; }

/* Calendrier */
.cal-card { background:#fff; border-radius:16px; overflow:hidden; margin-bottom:1.5rem; box-shadow:0 4px 24px rgba(0,0,0,.22); }

.cal-nav { display:flex; align-items:center; gap:.5rem; padding:.9rem 1.25rem .7rem; border-bottom:1px solid #f0f0f0; flex-wrap:wrap; }
.cal-month { font-size:1.2rem; font-weight:800; color:#111827; margin:0 .4rem; min-width:170px; }
.nav-btn { background:#f3f4f6; border:none; color:#374151; width:32px; height:32px; border-radius:8px; font-size:1.3rem; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background .12s; }
.nav-btn:hover { background:#e5e7eb; }
.btn-today-sm { background:transparent; border:1px solid #d1d5db; color:#374151; padding:0 12px; height:30px; border-radius:7px; font-size:.78rem; cursor:pointer; }
.btn-today-sm:hover { border-color:#374151; }

.cal-legend { display:flex; flex-wrap:wrap; gap:.25rem .9rem; margin-left:auto; }
.leg { display:flex; align-items:center; gap:5px; font-size:.7rem; color:#6b7280; }
.leg i { display:inline-block; width:10px; height:10px; border-radius:3px; flex-shrink:0; }

.cal-dow { display:grid; grid-template-columns:repeat(7,1fr); background:#f9fafb; border-bottom:1px solid #f0f0f0; }
.cal-dow div { padding:8px 0; text-align:center; font-size:.68rem; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; }
.cal-dow .wk { color:#6b7280; }

.cal-grid { display:grid; grid-template-columns:repeat(7,1fr); background:#fff; }

/* Cases */
.dc { min-height:76px; border-right:1px solid #f0f0f0; border-bottom:1px solid #f0f0f0; padding:6px 7px 5px; display:flex; flex-direction:column; gap:2px; }
.dc:nth-child(7n) { border-right:none; }
.dc-empty { background:#fafafa !important; }
.dc-today { box-shadow:inset 0 0 0 2px #4dd4c8; }
.dc-free { background:#f8fafd; }
.dc-weekend { background:#fff8ed; }
.dc-free:hover, .dc-weekend:hover { filter:brightness(.97); }
.dc-resa:hover, .dc-blocked:hover { filter:brightness(1.08); }

.dc-num { font-size:12px; font-weight:700; color:#374151; width:24px; height:24px; display:flex; align-items:center; justify-content:center; border-radius:50%; flex-shrink:0; }
.dc-num-today { background:#4dd4c8; color:#fff; font-weight:800; }
.dc-num-inv { color:rgba(255,255,255,.9); }

.dc-price { font-size:13px; font-weight:800; color:#111827; margin-top:auto; text-align:center; width:100%; }
.dc-weekend .dc-price { color:#92400e; }

.dc-tag { font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:.05em; color:rgba(255,255,255,.85); background:rgba(0,0,0,.18); border-radius:4px; padding:2px 5px; align-self:flex-start; }
.dc-client { font-size:10px; font-weight:600; color:rgba(255,255,255,.9); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin-top:auto; width:100%; }

/* Formulaire de blocage */
.block-panel { background:#1a2b3c; border:1px solid #2a3d50; border-radius:14px; overflow:hidden; }
.block-panel > summary { padding:.9rem 1.25rem; font-size:.87rem; font-weight:600; color:#94a3b8; cursor:pointer; list-style:none; user-select:none; transition:color .12s; }
.block-panel > summary::-webkit-details-marker { display:none; }
.block-panel > summary:hover { color:#cbd5e1; }
