---
// src/pages/admin/calendrier.astro
// Interface de gestion des créneaux bloqués (manuel + Getaround)
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const cookies = Astro.request.headers.get('cookie') || '';
const isAuthenticated = cookies.includes('admin_auth=true');

if (!isAuthenticated) {
  return Astro.redirect('/admin');
}

const { data: vehicules } = await supabaseAdmin
  .from('vehicules')
  .select('id, nom, getaround_id')
  .order('nom');

const { data: reservations } = await supabaseAdmin
  .from('reservations')
  .select('id, vehicule_id, date_debut, date_fin, statut, email_client, locataire_nom, vehicules(nom)')
  .in('statut', ['paye', 'confirmee', 'en_attente_paiement'])
  .order('date_debut', { ascending: true });

const { data: indisponibilites } = await supabaseAdmin
  .from('indisponibilites')
  .select('id, vehicule_id, date_debut, date_fin, source, note, getaround_rental_id, vehicules(nom)')
  .order('date_debut', { ascending: true });

function fmt(d: string) {
  if (!d) return '—';
  return new Date(d).toLocaleString('fr-FR', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}
---

<MainLayout title="Gestion du calendrier — Admin Ship Cars">
  <div class="admin-container">
    <header class="admin-header">
      <div class="header-row">
        <div>
          <a href="/admin" class="back-link">← Tableau de bord</a>
          <h1>📅 Gestion du calendrier</h1>
          <p class="subtitle">Synchronisez avec Getaround, bloquez des créneaux manuellement ou annulez des réservations.</p>
        </div>
        <button id="btn-sync" class="btn-sync">🔄 Synchroniser Getaround</button>
      </div>
      <div id="sync-result" class="sync-result" style="display:none;"></div>
    </header>

    <!-- BLOCAGE MANUEL -->
    <section class="admin-card">
      <h2>🚫 Bloquer un créneau manuellement</h2>
      <p class="card-sub">Le créneau sera bloqué sur ce site ET sur Getaround simultanément.</p>

      <form id="form-block" class="block-form">
        <div class="form-row">
          <div class="form-group">
            <label for="sel-vehicule">Véhicule</label>
            <select id="sel-vehicule" required>
              <option value="">Choisir un véhicule...</option>
              {vehicules?.map((v) => (
                <option value={v.id}>{v.nom}{v.getaround_id ? ' ✓ GA' : ''}</option>
              ))}
            </select>
          </div>
          <div class="form-group">
            <label for="inp-debut">Début du blocage</label>
            <input type="datetime-local" id="inp-debut" required />
          </div>
          <div class="form-group">
            <label for="inp-fin">Fin du blocage</label>
            <input type="datetime-local" id="inp-fin" required />
          </div>
          <div class="form-group">
            <label for="inp-note">Motif (optionnel)</label>
            <input type="text" id="inp-note" placeholder="Ex: Révision, Privatisation..." />
          </div>
        </div>
        <div id="block-error" class="error-msg" style="display:none;"></div>
        <button type="submit" class="btn-block">Bloquer ce créneau</button>
      </form>
    </section>

    <!-- BLOCAGES ACTIFS (indisponibilites) -->
    <section class="admin-card">
      <h2>🔒 Créneaux bloqués ({indisponibilites?.length || 0})</h2>
      <p class="card-sub">Inclut les blocages manuels et les locations importées de Getaround.</p>

      {indisponibilites && indisponibilites.length > 0 ? (
        <div class="table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Véhicule</th>
                <th>Source</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Note</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              {indisponibilites.map((item) => (
                <tr data-id={item.id}>
                  <td><strong>{(item.vehicules as any)?.nom ?? '—'}</strong></td>
                  <td>
                    <span class={`badge badge-${item.source}`}>
                      {item.source === 'getaround' ? '🔗 Getaround' : '✋ Manuel'}
                    </span>
                  </td>
                  <td>{fmt(item.date_debut)}</td>
                  <td>{fmt(item.date_fin)}</td>
                  <td class="note-cell">{item.note || '—'}</td>
                  <td>
                    <button
                      class="btn-unblock"
                      data-id={item.id}
                      title="Supprimer ce blocage"
                    >
                      🗑️ Débloquer
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="empty">Aucun créneau bloqué.</p>
      )}
    </section>

    <!-- RÉSERVATIONS ACTIVES -->
    <section class="admin-card">
      <h2>📋 Réservations actives ({reservations?.length || 0})</h2>
      <p class="card-sub">Annuler une réservation la supprime du calendrier du site ET de Getaround.</p>

      {reservations && reservations.length > 0 ? (
        <div class="table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Véhicule</th>
                <th>Client</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Statut</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              {reservations.map((res) => (
                <tr data-id={res.id}>
                  <td><strong>{(res.vehicules as any)?.nom ?? '—'}</strong></td>
                  <td>{res.locataire_nom || res.email_client || '—'}</td>
                  <td>{fmt(res.date_debut)}</td>
                  <td>{fmt(res.date_fin)}</td>
                  <td>
                    <span class={`badge badge-${res.statut}`}>{res.statut}</span>
                  </td>
                  <td>
                    <button
                      class="btn-cancel"
                      data-id={res.id}
                      title="Annuler cette réservation"
                    >
                      ❌ Annuler
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="empty">Aucune réservation active.</p>
      )}
    </section>
  </div>
</MainLayout>

<script is:inline>
  // ── Synchronisation Getaround ──────────────────────────────────────────────
  document.getElementById('btn-sync').addEventListener('click', async () => {
    const btn = document.getElementById('btn-sync');
    const resultEl = document.getElementById('sync-result');
    btn.disabled = true;
    btn.textContent = '⏳ Synchronisation...';
    resultEl.style.display = 'none';

    try {
      const res = await fetch('/api/sync-calendar');
      const data = await res.json();
      resultEl.style.display = 'block';
      if (data.success) {
        resultEl.className = 'sync-result success';
        const detailStr = data.detail
          ? Object.entries(data.detail).map(([nom, n]) => `${nom}: ${n}`).join(', ')
          : '';
        resultEl.textContent = `✅ ${data.synced} créneau(x) importé(s) depuis Getaround${detailStr ? ' — ' + detailStr : ''}.`;
        setTimeout(() => location.reload(), 2000);
      } else {
        resultEl.className = 'sync-result error';
        resultEl.textContent = `❌ Erreur : ${data.error}`;
      }
    } catch (e) {
      resultEl.style.display = 'block';
      resultEl.className = 'sync-result error';
      resultEl.textContent = '❌ Erreur réseau';
    } finally {
      btn.disabled = false;
      btn.textContent = '🔄 Synchroniser Getaround';
    }
  });

  // ── Blocage manuel ─────────────────────────────────────────────────────────
  document.getElementById('form-block').addEventListener('submit', async (e) => {
    e.preventDefault();
    const errEl = document.getElementById('block-error');
    errEl.style.display = 'none';

    const vehicule_id = document.getElementById('sel-vehicule').value;
    const date_debut  = new Date(document.getElementById('inp-debut').value).toISOString();
    const date_fin    = new Date(document.getElementById('inp-fin').value).toISOString();
    const note        = document.getElementById('inp-note').value;

    const submitBtn = e.target.querySelector('button[type=submit]');
    submitBtn.disabled = true;
    submitBtn.textContent = '⏳ Blocage en cours...';

    try {
      const res = await fetch('/api/admin/block-dates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ vehicule_id, date_debut, date_fin, note }),
      });
      const data = await res.json();
      if (data.success) {
        const gaStatus = data.getaround_blocked
          ? '✅ Synchronisé sur Getaround'
          : '⚠️ Non synchronisé sur Getaround (vérifiez la clé API ou l\'ID voiture)';
        errEl.style.display = 'block';
        errEl.style.color = data.getaround_blocked ? '#4ade80' : '#fbbf24';
        errEl.textContent = `✅ Créneau bloqué sur le site — ${gaStatus}`;
        setTimeout(() => location.reload(), 2500);
      } else {
        errEl.textContent = data.error || 'Erreur inconnue';
        errEl.style.display = 'block';
      }
    } catch {
      errEl.textContent = 'Erreur réseau';
      errEl.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Bloquer ce créneau';
    }
  });

  // ── Déblocage ──────────────────────────────────────────────────────────────
  document.querySelectorAll('.btn-unblock').forEach((btn) => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer ce blocage ? Cette action sera répercutée sur Getaround.')) return;
      const id = btn.dataset.id;
      btn.disabled = true;
      btn.textContent = '⏳...';

      const res = await fetch('/api/admin/block-dates', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ indisponibilite_id: id }),
      });
      const data = await res.json();
      if (data.success) {
        btn.closest('tr').remove();
      } else {
        alert('Erreur : ' + (data.error || 'Inconnu'));
        btn.disabled = false;
        btn.textContent = '🗑️ Débloquer';
      }
    });
  });

  // ── Annulation réservation ────────────────────────────────────────────────
  document.querySelectorAll('.btn-cancel').forEach((btn) => {
    btn.addEventListener('click', async () => {
      if (!confirm('Annuler cette réservation ? Le créneau sera libéré sur Getaround.')) return;
      const id = btn.dataset.id;
      btn.disabled = true;
      btn.textContent = '⏳...';

      const res = await fetch('/api/reservations/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reservation_id: id }),
      });
      const data = await res.json();
      if (data.success) {
        btn.closest('tr').remove();
      } else {
        alert('Erreur : ' + (data.error || 'Inconnu'));
        btn.disabled = false;
        btn.textContent = '❌ Annuler';
      }
    });
  });
</script>

<style>
  .admin-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .admin-header { margin-bottom: 2rem; }

  .header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .back-link {
    font-size: 0.82rem;
    color: #6b7280;
    text-decoration: none;
    display: block;
    margin-bottom: 0.4rem;
  }
  .back-link:hover { color: #4dd4c8; }

  h1 {
    font-size: 1.6rem;
    font-weight: 800;
    color: #f0f4f8;
    margin: 0 0 0.3rem;
  }

  .subtitle {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0;
  }

  .btn-sync {
    background: #4dd4c8;
    color: #0f1e33;
    border: none;
    padding: 0.7rem 1.4rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }
  .btn-sync:disabled { opacity: 0.6; cursor: not-allowed; }

  .sync-result {
    margin-top: 0.8rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.88rem;
  }
  .sync-result.success { background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
  .sync-result.error   { background: rgba(239,68,68,0.1);  color: #f87171; border: 1px solid rgba(239,68,68,0.3); }

  .admin-card {
    background: #1a2b3c;
    border: 1px solid #2a3d50;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .admin-card h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #f0f4f8;
    margin: 0 0 0.4rem;
  }

  .card-sub {
    font-size: 0.8rem;
    color: #6b7280;
    margin: 0 0 1.25rem;
  }

  .block-form .form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .form-group { display: flex; flex-direction: column; gap: 5px; }

  .form-group label {
    font-size: 0.74rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-group select,
  .form-group input {
    background: #0f1e33;
    border: 1px solid #2a3d50;
    color: #e2e8f0;
    padding: 9px 12px;
    border-radius: 7px;
    font-size: 0.88rem;
    color-scheme: dark;
  }
  .form-group select:focus,
  .form-group input:focus {
    outline: none;
    border-color: #4dd4c8;
  }

  .error-msg {
    font-size: 0.83rem;
    margin-bottom: 0.75rem;
  }

  .btn-block {
    background: #c9a84c;
    color: #000;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-block:disabled { opacity: 0.6; cursor: not-allowed; }

  .table-wrap { overflow-x: auto; }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .admin-table th {
    text-align: left;
    padding: 8px 12px;
    color: #9ca3af;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    border-bottom: 1px solid #2a3d50;
  }

  .admin-table td {
    padding: 10px 12px;
    color: #cbd5e1;
    border-bottom: 1px solid #1e2d3d;
    vertical-align: middle;
  }

  .admin-table tr:last-child td { border-bottom: none; }

  .note-cell {
    color: #6b7280;
    font-size: 0.8rem;
    max-width: 200px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 99px;
    font-size: 0.74rem;
    font-weight: 600;
  }
  .badge-getaround { background: rgba(59,130,246,0.15); color: #60a5fa; }
  .badge-manual    { background: rgba(234,179,8,0.15);  color: #fbbf24; }
  .badge-paye      { background: rgba(34,197,94,0.15);  color: #4ade80; }
  .badge-confirmee { background: rgba(59,130,246,0.15); color: #60a5fa; }
  .badge-en_attente_paiement { background: rgba(234,179,8,0.15); color: #fbbf24; }

  .btn-unblock,
  .btn-cancel {
    background: transparent;
    border: 1px solid #4a3a3a;
    color: #f87171;
    padding: 5px 12px;
    border-radius: 6px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .btn-unblock:hover,
  .btn-cancel:hover { background: rgba(239,68,68,0.1); }
  .btn-unblock:disabled,
  .btn-cancel:disabled { opacity: 0.5; cursor: not-allowed; }

  .empty {
    color: #4b5563;
    font-size: 0.85rem;
    font-style: italic;
    padding: 0.5rem 0;
  }

  @media (max-width: 600px) {
    .block-form .form-row { grid-template-columns: 1fr; }
  }
</style>
