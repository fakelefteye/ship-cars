---
// src/pages/admin/index.astro
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

// Vérification du mot de passe
const url = new URL(Astro.request.url);
const password = url.searchParams.get('password');
const adminPassword = import.meta.env.ADMIN_PASSWORD;

// Vérifier si l'utilisateur est authentifié via cookie ou paramètre
const cookies = Astro.request.headers.get('cookie') || '';
const isAuthenticated = cookies.includes('admin_auth=true') || password === adminPassword;

if (!isAuthenticated) {
  // Afficher le formulaire de connexion
  const error = url.searchParams.get('error');
  const html = `
    <!DOCTYPE html>
    <html lang="fr">
    <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Administration - Ship Cars</title>
      <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; margin: 0; padding: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .login-container { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); max-width: 400px; width: 100%; margin: 1rem; }
        .login-title { text-align: center; margin-bottom: 2rem; color: #333; }
        .form-group { margin-bottom: 1.5rem; }
        label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: #555; }
        input { width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px; font-size: 1rem; }
        .btn-submit { width: 100%; background: #2ecc71; color: white; border: none; padding: 0.75rem; border-radius: 6px; font-size: 1rem; cursor: pointer; }
        .btn-submit:hover { background: #27ae60; }
        .error { background: #f8d7da; color: #721c24; padding: 0.75rem; border-radius: 6px; margin-bottom: 1rem; border: 1px solid #f5c6cb; }
      </style>
    </head>
    <body>
      <div class="login-container">
        <h1 class="login-title">🔐 Accès Administration</h1>
        ${error ? '<div class="error">Mot de passe incorrect</div>' : ''}
        <form method="GET">
          <div class="form-group">
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" required />
          </div>
          <button type="submit" class="btn-submit">Se connecter</button>
        </form>
      </div>
    </body>
    </html>
  `;
  return new Response(html, { status: 200, headers: { 'Content-Type': 'text/html' } });
}

// Si authentifié, définir le cookie et continuer
Astro.cookies.set('admin_auth', 'true', {
  path: '/',
  httpOnly: true,
  maxAge: 86400,
});

// Récupération des données pour l'affichage
const { data: vehicules, error: vehiculesError } = await supabaseAdmin
  .from('vehicules')
  .select('*')
  .order('nom');

const { data: accessoires, error: accessoiresError } = await supabaseAdmin
  .from('options_location')
  .select('*')
  .order('nom');

// On récupère le paramètre "success" dans l'URL pour afficher une notification
const success = url.searchParams.get('success');
const deleted = url.searchParams.get('deleted');
const updated = url.searchParams.get('updated');
---

<MainLayout title="Administration - Ship Cars">
  <div class="admin-container">
    <header class="admin-header">
      <h1>Tableau de bord</h1>
      {success && <p class="success-msg">✅ L'élément a été ajouté avec succès !</p>}
      {deleted && <p class="success-msg">✅ L'élément a été supprimé avec succès !</p>}
      {updated && <p class="success-msg">✅ L'élément a été modifié avec succès !</p>}
    </header>
    
    <!-- LISTE DES VÉHICULES -->
    <section class="admin-card">
      <h2>🚗 Véhicules ({vehicules?.length || 0})</h2>
      <div class="items-list">
        {vehicules?.map((vehicule) => (
          <div class="item-row">
            <div class="item-info">
              <strong>{vehicule.nom}</strong>
              {vehicule.modele && <span> - {vehicule.modele}</span>}
              {vehicule.annee && <span> ({vehicule.annee})</span>}
              <span class="price">{vehicule.prix_journalier_base}€/jour</span>
            </div>
            <div class="item-actions">
              <button class="btn-edit" data-type="vehicule" data-id={vehicule.id}>✏️ Modifier</button>
              <button class="btn-delete" data-type="vehicule" data-id={vehicule.id}>🗑️ Supprimer</button>
            </div>
          </div>
        ))}
        {(!vehicules || vehicules.length === 0) && (
          <p class="empty">Aucun véhicule enregistré.</p>
        )}
      </div>
    </section>

    <!-- GESTION DES SIÈGES AUTO -->
    <section class="admin-card">
      <h2>🪑 Gestion des sièges auto</h2>
      <p class="subtitle">Ajustez le stock et le prix des sièges auto disponibles.</p>

      <div class="sieges-grid">
        {accessoires?.filter(acc => acc.nom.toLowerCase().includes('siège') || acc.nom.toLowerCase().includes('siege')).map((siege) => (
          <div class="siege-item">
            <div class="siege-info">
              <strong>{siege.nom}</strong>
              <span class="current-stock">Stock actuel: {siege.stock_total} · Prix: {siege.prix_fixe}€</span>
            </div>
            <div class="siege-controls-grid">
              <div class="siege-field">
                <label class="siege-label">Stock</label>
                <div class="siege-controls">
                  <button class="btn-stock" data-id={siege.id} data-action="decrement">-1</button>
                  <input type="number" class="stock-input" id={`stock-${siege.id}`} value={siege.stock_total} min="0" data-id={siege.id}>
                  <button class="btn-stock" data-id={siege.id} data-action="increment">+1</button>
                </div>
              </div>
              <div class="siege-field">
                <label class="siege-label">Prix (€)</label>
                <input type="number" class="price-input" id={`price-${siege.id}`} value={siege.prix_fixe} min="0" step="0.01" data-id={siege.id}>
              </div>
            </div>
          </div>
        ))}
        {(!accessoires || accessoires.filter(acc => acc.nom.toLowerCase().includes('siège') || acc.nom.toLowerCase().includes('siege')).length === 0) && (
          <p class="empty">Aucun siège auto trouvé. Créez d'abord des accessoires "siège auto".</p>
        )}
      </div>
    </section>
    
    <!-- FORMULAIRE AJOUT -->
    <section class="admin-card">
      <h2>Ajouter un véhicule ou un accessoire</h2>
      <p class="subtitle">Remplissez les informations ci-dessous pour mettre à jour votre catalogue.</p>

      <form id="add-item-form" action="/api/admin/add-item" method="POST" enctype="multipart/form-data" class="admin-form">
        <div class="form-group">
          <label for="type-selector">Type d'élément</label>
          <select name="type" id="type-selector" required>
            <option value="vehicule">🚗 Véhicule</option>
            <option value="accessoire">🧸 Accessoire (Siège, GPS...)</option>
          </select>
        </div>

        <div class="form-group">
          <label for="nom">Nom de l'article</label>
          <input type="text" id="nom" name="nom" placeholder="Ex: Renault Clio 4" required />
        </div>

        <div id="vehicule-fields">
          <div class="form-row">
            <div class="form-group">
              <label for="modele">Modèle / Phase</label>
              <input type="text" id="modele" name="modele" placeholder="Ex: Phase 2" />
            </div>
            <div class="form-group">
              <label for="annee">Année</label>
              <input type="number" id="annee" name="annee" placeholder="2024" />
            </div>
          </div>          
          <div class="form-group">
            <label for="prix">Prix journalier</label>
            <input type="number" step="0.01" id="prix" name="prix" placeholder="0.00" required />
          </div>

          <div class="form-group" id="images-container">
            <label>Photos du véhicule</label>

            <!-- Photo principale -->
            <div class="image-upload-slot">
              <div class="upload-row">
                <label class="btn-upload-file" for="file_main">📁 Choisir un fichier</label>
                <input type="file" id="file_main" class="hidden-file-input" accept="image/jpeg,image/png,image/webp,image/gif" data-target="image_url" data-preview="preview_main" data-status="status_main">
                <input type="text" name="image_url" id="image_url" class="url-input" data-preview="preview_main" placeholder="ou coller une URL (.jpg, .png…)" required />
              </div>
              <div class="upload-feedback">
                <span class="upload-status" id="status_main"></span>
                <div class="image-preview" id="preview_main"></div>
              </div>
            </div>

            <!-- Photos supplémentaires -->
            <div class="additional-photos">
              <div class="image-upload-slot">
                <div class="upload-row">
                  <label class="btn-upload-file" for="file_2">📁</label>
                  <input type="file" id="file_2" class="hidden-file-input" accept="image/jpeg,image/png,image/webp,image/gif" data-target="image_url_2" data-preview="preview_2" data-status="status_2">
                  <input type="text" name="image_url_2" id="image_url_2" class="url-input" data-preview="preview_2" placeholder="Photo 2 (Optionnelle)" />
                </div>
                <div class="upload-feedback">
                  <span class="upload-status" id="status_2"></span>
                  <div class="image-preview" id="preview_2"></div>
                </div>
              </div>
              <div class="image-upload-slot">
                <div class="upload-row">
                  <label class="btn-upload-file" for="file_3">📁</label>
                  <input type="file" id="file_3" class="hidden-file-input" accept="image/jpeg,image/png,image/webp,image/gif" data-target="image_url_3" data-preview="preview_3" data-status="status_3">
                  <input type="text" name="image_url_3" id="image_url_3" class="url-input" data-preview="preview_3" placeholder="Photo 3 (Optionnelle)" />
                </div>
                <div class="upload-feedback">
                  <span class="upload-status" id="status_3"></span>
                  <div class="image-preview" id="preview_3"></div>
                </div>
              </div>
              <div class="image-upload-slot">
                <div class="upload-row">
                  <label class="btn-upload-file" for="file_4">📁</label>
                  <input type="file" id="file_4" class="hidden-file-input" accept="image/jpeg,image/png,image/webp,image/gif" data-target="image_url_4" data-preview="preview_4" data-status="status_4">
                  <input type="text" name="image_url_4" id="image_url_4" class="url-input" data-preview="preview_4" placeholder="Photo 4 (Optionnelle)" />
                </div>
                <div class="upload-feedback">
                  <span class="upload-status" id="status_4"></span>
                  <div class="image-preview" id="preview_4"></div>
                </div>
              </div>
              <div class="image-upload-slot">
                <div class="upload-row">
                  <label class="btn-upload-file" for="file_5">📁</label>
                  <input type="file" id="file_5" class="hidden-file-input" accept="image/jpeg,image/png,image/webp,image/gif" data-target="image_url_5" data-preview="preview_5" data-status="status_5">
                  <input type="text" name="image_url_5" id="image_url_5" class="url-input" data-preview="preview_5" placeholder="Photo 5 (Optionnelle)" />
                </div>
                <div class="upload-feedback">
                  <span class="upload-status" id="status_5"></span>
                  <div class="image-preview" id="preview_5"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div id="accessoire-fields" style="display:none;">
          <div class="form-row">
            <div class="form-group">
              <label for="prix-accessoire">Prix fixe</label>
              <input type="number" step="0.01" id="prix-accessoire" name="prix" placeholder="0.00" required />
            </div>
            <div class="form-group">
              <label for="stock">Stock disponible</label>
              <input type="number" id="stock" name="stock" placeholder="Ex: 3" />
            </div>
          </div>
        </div>

        <button type="submit" class="btn-submit">💾 Enregistrer l'élément</button>
      </form>
    </section>
  </div>

  <!-- MODAL POUR MODIFICATION -->
  <div id="edit-modal" class="modal" style="display:none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">Modifier l'élément</h3>
        <button class="modal-close" onclick="closeModal()">×</button>
      </div>
      <div id="modal-body">
        <!-- Le contenu sera chargé dynamiquement -->
      </div>
    </div>
  </div>
</MainLayout>

<script>
  // @ts-nocheck
  // Script JavaScript pour l'administration
  document.addEventListener('DOMContentLoaded', function() {
    // Gestion du sélecteur de type
    const typeSelector = document.getElementById('type-selector');
    const vehiculeFields = document.getElementById('vehicule-fields');
    const accessoireFields = document.getElementById('accessoire-fields');
    const additionalPhotos = document.querySelector('.additional-photos');

    const formTypeSelector = document.getElementById('type-selector');

    function setFieldGroupState(container, disabled) {
      if (!container) return;
      container.querySelectorAll('input, select, textarea').forEach((field) => {
        field.disabled = disabled;
      });
    }

    function updateFormTypeState(value) {
      if (value === 'accessoire') {
        if (vehiculeFields) {
          vehiculeFields.style.display = 'none';
          setFieldGroupState(vehiculeFields, true);
        }
        if (accessoireFields) {
          accessoireFields.style.display = 'block';
          setFieldGroupState(accessoireFields, false);
        }
        if (additionalPhotos) additionalPhotos.style.display = 'none';
      } else {
        if (vehiculeFields) {
          vehiculeFields.style.display = 'block';
          setFieldGroupState(vehiculeFields, false);
        }
        if (accessoireFields) {
          accessoireFields.style.display = 'none';
          setFieldGroupState(accessoireFields, true);
        }
        if (additionalPhotos) additionalPhotos.style.display = 'grid';
      }
    }

    if (formTypeSelector) {
      updateFormTypeState(formTypeSelector.value);
      formTypeSelector.addEventListener('change', function(e) {
        updateFormTypeState(e.target.value);
      });
    }

    // Attacher les event listeners aux boutons
    attachButtonListeners();
  });

  function attachButtonListeners() {
    // Gérer la soumission du formulaire d'ajout
    const addItemForm = document.getElementById('add-item-form');
    if (addItemForm) {
      addItemForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        await submitAddItemForm();
      });
    }

    // Boutons de modification
    document.querySelectorAll('.btn-edit').forEach(function(button) {
      button.addEventListener('click', function() {
        const type = this.getAttribute('data-type');
        const id = this.getAttribute('data-id');
        if (type === 'vehicule') {
          editVehicule(id);
        } else if (type === 'accessoire') {
          editAccessoire(id);
        }
      });
    });

    // Boutons de suppression
    document.querySelectorAll('.btn-delete').forEach(function(button) {
      button.addEventListener('click', function() {
        const type = this.getAttribute('data-type');
        const id = this.getAttribute('data-id');
        deleteItem(type, id);
      });
    });

    // Contrôles de stock des sièges auto
    document.querySelectorAll('.btn-stock').forEach(function(button) {
      button.addEventListener('click', function() {
        const id = this.getAttribute('data-id');
        const action = this.getAttribute('data-action');
        const input = document.querySelector(`.stock-input[data-id="${id}"]`);
        if (!input) return;
        const currentValue = parseInt(input.value) || 0;
        const newValue = action === 'increment' ? currentValue + 1 : Math.max(0, currentValue - 1);
        input.value = newValue;
        updateStock(id, newValue);
      });
    });

    document.querySelectorAll('.stock-input').forEach(function(input) {
      input.addEventListener('change', function() {
        const id = this.getAttribute('data-id');
        updateStock(id, parseInt(this.value) || 0);
      });
    });

    // Contrôle du prix des sièges auto
    document.querySelectorAll('.price-input').forEach(function(input) {
      input.addEventListener('change', function() {
        const id = this.getAttribute('data-id');
        const val = parseFloat(this.value);
        if (isNaN(val) || val < 0) {
          showNotification('Prix invalide', 'error');
          return;
        }
        updatePrice(id, val);
      });
    });

    // Aperçu quand on colle une URL
    document.querySelectorAll('.url-input').forEach(function(urlInput) {
      const refreshPreview = function() {
        const previewId = urlInput.getAttribute('data-preview');
        const previewEl = document.getElementById(previewId);
        if (!previewEl) return;
        const url = urlInput.value.trim();
        if (url) {
          previewEl.innerHTML = `<img src="${url}" alt="Aperçu" onerror="this.parentElement.innerHTML='<span style=&quot;color:#e74c3c;font-size:0.8rem;&quot;>❌ URL invalide</span>'">`;
        } else {
          previewEl.innerHTML = '';
        }
      };
      urlInput.addEventListener('input', refreshPreview);
      urlInput.addEventListener('paste', function() { setTimeout(refreshPreview, 10); });
    });

    // Upload de fichiers image
    document.querySelectorAll('.hidden-file-input').forEach(function(fileInput) {
      fileInput.addEventListener('change', async function() {
        const file = this.files && this.files[0];
        if (!file) return;

        const targetId = this.getAttribute('data-target');
        const previewId = this.getAttribute('data-preview');
        const statusId = this.getAttribute('data-status');

        const targetInput = document.getElementById(targetId);
        const previewEl = document.getElementById(previewId);
        const statusEl = document.getElementById(statusId);

        if (statusEl) { statusEl.textContent = '⏳ Upload en cours…'; statusEl.style.color = '#f39c12'; }

        const uploadData = new FormData();
        uploadData.append('file', file);

        try {
          const response = await fetch('/api/admin/upload-image', {
            method: 'POST',
            body: uploadData,
            credentials: 'include',
          });
          const result = await response.json();

          if (result.success) {
            if (targetInput) targetInput.value = result.url;
            if (previewEl) previewEl.innerHTML = `<img src="${result.url}" alt="Aperçu">`;
            if (statusEl) { statusEl.textContent = '✅ Uploadé'; statusEl.style.color = '#2ecc71'; }
          } else {
            if (statusEl) { statusEl.textContent = '❌ ' + result.error; statusEl.style.color = '#e74c3c'; }
          }
        } catch (err) {
          if (statusEl) { statusEl.textContent = '❌ Erreur réseau'; statusEl.style.color = '#e74c3c'; }
        }
      });
    });
  }

  function deleteItem(type, id) {
    if (confirm('Êtes-vous sûr de vouloir supprimer cet élément ?')) {
      fetch('/api/admin/delete-item', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: type, id: id })
      })
      .then(function(response) { return response.json(); })
      .then(function(data) {
        if (data.success) {
          window.location.href = '/admin?deleted=true';
        } else {
          alert('Erreur lors de la suppression: ' + data.error);
        }
      })
      .catch(function(error) {
        console.error('Erreur:', error);
        alert('Erreur lors de la suppression');
      });
    }
  }

  function editVehicule(id) {
    console.log('Editing vehicule:', id);
    fetch('/api/admin/get-item?type=vehicule&id=' + id)
      .then(function(response) { return response.json(); })
      .then(function(data) {
        console.log('Response data:', data);
        if (data.success) {
          openEditModal('vehicule', data.item);
        } else {
          alert('Erreur lors du chargement: ' + data.error);
        }
      })
      .catch(function(error) {
        console.error('Erreur:', error);
        alert('Erreur lors du chargement du véhicule');
      });
  }

  function editAccessoire(id) {
    console.log('Editing accessoire:', id);
    fetch('/api/admin/get-item?type=accessoire&id=' + id)
      .then(function(response) { return response.json(); })
      .then(function(data) {
        console.log('Response data:', data);
        if (data.success) {
          openEditModal('accessoire', data.item);
        } else {
          alert('Erreur lors du chargement: ' + data.error);
        }
      })
      .catch(function(error) {
        console.error('Erreur:', error);
        alert('Erreur lors du chargement de l\'accessoire');
      });
  }

  function openEditModal(type, item) {
    console.log('Opening modal for:', type, item);
    const modal = document.getElementById('edit-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalBody = document.getElementById('modal-body');

    if (!modal || !modalTitle || !modalBody) {
      console.error('Modal elements not found');
      return;
    }

    modalTitle.textContent = 'Modifier ' + (type === 'vehicule' ? 'le véhicule' : 'l\'accessoire');
    
    let formHtml = '';
    if (type === 'vehicule') {
      formHtml = `
        <form action="/api/admin/update-item" method="POST" enctype="application/x-www-form-urlencoded">
          <input type="hidden" name="type" value="vehicule">
          <input type="hidden" name="id" value="${item.id}">
          
          <div class="form-group">
            <label>Nom du véhicule</label>
            <input type="text" name="nom" value="${item.nom || ''}" required>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label>Modèle / Phase</label>
              <input type="text" name="modele" value="${item.modele || ''}">
            </div>
            <div class="form-group">
              <label>Année</label>
              <input type="number" name="annee" value="${item.annee || ''}">
            </div>
          </div>
          
          <div class="form-group">
            <label>Prix journalier</label>
            <input type="number" step="0.01" name="prix" value="${item.prix_journalier_base || ''}" required>
          </div>
          
          <div class="form-group">
            <label>Photo principale (URL)</label>
            <input type="text" name="image_url" value="${item.image_url || ''}" required>
          </div>
          
          <div class="additional-photos">
            <input type="text" name="image_url_2" placeholder="Photo 2" value="${item.image_url_2 || ''}">
            <input type="text" name="image_url_3" placeholder="Photo 3" value="${item.image_url_3 || ''}">
            <input type="text" name="image_url_4" placeholder="Photo 4" value="${item.image_url_4 || ''}">
            <input type="text" name="image_url_5" placeholder="Photo 5" value="${item.image_url_5 || ''}">
          </div>
          
          <button type="submit" class="btn-submit">💾 Mettre à jour</button>
        </form>
      `;
    } else {
      formHtml = `
        <form action="/api/admin/update-item" method="POST" enctype="application/x-www-form-urlencoded">
          <input type="hidden" name="type" value="accessoire">
          <input type="hidden" name="id" value="${item.id}">
          
          <div class="form-group">
            <label>Nom de l'accessoire</label>
            <input type="text" name="nom" value="${item.nom || ''}" required>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label>Prix fixe</label>
              <input type="number" step="0.01" name="prix" value="${item.prix_fixe || ''}" required>
            </div>
            <div class="form-group">
              <label>Stock disponible</label>
              <input type="number" name="stock" value="${item.stock_total || ''}" required>
            </div>
          </div>
          
          <button type="submit" class="btn-submit">💾 Mettre à jour</button>
        </form>
      `;
    }
    
    modalBody.innerHTML = formHtml;
    modal.style.display = 'flex';
  }

  function closeModal() {
    const modal = document.getElementById('edit-modal');
    if (modal) {
      modal.style.display = 'none';
    }
  }

  async function submitAddItemForm(event) {
    if (event && event.preventDefault) {
      event.preventDefault();
    }

    const form = document.getElementById('add-item-form');
    if (!form) return;

    try {
      const formData = new FormData(form);
      
      const response = await fetch('/api/admin/add-item', {
        method: 'POST',
        body: formData,
        credentials: 'include'
      });

      if (response.ok) {
        showNotification('✅ Élément ajouté avec succès !', 'success');
        form.reset();
        // Recharger la page après 1.5 secondes pour voir les changements
        setTimeout(() => {
          window.location.href = '/admin?success=true';
        }, 1500);
      } else {
        const errorData = await response.json().catch(() => ({}));
        const errorMsg = errorData.error || `Erreur HTTP ${response.status}`;
        showNotification('❌ Erreur : ' + errorMsg, 'error');
        console.error('Erreur API:', errorMsg);
      }
    } catch (error) {
      console.error('Erreur lors de la soumission:', error);
      showNotification('❌ Erreur lors de l\'enregistrement', 'error');
    }
  }

  // Gestion du stock des sièges auto
  function adjustStock(id, delta) {
    const input = document.getElementById(`stock-${id}`);
    const currentValue = parseInt(input.value) || 0;
    const newValue = Math.max(0, currentValue + delta);
    input.value = newValue;
    updateStock(id, newValue);
  }

  function refreshSiegeSummary(id) {
    const stockInput = document.getElementById(`stock-${id}`);
    const priceInput = document.getElementById(`price-${id}`);
    if (!stockInput) return;
    const siegeItem = stockInput.closest('.siege-item');
    if (!siegeItem) return;
    const summary = siegeItem.querySelector('.current-stock');
    if (!summary) return;
    const stock = parseInt(stockInput.value) || 0;
    const prix = priceInput ? parseFloat(priceInput.value) || 0 : 0;
    summary.textContent = `Stock actuel: ${stock} · Prix: ${prix}€`;
  }

  async function updateStock(id, newStock) {
    try {
      const response = await fetch('/api/admin/update-item', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          type: 'accessoire',
          id: id,
          stock_total: parseInt(newStock)
        })
      });

      if (response.ok) {
        refreshSiegeSummary(id);
        showNotification('Stock mis à jour avec succès !', 'success');
      } else {
        showNotification('Erreur lors de la mise à jour du stock.', 'error');
      }
    } catch (error) {
      console.error('Erreur:', error);
      showNotification('Erreur lors de la mise à jour du stock.', 'error');
    }
  }

  async function updatePrice(id, newPrice) {
    try {
      const response = await fetch('/api/admin/update-item', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          type: 'accessoire',
          id: id,
          prix: newPrice
        })
      });

      if (response.ok) {
        refreshSiegeSummary(id);
        showNotification('Prix mis à jour avec succès !', 'success');
      } else {
        showNotification('Erreur lors de la mise à jour du prix.', 'error');
      }
    } catch (error) {
      console.error('Erreur:', error);
      showNotification('Erreur lors de la mise à jour du prix.', 'error');
    }
  }

  function showNotification(message, type) {
    // Créer une notification temporaire
    const notification = document.createElement('div');
    notification.className = `notification ${type}`;
    notification.textContent = message;
    notification.style.cssText = `
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 1rem 1.5rem;
      border-radius: 6px;
      color: white;
      font-weight: bold;
      z-index: 1001;
      animation: slideIn 0.3s ease-out;
    `;
    
    if (type === 'success') {
      notification.style.backgroundColor = '#2ecc71';
    } else {
      notification.style.backgroundColor = '#e74c3c';
    }
    
    document.body.appendChild(notification);
    
    // Supprimer après 3 secondes
    setTimeout(() => {
      notification.style.animation = 'slideOut 0.3s ease-out';
      setTimeout(() => {
        document.body.removeChild(notification);
      }, 300);
    }, 3000);
  }
</script>

