---
// src/pages/admin/tarifs.astro — Calendrier tarifaire par véhicule
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const cookies = Astro.request.headers.get('cookie') || '';
if (!cookies.includes('admin_auth=true')) return Astro.redirect('/admin');

const { data: vehicules } = await supabaseAdmin
  .from('vehicules')
  .select('id, nom, prix_journalier_base, prix_basse, prix_moyenne, prix_haute, prix_tres_haute, getaround_id')
  .order('nom');

// Pré-sélection via URL param ?vehicule=UUID
const urlParam = Astro.url.searchParams.get('vehicule') ?? '';
---

<MainLayout title="Tarifs — Admin Ship Cars">
<div class="page">

  <header class="page-header">
    <a href="/admin" class="back-link">← Tableau de bord</a>
    <h1>💰 Tarifs &amp; calendrier</h1>
  </header>

  <!-- Barre sélection véhicule + zone + sync -->
  <div class="top-bar">
    <div class="vehicle-pick">
      <label class="bar-label">Véhicule</label>
      <select id="sel-vehicule">
        <option value="">Choisir un véhicule…</option>
        {vehicules?.map((v) => (
          <option
            value={v.id}
            data-base={v.prix_journalier_base ?? 0}
            data-basse={v.prix_basse ?? v.prix_journalier_base ?? 0}
            data-moyenne={v.prix_moyenne ?? 0}
            data-haute={v.prix_haute ?? 0}
            data-tres-haute={v.prix_tres_haute ?? 0}
            data-ga={v.getaround_id ?? ''}
            selected={v.id === urlParam}
          >
            {v.nom}{v.getaround_id ? ' 🔗' : ''}
          </option>
        ))}
      </select>
    </div>
    <div class="zone-pick">
      <label class="bar-label">Zone scolaire</label>
      <select id="sel-zone">
        <option value="A">Zone A</option>
        <option value="B" selected>Zone B</option>
        <option value="C">Zone C</option>
      </select>
    </div>
    <div id="sync-zone" style="display:none;">
      <button id="btn-sync" class="btn-sync">🔄 Sync Getaround</button>
      <span id="sync-status" class="sync-status"></span>
    </div>
  </div>

  <div id="no-vehicle" class="no-vehicle">
    <p>← Sélectionnez un véhicule pour gérer ses tarifs.</p>
  </div>

  <div id="main-content" style="display:none;">

    <!-- ── PRIX PAR SAISON ── -->
    <section class="season-section">
      <h2>Vos prix par jour</h2>
      <p class="season-sub">Fixez votre prix pour les 4 niveaux de demande. Ces prix s'appliquent automatiquement. Les tarifs personnalisés ont priorité.</p>
      <div class="season-cards">
        <div class="season-card faible">
          <div class="s-dot-bar faible"></div>
          <div class="s-head">
            <strong>Faible</strong>
          </div>
          <div class="s-price-row">
            <input type="number" id="inp-basse" min="0" step="1" placeholder="—" />
            <span>€ / jour</span>
          </div>
          <small>Jours de semaine en période scolaire</small>
        </div>
        <div class="season-card moyenne">
          <div class="s-dot-bar moyenne"></div>
          <div class="s-head">
            <strong>Moyenne</strong>
          </div>
          <div class="s-price-row">
            <input type="number" id="inp-moyenne" min="0" step="1" placeholder="—" />
            <span>€ / jour</span>
          </div>
          <small>Week-ends en période scolaire</small>
        </div>
        <div class="season-card forte">
          <div class="s-dot-bar forte"></div>
          <div class="s-head">
            <strong>Forte</strong>
          </div>
          <div class="s-price-row">
            <input type="number" id="inp-haute" min="0" step="1" placeholder="—" />
            <span>€ / jour</span>
          </div>
          <small>Vacances scolaires &amp; jours fériés</small>
        </div>
        <div class="season-card tres-forte">
          <div class="s-dot-bar tres-forte"></div>
          <div class="s-head">
            <strong>Très forte</strong>
          </div>
          <div class="s-price-row">
            <input type="number" id="inp-tres-haute" min="0" step="1" placeholder="—" />
            <span>€ / jour</span>
          </div>
          <small>Vacances d'été (juillet – août)</small>
        </div>
      </div>
      <div id="prix-msg" class="form-msg" style="display:none;"></div>
      <button id="btn-save-prix" class="btn-save-season">💾 Enregistrer les prix de saison</button>
    </section>

    <!-- ── LAYOUT : CALENDRIER + SIDEBAR ── -->
    <div class="layout">

      <!-- Calendrier -->
      <div class="cal-zone">
        <div class="cal-toolbar">
          <button id="btn-prev" class="btn-nav">&#8249;</button>
          <span id="cal-title" class="cal-title"></span>
          <button id="btn-next" class="btn-nav">&#8250;</button>
          <span id="hint-sel" class="hint-sel"></span>
        </div>
        <div id="calendar" class="calendar"></div>
        <div class="legend">
          <span class="leg"><span class="ldot faible"></span> Faible</span>
          <span class="leg"><span class="ldot moyenne"></span> Moyenne</span>
          <span class="leg"><span class="ldot forte"></span> Forte</span>
          <span class="leg"><span class="ldot tres-forte"></span> Très forte (été)</span>
          <span class="leg"><span class="ldot custom"></span> Personnalisé</span>
          <span class="leg"><span class="ldot ga"></span> Getaround</span>
          <span class="leg"><span class="ldot blocked"></span> Bloqué</span>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="sidebar">

        <!-- Panel modifier un tarif (jour ou plage) -->
        <section id="panel-edit" class="card" style="display:none;">
          <h2 id="panel-title">✏️ Modifier le tarif</h2>
          <p id="panel-range" class="range-label"></p>
          <div class="field">
            <label>Prix / jour (€)</label>
            <input type="number" id="t-prix" min="0" step="1" placeholder="Ex : 70" />
          </div>
          <div class="field">
            <label>Libellé <span class="opt">(optionnel)</span></label>
            <input type="text" id="t-label" placeholder="Ex : Été 2026" />
          </div>
          <div id="panel-err" class="err" style="display:none;"></div>
          <div class="btn-row">
            <button id="btn-save-tarif" class="btn-primary">Enregistrer</button>
            <button id="btn-cancel-edit" class="btn-ghost">Annuler</button>
          </div>
        </section>

        <!-- Règles de location -->
        <section class="card">
          <h2>⚙️ Règles de location</h2>
          <form id="form-regles">
            <div class="field">
              <label>Durée minimale</label>
              <div class="row-unit">
                <input type="number" id="r-min-h" min="1" value="24" />
                <select id="r-min-unit">
                  <option value="hours">heures</option>
                  <option value="days" selected>jours</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label>Durée maximale <span class="opt">(optionnel)</span></label>
              <div class="row-unit">
                <input type="number" id="r-max-j" min="1" placeholder="Illimité" />
                <span class="unit-txt">jours</span>
              </div>
            </div>
            <div class="field">
              <label>Préavis minimum</label>
              <select id="r-delai">
                <option value="0">Aucun</option>
                <option value="2">2 h</option>
                <option value="6">6 h</option>
                <option value="12">12 h</option>
                <option value="24">24 h</option>
                <option value="48">48 h</option>
                <option value="72">3 jours</option>
              </select>
            </div>
            <div class="field">
              <label>Horizon de réservation</label>
              <select id="r-plage">
                <option value="30">1 mois</option>
                <option value="60">2 mois</option>
                <option value="90" selected>3 mois</option>
                <option value="120">4 mois</option>
                <option value="180">6 mois</option>
                <option value="365">1 an</option>
              </select>
            </div>
            <div id="regles-msg" class="form-msg" style="display:none;"></div>
            <button type="submit" class="btn-primary">💾 Enregistrer</button>
          </form>
        </section>

        <!-- Tarifs personnalisés actifs -->
        <section class="card" id="tarifs-list-card" style="display:none;">
          <h2>📋 Tarifs personnalisés</h2>
          <div id="tarifs-list"></div>
        </section>

      </aside>
    </div>
  </div>
</div>
</MainLayout>

<script is:inline>
// ─────────────────────────────────────────────────────────────────────────────
// Vacances scolaires 2025-2027 par zone + jours fériés
// ─────────────────────────────────────────────────────────────────────────────
const VACANCES = {
  A:[{l:'Toussaint',d:'2025-10-18',f:'2025-11-03'},{l:'Noël',d:'2025-12-20',f:'2026-01-05'},
     {l:'Hiver',d:'2026-02-21',f:'2026-03-09'},{l:'Printemps',d:'2026-04-18',f:'2026-05-04'},
     {l:'Été',d:'2026-07-04',f:'2026-08-31'},{l:'Toussaint',d:'2026-10-17',f:'2026-11-02'},
     {l:'Noël',d:'2026-12-19',f:'2027-01-04'},{l:'Hiver',d:'2027-02-20',f:'2027-03-08'},
     {l:'Printemps',d:'2027-04-10',f:'2027-04-26'},{l:'Été',d:'2027-07-03',f:'2027-08-31'}],
  B:[{l:'Toussaint',d:'2025-10-18',f:'2025-11-03'},{l:'Noël',d:'2025-12-20',f:'2026-01-05'},
     {l:'Hiver',d:'2026-02-07',f:'2026-02-23'},{l:'Printemps',d:'2026-04-25',f:'2026-05-11'},
     {l:'Été',d:'2026-07-04',f:'2026-08-31'},{l:'Toussaint',d:'2026-10-17',f:'2026-11-02'},
     {l:'Noël',d:'2026-12-19',f:'2027-01-04'},{l:'Hiver',d:'2027-02-06',f:'2027-02-22'},
     {l:'Printemps',d:'2027-04-17',f:'2027-05-03'},{l:'Été',d:'2027-07-03',f:'2027-08-31'}],
  C:[{l:'Toussaint',d:'2025-10-18',f:'2025-11-03'},{l:'Noël',d:'2025-12-20',f:'2026-01-05'},
     {l:'Hiver',d:'2026-02-14',f:'2026-03-02'},{l:'Printemps',d:'2026-04-11',f:'2026-04-27'},
     {l:'Été',d:'2026-07-04',f:'2026-08-31'},{l:'Toussaint',d:'2026-10-17',f:'2026-11-02'},
     {l:'Noël',d:'2026-12-19',f:'2027-01-04'},{l:'Hiver',d:'2027-02-13',f:'2027-03-01'},
     {l:'Printemps',d:'2027-04-03',f:'2027-04-19'},{l:'Été',d:'2027-07-03',f:'2027-08-31'}],
};
const FERIES = new Set([
  '2026-01-01','2026-04-06','2026-05-01','2026-05-08','2026-05-14','2026-05-25',
  '2026-07-14','2026-08-15','2026-11-01','2026-11-11','2026-12-25',
  '2027-01-01','2027-04-05','2027-05-01','2027-05-08','2027-05-13','2027-05-24',
  '2027-07-14','2027-08-15','2027-11-01','2027-11-11','2027-12-25',
]);

const MONTH_NAMES = ['Janvier','Février','Mars','Avril','Mai','Juin',
                     'Juillet','Août','Septembre','Octobre','Novembre','Décembre'];

// ─────────────────────────────────────────────────────────────────────────────
// État global
// ─────────────────────────────────────────────────────────────────────────────
let vehiculeId   = '';
let zone         = 'B';
let year         = new Date().getFullYear();
let month        = new Date().getMonth();
let prixBasse    = 0, prixMoyenne = 0, prixHaute = 0, prixTresHaute = 0;
let tarifs       = [];
let blocages     = [];
let rangeStart   = null, rangeHover = null;
const TODAY      = new Date().toISOString().slice(0,10);

// ─────────────────────────────────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────────────────────────────────
const pad = n => String(n).padStart(2,'0');

function getVacance(d) { return VACANCES[zone].find(v => d >= v.d && d <= v.f) ?? null; }

function getDayTier(d) {
  const vac = getVacance(d);
  if (vac?.l === 'Été') return 'tres_haute';
  if (vac || FERIES.has(d)) return 'haute';
  const dow = new Date(d + 'T12:00:00').getDay();
  return (dow === 0 || dow === 6) ? 'moyenne' : 'basse';
}

function getTarifOverride(d) {
  const matches = tarifs.filter(t => t.date_debut <= d && t.date_fin >= d);
  matches.sort((a,b) => {
    const la = new Date(a.date_fin) - new Date(a.date_debut);
    const lb = new Date(b.date_fin) - new Date(b.date_debut);
    return la - lb;
  });
  return matches[0] ?? null;
}

function getBlocage(d) {
  return blocages.find(b => {
    const deb = (b.date_debut || '').slice(0, 10);
    const fin = (b.date_fin   || '').slice(0, 10);
    return d >= deb && d <= fin;
  }) ?? null;
}

function getPrix(d) {
  const override = getTarifOverride(d);
  if (override) return { prix: Number(override.prix_journalier), type: 'custom', tarif: override };
  const tier = getDayTier(d);
  let prix;
  if (tier === 'tres_haute') prix = prixTresHaute || prixHaute;
  else if (tier === 'haute')  prix = prixHaute;
  else if (tier === 'moyenne') prix = prixMoyenne;
  else                         prix = prixBasse;
  return { prix, type: tier, tarif: null };
}

function fmtDate(s) {
  if (!s) return '—';
  const [y,m,d] = s.slice(0,10).split('-');
  return `${d}/${m}/${y}`;
}

// ─────────────────────────────────────────────────────────────────────────────
// Chargement véhicule
// ─────────────────────────────────────────────────────────────────────────────
async function loadVehicule(id, basse, moyenne, haute, tresHaute, gaId) {
  vehiculeId   = id;
  prixBasse    = parseFloat(basse)     || 0;
  prixMoyenne  = parseFloat(moyenne)   || 0;
  prixHaute    = parseFloat(haute)     || 0;
  prixTresHaute = parseFloat(tresHaute) || 0;

  document.getElementById('inp-basse').value      = prixBasse     || '';
  document.getElementById('inp-moyenne').value    = prixMoyenne   || '';
  document.getElementById('inp-haute').value      = prixHaute     || '';
  document.getElementById('inp-tres-haute').value = prixTresHaute || '';

  document.getElementById('sync-zone').style.display = gaId ? 'flex' : 'none';

  const [tRes, bRes, rRes] = await Promise.all([
    fetch('/api/admin/tarifs?vehicule_id=' + id, { credentials: 'include' }),
    fetch('/api/admin/block-dates?vehicule_id=' + id, { credentials: 'include' }),
    fetch('/api/admin/regles?vehicule_id=' + id, { credentials: 'include' }),
  ]);
  tarifs   = await tRes.json().catch(() => []);
  blocages = await bRes.json().catch(() => []);
  const regles = await rRes.json().catch(() => ({}));
  if (!Array.isArray(tarifs))   tarifs   = [];
  if (!Array.isArray(blocages)) blocages = [];

  applyRegles(regles);
  clearEdit();
  renderCalendar();
  renderTarifsList();

  document.getElementById('main-content').style.display = 'block';
  document.getElementById('no-vehicle').style.display   = 'none';

  if (gaId) syncGetaround(false);
}

function applyRegles(r) {
  document.getElementById('r-min-h').value    = r.duree_min_heures ?? 24;
  document.getElementById('r-min-unit').value = 'hours';
  document.getElementById('r-max-j').value    = r.duree_max_jours ?? '';
  document.getElementById('r-delai').value    = String(r.delai_reservation_heures ?? 0);
  document.getElementById('r-plage').value    = String(r.plage_disponibilite_jours ?? 90);
}

// ─────────────────────────────────────────────────────────────────────────────
// Rendu calendrier — style Getaround
// ─────────────────────────────────────────────────────────────────────────────
function renderCalendar() {
  const cal = document.getElementById('calendar');
  cal.innerHTML = '';
  document.getElementById('cal-title').textContent = MONTH_NAMES[month] + ' ' + year;

  const header = document.createElement('div');
  header.className = 'cal-header';
  ['LUN','MAR','MER','JEU','VEN','SAM','DIM'].forEach(j => {
    const h = document.createElement('div');
    h.className = 'cal-wday';
    h.textContent = j;
    header.appendChild(h);
  });
  cal.appendChild(header);

  const grid = document.createElement('div');
  grid.className = 'cal-grid';

  const firstDay  = new Date(year, month, 1);
  const totalDays = new Date(year, month + 1, 0).getDate();
  const startDow  = (firstDay.getDay() + 6) % 7;

  for (let i = 0; i < startDow; i++) {
    const e = document.createElement('div');
    e.className = 'cal-day empty';
    grid.appendChild(e);
  }

  for (let day = 1; day <= totalDays; day++) {
    const d      = `${year}-${pad(month+1)}-${pad(day)}`;
    const blocage = getBlocage(d);
    const vac    = getVacance(d);
    const ferie  = FERIES.has(d);
    const { prix, type, tarif } = getPrix(d);
    const isToday = d === TODAY;

    const inSel = rangeStart && rangeHover &&
      d >= Math.min(rangeStart, rangeHover) && d <= Math.max(rangeStart, rangeHover);

    const cell = document.createElement('div');
    cell.className = 'cal-day';
    cell.dataset.d = d;
    if (isToday) cell.classList.add('day-today');

    if (blocage) {
      cell.classList.add(blocage.source === 'getaround' ? 'day-ga' : 'day-blocked');
    } else {
      const tierClass = type === 'tres_haute' ? 'day-tres-haute'
                      : type === 'custom'     ? 'day-custom'
                      : 'day-' + type;
      cell.classList.add(tierClass);
      if (tarif) cell.style.setProperty('--cc', tarif.couleur || '#c9a84c');
    }
    if (inSel)           cell.classList.add('day-in-range');
    if (rangeStart === d) cell.classList.add('day-sel-start');

    // Numéro du jour
    const num = document.createElement('span');
    num.className = 'day-num';
    num.textContent = day;
    if (ferie) num.title = 'Jour férié ★';
    else if (vac) num.title = 'Vac. ' + vac.l;
    cell.appendChild(num);

    // Indicateur vacances/férié
    if ((ferie || vac) && !blocage) {
      const dot = document.createElement('span');
      dot.className = 'day-vac-label';
      dot.textContent = ferie ? '★' : vac.l === 'Été' ? '☀' : '▪';
      cell.appendChild(dot);
    }

    // Badge prix
    if (!blocage && prix > 0) {
      const badge = document.createElement('span');
      badge.className = 'day-price-badge';
      badge.textContent = prix + '€';
      cell.appendChild(badge);
    }

    // Label blocage
    if (blocage) {
      const lbl = document.createElement('span');
      lbl.className = 'day-lbl';
      lbl.textContent = blocage.source === 'getaround' ? 'GA' : '🔒';
      cell.appendChild(lbl);
    }

    if (!blocage) {
      cell.style.cursor = 'pointer';
      cell.addEventListener('click', () => onDayClick(d));
      cell.addEventListener('mouseenter', () => {
        if (rangeStart) { rangeHover = d; renderCalendar(); }
      });
    }

    grid.appendChild(cell);
  }

  cal.appendChild(grid);
}

// ─────────────────────────────────────────────────────────────────────────────
// Sélection jours / plage
// ─────────────────────────────────────────────────────────────────────────────
function onDayClick(d) {
  if (!rangeStart) {
    rangeStart = d; rangeHover = d;
    document.getElementById('hint-sel').textContent = 'Cliquez une 2ᵉ date pour une plage';
    renderCalendar();
    openEditPanel(d, d);
  } else if (d === rangeStart) {
    clearEdit();
    openEditPanel(d, d);
  } else {
    const a = rangeStart < d ? rangeStart : d;
    const b = rangeStart < d ? d : rangeStart;
    rangeStart = null; rangeHover = null;
    document.getElementById('hint-sel').textContent = '';
    renderCalendar();
    openEditPanel(a, b);
  }
}

function openEditPanel(debut, fin) {
  const panel = document.getElementById('panel-edit');
  const isSingle = debut === fin;
  document.getElementById('panel-title').textContent = isSingle
    ? '✏️ Tarif du ' + fmtDate(debut)
    : '✏️ Tarif du ' + fmtDate(debut) + ' au ' + fmtDate(fin);
  document.getElementById('panel-range').textContent = '';
  const { prix, tarif } = getPrix(debut);
  document.getElementById('t-prix').value  = prix || '';
  document.getElementById('t-label').value = tarif?.label || '';
  document.getElementById('panel-err').style.display = 'none';
  panel.dataset.debut = debut;
  panel.dataset.fin   = fin;
  panel.style.display = 'block';
  panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function clearEdit() {
  rangeStart = null; rangeHover = null;
  document.getElementById('hint-sel').textContent = '';
  document.getElementById('panel-edit').style.display = 'none';
}

// ─────────────────────────────────────────────────────────────────────────────
// Sauvegarde tarif personnalisé
// ─────────────────────────────────────────────────────────────────────────────
document.getElementById('btn-save-tarif').addEventListener('click', async () => {
  const panel  = document.getElementById('panel-edit');
  const errEl  = document.getElementById('panel-err');
  const prix   = parseFloat(document.getElementById('t-prix').value);
  const label  = document.getElementById('t-label').value.trim();
  const debut  = panel.dataset.debut;
  const fin    = panel.dataset.fin;

  if (!prix || prix <= 0) {
    errEl.textContent = 'Entrez un prix valide.';
    errEl.style.display = 'block';
    return;
  }

  const btn = document.getElementById('btn-save-tarif');
  btn.disabled = true; btn.textContent = '⏳…';

  const tier    = getDayTier(debut);
  const couleur = tier === 'tres_haute' ? '#166534'
                : tier === 'haute'      ? '#16a34a'
                : tier === 'moyenne'    ? '#4ade80'
                :                        '#86efac';

  try {
    const res = await fetch('/api/admin/tarifs', {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ vehicule_id: vehiculeId, date_debut: debut, date_fin: fin, prix_journalier: prix, label, couleur }),
    });
    const data = await res.json();
    if (data.success) {
      const tRes = await fetch('/api/admin/tarifs?vehicule_id=' + vehiculeId, { credentials: 'include' });
      tarifs = await tRes.json().catch(() => []);
      if (!Array.isArray(tarifs)) tarifs = [];
      clearEdit(); renderCalendar(); renderTarifsList();
    } else {
      errEl.textContent = data.error || 'Erreur';
      errEl.style.display = 'block';
    }
  } catch {
    errEl.textContent = 'Erreur réseau';
    errEl.style.display = 'block';
  } finally {
    btn.disabled = false; btn.textContent = 'Enregistrer';
  }
});

document.getElementById('btn-cancel-edit').addEventListener('click', clearEdit);

// ─────────────────────────────────────────────────────────────────────────────
// Sauvegarde prix de saison
// ─────────────────────────────────────────────────────────────────────────────
document.getElementById('btn-save-prix').addEventListener('click', async () => {
  const msg = document.getElementById('prix-msg');
  const btn = document.getElementById('btn-save-prix');
  const b  = parseFloat(document.getElementById('inp-basse').value)      || null;
  const m  = parseFloat(document.getElementById('inp-moyenne').value)    || null;
  const h  = parseFloat(document.getElementById('inp-haute').value)      || null;
  const th = parseFloat(document.getElementById('inp-tres-haute').value) || null;

  btn.disabled = true; btn.textContent = '⏳…';

  try {
    const res = await fetch('/api/admin/vehicule-prix', {
      method: 'PUT', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ vehicule_id: vehiculeId, prix_basse: b, prix_moyenne: m, prix_haute: h, prix_tres_haute: th }),
    });
    const data = await res.json();
    if (data.success) {
      if (b  !== null) prixBasse     = b;
      if (m  !== null) prixMoyenne   = m;
      if (h  !== null) prixHaute     = h;
      if (th !== null) prixTresHaute = th;
      msg.className = 'form-msg ok'; msg.textContent = '✅ Prix de saison enregistrés';
      msg.style.display = 'block';
      renderCalendar();
      setTimeout(() => msg.style.display = 'none', 3000);
    } else {
      msg.className = 'form-msg ko'; msg.textContent = '❌ ' + (data.error || 'Erreur');
      msg.style.display = 'block';
    }
  } catch {
    msg.className = 'form-msg ko'; msg.textContent = '❌ Erreur réseau';
    msg.style.display = 'block';
  } finally {
    btn.disabled = false; btn.textContent = '💾 Enregistrer les prix de saison';
  }
});

// ─────────────────────────────────────────────────────────────────────────────
// Liste des tarifs personnalisés
// ─────────────────────────────────────────────────────────────────────────────
function renderTarifsList() {
  const card = document.getElementById('tarifs-list-card');
  const list = document.getElementById('tarifs-list');
  if (!tarifs.length) { card.style.display = 'none'; return; }
  card.style.display = 'block';

  list.innerHTML = tarifs.map(t => `
    <div class="tarif-row" data-id="${t.id}">
      <span class="tarif-dot" style="background:${t.couleur || '#c9a84c'}"></span>
      <span class="tarif-info">
        <span class="tarif-lbl">${t.label || '—'}</span>
        <span class="tarif-dates">${fmtDate(t.date_debut)} → ${fmtDate(t.date_fin)}</span>
      </span>
      <span class="tarif-prix">${Number(t.prix_journalier).toFixed(0)} €/j</span>
      <button class="btn-del" data-id="${t.id}">🗑️</button>
    </div>
  `).join('');

  list.querySelectorAll('.btn-del').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer ce tarif personnalisé ?')) return;
      btn.disabled = true;
      const res  = await fetch('/api/admin/tarifs', {
        method: 'DELETE', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: btn.dataset.id }),
      });
      const data = await res.json();
      if (data.success) {
        tarifs = tarifs.filter(t => t.id !== btn.dataset.id);
        renderCalendar(); renderTarifsList();
      } else {
        alert('Erreur : ' + (data.error || 'Inconnu'));
        btn.disabled = false;
      }
    });
  });
}

// ─────────────────────────────────────────────────────────────────────────────
// Règles de location
// ─────────────────────────────────────────────────────────────────────────────
document.getElementById('form-regles').addEventListener('submit', async (e) => {
  e.preventDefault();
  const msg = document.getElementById('regles-msg');
  const btn = e.target.querySelector('button[type=submit]');
  const minVal  = parseInt(document.getElementById('r-min-h').value) || 24;
  const minUnit = document.getElementById('r-min-unit').value;
  btn.disabled = true; btn.textContent = '⏳…';

  const res = await fetch('/api/admin/regles', {
    method: 'PUT', credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      vehicule_id:               vehiculeId,
      duree_min_heures:          minUnit === 'days' ? minVal * 24 : minVal,
      duree_max_jours:           document.getElementById('r-max-j').value || null,
      delai_reservation_heures:  document.getElementById('r-delai').value,
      plage_disponibilite_jours: document.getElementById('r-plage').value,
    }),
  });
  const data = await res.json();
  msg.className = data.success ? 'form-msg ok' : 'form-msg ko';
  msg.textContent = data.success ? '✅ Règles enregistrées' : '❌ ' + (data.error || 'Erreur');
  msg.style.display = 'block';
  btn.disabled = false; btn.textContent = '💾 Enregistrer';
  setTimeout(() => msg.style.display = 'none', 3000);
});

// ─────────────────────────────────────────────────────────────────────────────
// Sync Getaround
// ─────────────────────────────────────────────────────────────────────────────
async function syncGetaround(showFeedback = true) {
  const btn    = document.getElementById('btn-sync');
  const status = document.getElementById('sync-status');
  if (showFeedback) { btn.disabled = true; status.textContent = '⏳…'; status.className = 'sync-status pending'; }
  try {
    const res  = await fetch('/api/sync-calendar', { credentials: 'include' });
    const data = await res.json();
    if (data.success) {
      const bRes = await fetch('/api/admin/block-dates?vehicule_id=' + vehiculeId, { credentials: 'include' });
      blocages = await bRes.json().catch(() => []);
      if (!Array.isArray(blocages)) blocages = [];
      renderCalendar();
      if (showFeedback) { status.textContent = `✅ ${data.synced} période(s)`; status.className = 'sync-status ok'; }
    } else {
      if (showFeedback) { status.textContent = '❌ ' + (data.error || 'Erreur'); status.className = 'sync-status err'; }
    }
  } catch {
    if (showFeedback) { status.textContent = '❌ Réseau'; status.className = 'sync-status err'; }
  } finally {
    if (showFeedback) { btn.disabled = false; setTimeout(() => { status.textContent = ''; status.className = 'sync-status'; }, 5000); }
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// Événements UI
// ─────────────────────────────────────────────────────────────────────────────
document.getElementById('btn-prev').addEventListener('click', () => {
  month--; if (month < 0) { month = 11; year--; } clearEdit(); renderCalendar();
});
document.getElementById('btn-next').addEventListener('click', () => {
  month++; if (month > 11) { month = 0; year++; } clearEdit(); renderCalendar();
});

document.getElementById('sel-vehicule').addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  if (!this.value) {
    document.getElementById('main-content').style.display = 'none';
    document.getElementById('no-vehicle').style.display   = 'block';
    document.getElementById('sync-zone').style.display    = 'none';
    return;
  }
  loadVehicule(this.value, opt.dataset.basse, opt.dataset.moyenne, opt.dataset.haute, opt.dataset.tresHaute, opt.dataset.ga);
});

document.getElementById('sel-zone').addEventListener('change', function() {
  zone = this.value; renderCalendar();
});

document.getElementById('btn-sync').addEventListener('click', () => syncGetaround(true));

// ─────────────────────────────────────────────────────────────────────────────
// Auto-sélection via URL param ?vehicule=UUID
// ─────────────────────────────────────────────────────────────────────────────
(function() {
  const params = new URLSearchParams(location.search);
  const preselId = params.get('vehicule');
  if (!preselId) return;
  const sel = document.getElementById('sel-vehicule');
  const opt = [...sel.options].find(o => o.value === preselId);
  if (!opt) return;
  sel.value = preselId;
  loadVehicule(opt.value, opt.dataset.basse, opt.dataset.moyenne, opt.dataset.haute, opt.dataset.tresHaute, opt.dataset.ga);
})();
</script>

