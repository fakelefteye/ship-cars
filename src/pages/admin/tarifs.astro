---
// src/pages/admin/tarifs.astro — Tarification dynamique & règles de location
import MainLayout from '../../layouts/MainLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const cookies = Astro.request.headers.get('cookie') || '';
if (!cookies.includes('admin_auth=true')) return Astro.redirect('/admin');

const { data: vehicules } = await supabaseAdmin
  .from('vehicules')
  .select('id, nom, prix_journalier_base')
  .order('nom');
---

<MainLayout title="Tarifs & Disponibilité — Admin Ship Cars">
<div class="admin-container">

  <header class="page-header">
    <div class="header-left">
      <a href="/admin" class="back-link">← Tableau de bord</a>
      <h1>💰 Tarifs &amp; Disponibilité</h1>
      <p class="subtitle">Calendrier tarifaire, vacances scolaires, règles de location.</p>
    </div>
  </header>

  <!-- Sélecteur de véhicule -->
  <div class="vehicle-selector-bar">
    <label for="sel-vehicule" class="sel-label">Véhicule :</label>
    <select id="sel-vehicule" class="sel-vehicule">
      <option value="">Choisir un véhicule...</option>
      {vehicules?.map((v) => (
        <option value={v.id} data-prix={v.prix_journalier_base}>{v.nom} — {v.prix_journalier_base}€/j</option>
      ))}
    </select>
    <span id="prix-base-badge" class="prix-badge" style="display:none;"></span>
  </div>

  <div id="main-content" style="display:none;">

    <div class="two-col">

      <!-- ── COLONNE GAUCHE ───────────────────────────────── -->
      <aside class="sidebar">

        <!-- Règles de location -->
        <section class="card">
          <h2>⚙️ Règles de location</h2>
          <form id="form-regles">

            <div class="field-group">
              <label>Durée minimale</label>
              <div class="input-with-unit">
                <input type="number" id="r-min-h" min="1" value="24" />
                <select id="r-min-unit">
                  <option value="hours">heures</option>
                  <option value="days" selected>jours</option>
                </select>
              </div>
              <p class="hint">Ex : 24h = 1 jour minimum</p>
            </div>

            <div class="field-group">
              <label>Durée maximale <span class="opt">(optionnel)</span></label>
              <div class="input-with-unit">
                <input type="number" id="r-max-j" min="1" placeholder="Illimité" />
                <span class="unit-label">jours</span>
              </div>
            </div>

            <div class="field-group">
              <label>Préavis minimum</label>
              <select id="r-delai">
                <option value="0">Réservations de dernière minute OK</option>
                <option value="2">2 heures avant</option>
                <option value="6">6 heures avant</option>
                <option value="12">12 heures avant</option>
                <option value="24">24 heures avant</option>
                <option value="48">48 heures avant</option>
                <option value="72">3 jours avant</option>
              </select>
            </div>

            <div class="field-group">
              <label>Plage de disponibilité</label>
              <select id="r-plage">
                <option value="30">1 mois</option>
                <option value="60">2 mois</option>
                <option value="90" selected>3 mois</option>
                <option value="120">4 mois</option>
                <option value="180">6 mois</option>
                <option value="365">1 an</option>
              </select>
              <p class="hint">Empêche les réservations trop éloignées</p>
            </div>

            <div id="regles-msg" class="form-msg" style="display:none;"></div>
            <button type="submit" class="btn-save">💾 Enregistrer les règles</button>
          </form>
        </section>

        <!-- Ajouter un tarif -->
        <section class="card">
          <h2>➕ Ajouter un tarif</h2>
          <p class="card-hint">Cliquez sur deux jours dans le calendrier pour pré-remplir les dates, ou saisissez-les manuellement.</p>
          <form id="form-tarif">

            <div class="field-group">
              <label>Du</label>
              <input type="date" id="t-debut" required />
            </div>
            <div class="field-group">
              <label>Au (inclus)</label>
              <input type="date" id="t-fin" required />
            </div>
            <div class="field-group">
              <label>Prix / jour (€)</label>
              <input type="number" id="t-prix" min="0" step="0.01" required placeholder="Ex: 120" />
            </div>
            <div class="field-group">
              <label>Libellé <span class="opt">(optionnel)</span></label>
              <input type="text" id="t-label" placeholder="Ex: Vacances d'été" />
            </div>
            <div class="field-group">
              <label>Couleur</label>
              <div class="color-row">
                <input type="color" id="t-couleur" value="#c9a84c" />
                <div class="color-presets">
                  <button type="button" class="preset" style="background:#e74c3c;" data-c="#e74c3c" title="Rouge"></button>
                  <button type="button" class="preset" style="background:#e67e22;" data-c="#e67e22" title="Orange"></button>
                  <button type="button" class="preset" style="background:#c9a84c;" data-c="#c9a84c" title="Or"></button>
                  <button type="button" class="preset" style="background:#27ae60;" data-c="#27ae60" title="Vert"></button>
                  <button type="button" class="preset" style="background:#3498db;" data-c="#3498db" title="Bleu"></button>
                  <button type="button" class="preset" style="background:#9b59b6;" data-c="#9b59b6" title="Violet"></button>
                </div>
              </div>
            </div>

            <div id="tarif-msg" class="form-msg" style="display:none;"></div>
            <button type="submit" class="btn-add">Ajouter ce tarif</button>
          </form>
        </section>

        <!-- Zone scolaire -->
        <section class="card">
          <h2>🏫 Zone scolaire</h2>
          <p class="card-hint">Choisir votre zone pour afficher les bonnes vacances.</p>
          <div class="zone-btns">
            <button class="btn-zone active" data-zone="A">Zone A</button>
            <button class="btn-zone" data-zone="B">Zone B</button>
            <button class="btn-zone" data-zone="C">Zone C</button>
          </div>
          <div class="legend">
            <div class="leg-item"><span class="dot" style="background:#3b5bdb;"></span> Vacances scolaires</div>
            <div class="leg-item"><span class="dot" style="background:#e74c3c;"></span> Jour férié / pont</div>
            <div class="leg-item"><span class="dot" style="background:#c9a84c;"></span> Tarif personnalisé</div>
          </div>
        </section>

      </aside>

      <!-- ── COLONNE DROITE : CALENDRIER ─────────────────── -->
      <div class="calendar-area">
        <div class="cal-nav">
          <button id="btn-prev" class="btn-nav">◀</button>
          <span id="cal-title" class="cal-title"></span>
          <button id="btn-next" class="btn-nav">▶</button>
        </div>
        <div id="calendar-grid" class="calendar-grid"></div>

        <!-- Tarifs actifs -->
        <section class="card tarifs-list-card" id="tarifs-list-section" style="display:none;">
          <h2>📋 Tarifs personnalisés actifs</h2>
          <div id="tarifs-list"></div>
        </section>
      </div>

    </div>
  </div>

  <div id="no-vehicle" class="no-vehicle">
    <p>← Sélectionnez un véhicule pour gérer ses tarifs.</p>
  </div>

</div>
</MainLayout>

<script is:inline>
// ══════════════════════════════════════════════════════════════════
// Données : vacances scolaires & jours fériés France
// ══════════════════════════════════════════════════════════════════
const VACANCES = {
  A: [
    // 2025-2026
    { label: 'Toussaint', debut: '2025-10-18', fin: '2025-11-03' },
    { label: 'Noël',      debut: '2025-12-20', fin: '2026-01-05' },
    { label: 'Hiver',     debut: '2026-02-21', fin: '2026-03-09' },
    { label: 'Printemps', debut: '2026-04-18', fin: '2026-05-04' },
    { label: 'Été',       debut: '2026-07-04', fin: '2026-08-31' },
    // 2026-2027
    { label: 'Toussaint', debut: '2026-10-17', fin: '2026-11-02' },
    { label: 'Noël',      debut: '2026-12-19', fin: '2027-01-04' },
    { label: 'Hiver',     debut: '2027-02-20', fin: '2027-03-08' },
    { label: 'Printemps', debut: '2027-04-10', fin: '2027-04-26' },
    { label: 'Été',       debut: '2027-07-03', fin: '2027-08-31' },
  ],
  B: [
    { label: 'Toussaint', debut: '2025-10-18', fin: '2025-11-03' },
    { label: 'Noël',      debut: '2025-12-20', fin: '2026-01-05' },
    { label: 'Hiver',     debut: '2026-02-07', fin: '2026-02-23' },
    { label: 'Printemps', debut: '2026-04-25', fin: '2026-05-11' },
    { label: 'Été',       debut: '2026-07-04', fin: '2026-08-31' },
    { label: 'Toussaint', debut: '2026-10-17', fin: '2026-11-02' },
    { label: 'Noël',      debut: '2026-12-19', fin: '2027-01-04' },
    { label: 'Hiver',     debut: '2027-02-06', fin: '2027-02-22' },
    { label: 'Printemps', debut: '2027-04-17', fin: '2027-05-03' },
    { label: 'Été',       debut: '2027-07-03', fin: '2027-08-31' },
  ],
  C: [
    { label: 'Toussaint', debut: '2025-10-18', fin: '2025-11-03' },
    { label: 'Noël',      debut: '2025-12-20', fin: '2026-01-05' },
    { label: 'Hiver',     debut: '2026-02-14', fin: '2026-03-02' },
    { label: 'Printemps', debut: '2026-04-11', fin: '2026-04-27' },
    { label: 'Été',       debut: '2026-07-04', fin: '2026-08-31' },
    { label: 'Toussaint', debut: '2026-10-17', fin: '2026-11-02' },
    { label: 'Noël',      debut: '2026-12-19', fin: '2027-01-04' },
    { label: 'Hiver',     debut: '2027-02-13', fin: '2027-03-01' },
    { label: 'Printemps', debut: '2027-04-03', fin: '2027-04-19' },
    { label: 'Été',       debut: '2027-07-03', fin: '2027-08-31' },
  ],
};

const FERIES = new Set([
  '2026-01-01','2026-04-06','2026-05-01','2026-05-08','2026-05-14',
  '2026-05-15','2026-05-25','2026-07-14','2026-08-15','2026-11-01',
  '2026-11-11','2026-12-25',
  '2027-01-01','2027-04-05','2027-05-01','2027-05-08','2027-05-13',
  '2027-05-24','2027-07-14','2027-08-15','2027-11-01','2027-11-11',
  '2027-12-25',
]);

// Ponts (entre un férié et un week-end)
const PONTS = new Set([
  '2026-05-15', // vendredi après Ascension
]);

// ══════════════════════════════════════════════════════════════════
// État global
// ══════════════════════════════════════════════════════════════════
let currentVehiculeId = '';
let currentPrixBase   = 0;
let currentZone       = 'A';
let currentYear       = new Date().getFullYear();
let currentMonth      = new Date().getMonth(); // 0-11
let tarifs            = [];
let selectStart       = null; // date string sélectionnée en premier clic

// ══════════════════════════════════════════════════════════════════
// Helpers
// ══════════════════════════════════════════════════════════════════
function toDS(d) {
  return d.toISOString().split('T')[0];
}
function addDays(ds, n) {
  const d = new Date(ds + 'T12:00:00');
  d.setDate(d.getDate() + n);
  return toDS(d);
}
function isBetween(ds, debut, fin) {
  return ds >= debut && ds <= fin;
}
function isVacance(ds) {
  return VACANCES[currentZone].some(v => isBetween(ds, v.debut, v.fin));
}
function getVacanceLabel(ds) {
  const v = VACANCES[currentZone].find(v => isBetween(ds, v.debut, v.fin));
  return v ? 'Vac. ' + v.label : '';
}
function getTarifForDay(ds) {
  return tarifs.find(t => ds >= t.date_debut && ds <= t.date_fin) ?? null;
}
function monthName(m) {
  return ['Janvier','Février','Mars','Avril','Mai','Juin',
          'Juillet','Août','Septembre','Octobre','Novembre','Décembre'][m];
}

// ══════════════════════════════════════════════════════════════════
// Rendu du calendrier (3 mois)
// ══════════════════════════════════════════════════════════════════
function renderCalendar() {
  const grid = document.getElementById('calendar-grid');
  grid.innerHTML = '';

  document.getElementById('cal-title').textContent =
    monthName(currentMonth) + ' ' + currentYear;

  for (let offset = 0; offset < 3; offset++) {
    let m = currentMonth + offset;
    let y = currentYear;
    if (m > 11) { m -= 12; y++; }

    const monthDiv = document.createElement('div');
    monthDiv.className = 'cal-month';

    const titleEl = document.createElement('div');
    titleEl.className = 'cal-month-title';
    titleEl.textContent = monthName(m) + ' ' + y;
    monthDiv.appendChild(titleEl);

    // En-têtes jours
    const weekRow = document.createElement('div');
    weekRow.className = 'cal-week-row';
    ['Lu','Ma','Me','Je','Ve','Sa','Di'].forEach(d => {
      const h = document.createElement('div');
      h.className = 'cal-weekday';
      h.textContent = d;
      weekRow.appendChild(h);
    });
    monthDiv.appendChild(weekRow);

    const daysGrid = document.createElement('div');
    daysGrid.className = 'cal-days-grid';

    const firstDay = new Date(y, m, 1);
    const totalDays = new Date(y, m + 1, 0).getDate();
    // Lundi = 0, Dimanche = 6
    let startDow = (firstDay.getDay() + 6) % 7;
    for (let i = 0; i < startDow; i++) {
      const empty = document.createElement('div');
      empty.className = 'cal-day empty';
      daysGrid.appendChild(empty);
    }

    for (let day = 1; day <= totalDays; day++) {
      const ds = `${y}-${String(m+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
      const tarif = getTarifForDay(ds);
      const vac   = isVacance(ds);
      const ferie = FERIES.has(ds);
      const pont  = PONTS.has(ds);
      const prix  = tarif ? Number(tarif.prix_journalier) : currentPrixBase;

      const cell = document.createElement('div');
      cell.className = 'cal-day';
      cell.dataset.ds = ds;

      if (ferie || pont)  cell.classList.add('ferie');
      else if (vac)       cell.classList.add('vacance');
      if (tarif)          cell.style.setProperty('--tarif-color', tarif.couleur || '#c9a84c');
      if (tarif)          cell.classList.add('tarif-custom');
      if (selectStart === ds) cell.classList.add('sel-start');

      const numEl = document.createElement('span');
      numEl.className = 'day-num';
      numEl.textContent = String(day);
      cell.appendChild(numEl);

      if (currentPrixBase > 0) {
        const priceEl = document.createElement('span');
        priceEl.className = 'day-price';
        priceEl.textContent = prix + '€';
        cell.appendChild(priceEl);
      }

      let tooltip = '';
      if (ferie || pont) tooltip = 'Jour férié' + (pont ? ' / Pont' : '');
      else if (vac)      tooltip = getVacanceLabel(ds);
      if (tarif?.label)  tooltip += (tooltip ? ' · ' : '') + tarif.label;
      if (tooltip)       cell.title = tooltip;

      cell.addEventListener('click', () => onDayClick(ds));
      daysGrid.appendChild(cell);
    }

    monthDiv.appendChild(daysGrid);
    grid.appendChild(monthDiv);
  }
}

function onDayClick(ds) {
  if (!selectStart) {
    selectStart = ds;
    document.getElementById('t-debut').value = ds;
    document.getElementById('t-fin').value = '';
    renderCalendar();
  } else {
    const a = selectStart < ds ? selectStart : ds;
    const b = selectStart < ds ? ds : selectStart;
    document.getElementById('t-debut').value = a;
    document.getElementById('t-fin').value   = b;
    selectStart = null;
    renderCalendar();
  }
}

// ══════════════════════════════════════════════════════════════════
// Chargement données véhicule
// ══════════════════════════════════════════════════════════════════
async function loadVehicule(id, prixBase) {
  currentVehiculeId = id;
  currentPrixBase   = parseFloat(prixBase);

  // Badge prix
  const badge = document.getElementById('prix-base-badge');
  badge.textContent = 'Prix de base : ' + prixBase + ' €/j';
  badge.style.display = 'inline-block';

  // Tarifs
  const res = await fetch('/api/admin/tarifs?vehicule_id=' + id);
  tarifs = await res.json();
  renderCalendar();
  renderTarifsList();

  // Règles
  const rRes = await fetch('/api/admin/regles?vehicule_id=' + id);
  const regles = await rRes.json();
  applyReglesToForm(regles);

  document.getElementById('main-content').style.display = 'block';
  document.getElementById('no-vehicle').style.display   = 'none';
}

function applyReglesToForm(r) {
  document.getElementById('r-min-h').value   = r.duree_min_heures ?? 24;
  document.getElementById('r-min-unit').value = 'hours';
  document.getElementById('r-max-j').value   = r.duree_max_jours ?? '';
  document.getElementById('r-delai').value   = String(r.delai_reservation_heures ?? 0);
  document.getElementById('r-plage').value   = String(r.plage_disponibilite_jours ?? 90);
}

// ══════════════════════════════════════════════════════════════════
// Liste des tarifs actifs
// ══════════════════════════════════════════════════════════════════
function renderTarifsList() {
  const section = document.getElementById('tarifs-list-section');
  const list    = document.getElementById('tarifs-list');

  if (!tarifs.length) {
    section.style.display = 'none';
    return;
  }
  section.style.display = 'block';

  list.innerHTML = tarifs.map(t => `
    <div class="tarif-row" data-id="${t.id}">
      <span class="tarif-dot" style="background:${t.couleur || '#c9a84c'};"></span>
      <span class="tarif-label">${t.label || '—'}</span>
      <span class="tarif-dates">${t.date_debut} → ${t.date_fin}</span>
      <span class="tarif-prix">${Number(t.prix_journalier).toFixed(0)} €/j</span>
      <button class="btn-del-tarif" data-id="${t.id}">🗑️</button>
    </div>
  `).join('');

  list.querySelectorAll('.btn-del-tarif').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Supprimer ce tarif ?')) return;
      await fetch('/api/admin/tarifs', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: btn.dataset.id }),
      });
      await loadVehicule(currentVehiculeId, currentPrixBase);
    });
  });
}

// ══════════════════════════════════════════════════════════════════
// Événements
// ══════════════════════════════════════════════════════════════════
document.getElementById('sel-vehicule').addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  if (!this.value) {
    document.getElementById('main-content').style.display = 'none';
    document.getElementById('no-vehicle').style.display   = 'block';
    document.getElementById('prix-base-badge').style.display = 'none';
    return;
  }
  loadVehicule(this.value, opt.dataset.prix);
});

document.getElementById('btn-prev').addEventListener('click', () => {
  currentMonth--;
  if (currentMonth < 0) { currentMonth = 11; currentYear--; }
  renderCalendar();
});
document.getElementById('btn-next').addEventListener('click', () => {
  currentMonth++;
  if (currentMonth > 11) { currentMonth = 0; currentYear++; }
  renderCalendar();
});

document.querySelectorAll('.btn-zone').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.btn-zone').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentZone = btn.dataset.zone;
    renderCalendar();
  });
});

document.querySelectorAll('.preset').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('t-couleur').value = btn.dataset.c;
  });
});

// Formulaire règles
document.getElementById('form-regles').addEventListener('submit', async (e) => {
  e.preventDefault();
  const msg = document.getElementById('regles-msg');
  const minVal  = parseInt(document.getElementById('r-min-h').value) || 24;
  const minUnit = document.getElementById('r-min-unit').value;
  const minH    = minUnit === 'days' ? minVal * 24 : minVal;

  const btn = e.target.querySelector('button[type=submit]');
  btn.disabled = true; btn.textContent = '⏳...';

  const res = await fetch('/api/admin/regles', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      vehicule_id:              currentVehiculeId,
      duree_min_heures:         minH,
      duree_max_jours:          document.getElementById('r-max-j').value || null,
      delai_reservation_heures: document.getElementById('r-delai').value,
      plage_disponibilite_jours:document.getElementById('r-plage').value,
    }),
  });
  const data = await res.json();
  msg.style.display = 'block';
  if (data.success) {
    msg.className = 'form-msg ok'; msg.textContent = '✅ Règles enregistrées';
  } else {
    msg.className = 'form-msg ko'; msg.textContent = '❌ ' + (data.error || 'Erreur');
  }
  btn.disabled = false; btn.textContent = '💾 Enregistrer les règles';
  setTimeout(() => msg.style.display = 'none', 3000);
});

// Formulaire tarif
document.getElementById('form-tarif').addEventListener('submit', async (e) => {
  e.preventDefault();
  const msg = document.getElementById('tarif-msg');
  const btn = e.target.querySelector('button[type=submit]');
  btn.disabled = true; btn.textContent = '⏳...';

  const res = await fetch('/api/admin/tarifs', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      vehicule_id:    currentVehiculeId,
      date_debut:     document.getElementById('t-debut').value,
      date_fin:       document.getElementById('t-fin').value,
      prix_journalier:document.getElementById('t-prix').value,
      label:          document.getElementById('t-label').value,
      couleur:        document.getElementById('t-couleur').value,
    }),
  });
  const data = await res.json();
  msg.style.display = 'block';
  if (data.success) {
    msg.className = 'form-msg ok'; msg.textContent = '✅ Tarif ajouté';
    e.target.reset();
    document.getElementById('t-couleur').value = '#c9a84c';
    await loadVehicule(currentVehiculeId, currentPrixBase);
  } else {
    msg.className = 'form-msg ko'; msg.textContent = '❌ ' + (data.error || 'Erreur');
  }
  btn.disabled = false; btn.textContent = 'Ajouter ce tarif';
  setTimeout(() => msg.style.display = 'none', 3000);
});

// Init calendrier vide
renderCalendar();
</script>

<style>
