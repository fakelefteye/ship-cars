const desc     = "Tout savoir sur le lac de Monteynard depuis Grenoble : comment y aller en voiture ou en bus, se garer pas cher grâce à la reconnaissance de plaque, et profiter du kitesurf, wingfoil, catamaran, passerelles himalayennes, bateau La Mira, VTT électrique, canoë et bien plus.";
---

<MainLayout title={`${titre} | Blog Ship Cars`}>
  <Fragment slot="head">
    <meta name="description" content={desc} />
